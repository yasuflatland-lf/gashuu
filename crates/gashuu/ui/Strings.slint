// Fluent-served static-string surface (issue 113). Property names equal the Fluent
// message IDs in i18n/en/gashuu.ftl; Rust pushes values via `Localizer::push_strings_to_ui()` (English
// defaults prevent blanks). The four `stepper-*` labels are composed in Rust, never concatenated.

export global Strings {
    // ── SettingsDialog ────────────────────────────────────────────────────────
    in property <string> settings-book-title: "Book settings";
    in property <string> settings-title: "Settings";
    in property <string> settings-section-reading: "Reading";
    in property <string> settings-section-display: "Display";
    in property <string> settings-section-performance: "Performance";
    in property <string> settings-section-general: "General";
    in property <string> settings-section-data: "Data";
    in property <string> settings-clear-history-label: "Clear reading history";
    in property <string> settings-clear-cache-label: "Clear cover cache";
    // ── SettingsDialog: About (auto-update epic, Task 10) ─────────────────────
    in property <string> settings-section-about: "About";
    in property <string> settings-auto-update-label: "Check for updates automatically";
    in property <string> settings-auto-update-a11y: "Check for updates automatically";
    in property <string> settings-check-updates-label: "Check for updates now";
    in property <string> settings-direction-label: "Direction";
    in property <string> settings-direction-ltr: "Left to Right";
    in property <string> settings-direction-rtl: "Right to Left";
    in property <string> settings-direction-a11y: "Reading direction";
    in property <string> settings-spread-label: "Spread";
    in property <string> settings-spread-single: "Single";
    in property <string> settings-spread-double: "Double";
    in property <string> settings-spread-auto: "Auto";
    in property <string> settings-spread-a11y: "Spread mode";
    in property <string> settings-cover-label: "Cover";
    in property <string> settings-cover-standalone: "Standalone";
    in property <string> settings-cover-paired: "Paired";
    in property <string> settings-cover-a11y: "Cover mode";
    in property <string> settings-fit-label: "Fit";
    in property <string> settings-fit-whole: "Whole";
    in property <string> settings-fit-width: "Width";
    in property <string> settings-fit-actual: "Actual";
    in property <string> settings-fit-a11y: "Fit mode";
    in property <string> settings-cache-label: "Cache size (pages)";
    in property <string> settings-cache-a11y: "Cache size in pages";
    in property <string> settings-preload-label: "Preload radius";
    in property <string> settings-preload-a11y: "Preload radius";
    in property <string> settings-track-recent-label: "Track recent files";
    in property <string> settings-track-recent-a11y: "Track recent files";
    in property <string> settings-allow-rar-label: "Allow CBR/RAR archives";
    in property <string> settings-allow-rar-a11y: "Allow CBR/RAR archives";
    in property <string> settings-performance-note: "Cache & preload apply to newly opened books.";
    in property <string> settings-language-label: "Language";
    in property <string> settings-language-a11y: "Display language";
    in property <string> settings-shortcuts-label: "⌨ Shortcuts";
    in property <string> settings-reset-to-global: "Reset to global";

    // ── ShortcutsOverlay ──────────────────────────────────────────────────────
    in property <string> shortcuts-title: "Keyboard shortcuts";

    // ── Carousel ──────────────────────────────────────────────────────────────
    in property <string> carousel-empty-title: "Your library is empty";
    in property <string> carousel-empty-subtitle: "Add books to start your shelf.";
    in property <string> carousel-empty-cta: "Select folders / files to add";
    in property <string> carousel-empty-cta-files: "Select files to add";
    in property <string> carousel-no-results-title: "No matching books";
    in property <string> carousel-no-results-hint: "Try a different search.";
    in property <string> cover-failed-label: "Can't open";
    // Drop-zone overlay shown while a file/folder drag hovers the Library screen.
    in property <string> drag-drop-hint: "Drop here to add";

    // ── BookmarkRibbon ────────────────────────────────────────────────────────
    in property <string> continue-reading: "Continue reading";

    // ── NavBar ────────────────────────────────────────────────────────────────
    in property <string> navbar-search-placeholder: "Search library";
    in property <string> navbar-search-a11y: "Search library";
    in property <string> navbar-add-files-a11y: "Add files";
    in property <string> navbar-add-folder-a11y: "Add folder";
    in property <string> navbar-add-books-a11y: "Add books";

    // ── ViewerPill ────────────────────────────────────────────────────────────
    in property <string> viewer-pill-goto-page-a11y: "Go to page";
    in property <string> viewer-pill-thumbnails-a11y: "Toggle thumbnails";

    // ── shared ────────────────────────────────────────────────────────────────
    in property <string> common-close: "Close";

    // ── ConfirmDialog ─────────────────────────────────────────────────────────
    in property <string> confirm-delete-cancel: "Cancel";

    // ── UpdateAvailableDialog (auto-update epic, Task 9) ──────────────────────
    in property <string> update-available-title: "Update available";
    in property <string> update-notes-label: "Release notes";
    in property <string> update-accept-label: "Update now";
    in property <string> update-later-label: "Later";
    in property <string> update-skip-label: "Skip this version";
    // Dynamic status messages set from Rust during an update check (handlers/update.rs);
    // Rust reads these getters instead of hardcoding literals so the status is localized.
    in property <string> update-status-checking: "Checking for updates…";
    in property <string> update-status-latest: "You're on the latest version.";
    in property <string> update-status-failed: "Couldn't check for updates.";
    in property <string> update-status-downloading: "Downloading…";
    in property <string> update-status-download-failed: "Download failed. Opening the release page…";
    in property <string> update-status-restarting: "Restarting to finish the update…";

    // ── SelectionToolbar ──────────────────────────────────────────────────────
    in property <string> selection-enter: "Select";
    in property <string> selection-exit-a11y: "Exit selection mode";
    // DangerButton label; doubles as the confirm-button label in the bulk-delete
    // ConfirmDialog (a parallel cluster binds Strings.selection-delete there).
    in property <string> selection-delete: "Delete";

    // ── Stepper composed (pre-composed in Rust via Fluent named args) ─────────
    in property <string> stepper-decrease-cache: "Decrease Cache size in pages";
    in property <string> stepper-increase-cache: "Increase Cache size in pages";
    in property <string> stepper-decrease-preload: "Decrease Preload radius";
    in property <string> stepper-increase-preload: "Increase Preload radius";
}
