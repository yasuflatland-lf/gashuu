// Single source of truth for gashuu's visual tokens, transcribed from /DESIGN.md
// (Google-Stitch format). Components reference `Theme.<token>` and NEVER paste raw hex inline.
export global Theme {
    // ── Colors: accent ──────────────────────────────────────────────────────
    out property <color> accent: #5b8cff;
    out property <color> accent-glow: #5b8cff40;   // rgba(91,140,255,0.25)
    // Moving-highlight tint for the bulk-add progress bar's shimmer sweep — a
    // light accent at ~60% alpha so it reads over both the accent fill and the
    // neutral track. (Component-inline hex is forbidden; the token lives here.)
    out property <color> progress-shimmer: #a0beff99;
    out property <color> success: #41c98a;

    // ── Colors: surface ladder ──────────────────────────────────────────────
    out property <color> canvas: #0b0e15;
    out property <color> surface: #0e1118;
    out property <color> surface-raised: #161b27;
    out property <color> surface-float: #10141f;
    out property <color> surface-sunken: #0d1019;
    out property <color> stage-top: #1a2030;

    // ── Colors: hairlines & tracks ──────────────────────────────────────────
    out property <color> hairline: #262c3a;
    out property <color> hairline-float: #2f3850;
    out property <color> track: #2a3243;
    out property <color> track-prog: #333c4f;
    out property <color> chip: #222a3a;

    // ── Colors: text (high -> faint) ──────────────────────────────────────────
    out property <color> text: #ffffff;
    out property <color> text-high: #dde5f5;
    out property <color> text-mid: #cdd8ef;
    out property <color> text-muted: #9fb0cc;
    out property <color> text-dim: #7c8bab;
    out property <color> text-faint: #67748f;

    // ── Shadows ───────────────────────────────────────────────────────────────
    out property <color> shadow-popover: #00000080;   // 50%-black drop shadow for floating popovers (PR-S)
    /// Card elevation shadow (~55% black) for raised cover cards (DESIGN.md elevation.card).
    out property <color> shadow-card: #0000008c;
    out property <length> shadow-blur-float: 22px;    // floating chrome: pills, modals, elevated cards
    out property <length> shadow-offset-float: 8px;   // its vertical offset
    out property <length> glow-blur: 12px;            // hover/danger glow radius
    out property <length> focus-glow-blur: 8px;       // keyboard-focus glow (NOT a spacing token)

    // Spacing (8px base, denser sub-steps for chrome). The sm → lg → xxl rungs (8/14/22)
    // double as the settings rhythm ladder ≈ Fibonacci 8/13/21, each step ≈ ×φ.
    out property <length> space-xxs: 4px;
    out property <length> space-xs: 6px;
    out property <length> space-sm: 8px;
    out property <length> space-md: 10px;
    out property <length> space-lg: 14px;
    out property <length> space-xl: 18px;
    out property <length> space-xxl: 22px;
    out property <length> space-huge: 26px;

    // ── Border radius scale ───────────────────────────────────────────────────
    out property <length> radius-xs: 3px;
    out property <length> radius-sm: 6px;
    out property <length> radius-md: 8px;
    out property <length> radius-lg: 10px;
    out property <length> radius-pill: 9999px;

    // Proportion primitives. The golden ratio — implicit in the nav Fibonacci sizes below;
    // the settings polish PR (spec 2026-06-04) consumes it directly for derived lengths.
    out property <float> phi: 1.618;

    // ── Component sizes (PR-S scrubber) ───────────────────────────────────────
    out property <length> scrubber-track-height: 6px;
    out property <length> scrubber-knob-size: 16px;
    out property <length> scrubber-knob-size-active: 20px;   // drag-grow target

    // Viewer swipe-to-turn affordance: edge glow band lighting the side the fingers push
    // toward as a two-finger swipe accumulates (PageView). Soft accent alpha; opacity scales with progress.
    out property <length> viewer-swipe-glow-width: 280px;
    out property <color> viewer-swipe-glow: #5b8cff4d;   // accent @ ~30% alpha (rgba(91,140,255,0.30))

    // Settings control atoms (issue 102). Shared visible-capsule height for Segmented /
    // Stepper / Toggle; the DESIGN ~32px hit area is met by the surrounding row, capsule is 30.
    out property <length> settings-control-h: 30px;
    // Segmented selected-pill inset — a consecutive-Fibonacci concentric triple with the cell
    // radius below: inset 3 → pill radius 5 → capsule 8 (inner = outer − inset; Apple nested-corner).
    out property <length> seg-pill-inset: 3px;
    out property <length> seg-cell-radius: radius-md - seg-pill-inset;
    // Horizontal label inset inside each segment cell — extends the Fibonacci triple
    // (3 → 5 → 8) to rung 13, the φ-generous inset so a label never crowds the rounded ends.
    out property <length> seg-label-pad: 13px;
    // Toggle track: width / height = φ — the same proportion as Apple's 51×31 switch.
    out property <length> toggle-track-w: settings-control-h * phi;
    // Toggle knob inset (Apple's switch keeps a 2px rim around the knob).
    out property <length> toggle-knob-inset: space-xxs / 2;

    // Settings dropdown (pull-down) atom. Fixed button width so the capsule doesn't resize
    // when the label length changes (e.g. "English" vs "日本語"); fits the widest label + chevron.
    out property <length> settings-dropdown-w: 140px;
    out property <length> settings-dropdown-chevron: 10px;  // chevron glyph square

    // ── Settings glass panel (issue 103, PR-B) ────────────────────────────────
    out property <length> settings-w: 432px;             // panel width (432 = 377 + 55, both Fibonacci numbers; widened from 377 so the 3-up segmented cells fit their widest JP label plus the 13px symmetric seg-label-pad without crowding the rounded ends — settings-label-col stays 165, so the extra width all goes to the control column); height is content-hug — spec 2026-06-04 dropped the fixed φ outline; shared by the Shortcuts overlay / Confirm width clamps
    out property <length> settings-radius: nav-pill-radius;  // = nav-pill-radius (shares NavBar's glass corner language)
    out property <length> settings-label-col: 165px;     // fixed label column; sized for the longest label — the Japanese "Allow CBR/RAR archives" string renders ≈ 157px in font-body (13px) — leaving ~8px slack; widened from 132px (an English-only fit that clipped the longer Japanese labels) when settings-w grew to 377px; labels never wrap/elide
    out property <length> settings-control-x: settings-label-col + space-lg;  // single vertical seam every CONTROL shares; section headers align with the label margin (not this seam)
    out property <length> settings-row-h: 34px;          // row height (= nav-capsule); the 30px atom centers within it
    // ⚠ NOT an accent — a hair lighter than glass-fill; top stop of the panel fill
    // gradient. Do not mistake for an accent color (cf. title-glow's similar caveat).
    out property <color> glass-sheen-top: #1a2030d1;     // stage-top @ ~82% alpha; top stop of settings panel gradient
    out property <length> settings-scroll-indicator-w: 3px;  // self-drawn scroll indicator width

    // Shortcuts overlay panel (issue 104, PR-C). Reuses settings-w/radius/glass tokens; only
    // the height differs — shorter than the settings panel so it reads as a smaller layered modal.
    out property <length> shortcuts-h: 466px;            // fixed; reads smaller than the settings panel's content-hug height

    // ── Typography sizes (system font; no custom typeface) ────────────────────
    out property <length> font-title: 15px;
    out property <length> font-body: 13px;
    out property <length> font-label: 12px;
    out property <length> font-micro: 11px;
    out property <length> font-numeric: 13px;   // page counters (tabular figures) (PR-S)

    // ── Scrims (modal backdrops) ──────────────────────────────────────────────
    out property <color> scrim: #000000a0;          // standard modal backdrop (~63% black)
    out property <color> scrim-soft: #00000060;     // lighter recede veil (~38% black); scrim is too dense for a NavBar recede

    // Drag-and-drop drop zone: full-window solid frame while an OS drag hovers the Library.
    // Recede uses drop-scrim (~70% black); frame/message at full strength (NO opacity layer).
    out property <color> drop-scrim: #000000b3;           // ~70% black recede; library shows at ~30% (drop-zone only; do NOT reuse — scrim-soft stays the NavBar veil)
    out property <length> drop-frame-inset: space-huge;   // 26px gap from each window edge to the frame
    out property <length> drop-frame-width: 2px;          // solid frame stroke thickness
    out property <color> drop-frame-line: #9f9f9f;        // frame + message tint

    // ── Neutral placeholder fill (thumbnail still-loading) ────────────────────
    out property <color> placeholder: #2a3243;      // neutral loading fill (= track hue)

    // STATE semantics (failed-decode / load-failure): `error` = border/glyph hue, `error-surface`
    // = cell ground. NOT for destructive buttons — white text fails WCAG AA on `error` (~3.44:1).
    out property <color> error: #d16b7c;
    out property <color> error-surface: #2a1820;

    // OPERATION semantics: destructive-button red (bulk-delete epic). Red is scarce —
    // destructive BUTTONS only; selection stays `accent`. `danger` passes WCAG AA where `error` fails.
    out property <color> danger: #c1455e;
    out property <color> danger-glow: #c1455e40;   // danger @ 25% alpha (rgba(193,69,94,0.25))

    // ── Motion ────────────────────────────────────────────────────────────────
    out property <duration> motion-fast: 180ms;     // chrome fades (existing value)
    // Screen-transition tempo (drill-in slide + panel-height ease): long enough to read a
    // horizontal push, short enough to stay snappy — between the 180ms fade and 480ms cover-flow.
    out property <duration> motion-med: 260ms;
    // Easing lives in each animate block — Slint has no <easing> property type, so
    // cubic-bezier(0.16, 1, 0.3, 1) can't be a Theme token and must be repeated at each site.
    out property <duration> motion-cinematic: 480ms;       // Carousel flow-position — the ONE animated scalar the cover-flow row chases; long enough for the eye to follow a full-width translation

    // Typography weights (DESIGN roles). Line-height is intentionally omitted: Slint 1.x
    // Text has no line-height property, so per-role lineHeight can't be expressed — don't fake it.
    out property <int> weight-regular: 400;
    out property <int> weight-medium: 500;
    out property <int> weight-semibold: 600;
    out property <int> weight-bold: 700;

    // ── Glass (Slint has no backdrop-blur; approximate with translucent fill + rim) ──
    out property <color> glass-fill: #10141fd1;      // surface-float @ ~82% alpha
    out property <color> glass-border: #2f3850b3;    // hairline-float @ ~70% alpha
    out property <color> glass-highlight: #dde5f51f; // text-high @ ~12% — top inner rim
    // Resting search-field rim — hairline-float hue at ~15% alpha (a hair above glass-highlight's
    // ~12%). Dedicated so glass-border (shared by 5 components) stays untouched; brightens on focus.
    out property <color> search-border-rest: #2f385026; // hairline-float @ ~15% alpha
    out property <color> viewer-pill-fill: #10141fb3;   // surface-float @ ~70% alpha (viewer pill, slightly more transparent than glass-fill)
    // Glow for the book-title label. Slint 1.x Text has no text-shadow, so the title is drawn
    // as 1px-offset duplicates in this color behind a crisp white copy (legible over bright pages).
    out property <color> title-glow: #3d3d3d;            // text-glow tone behind the white title

    // ── Nav bar sizing (golden ratio phi ~= 1.618 via Fibonacci px) ──
    out property <length> nav-icon: 21px;        // 13 x phi
    out property <length> nav-capsule: 34px;     // 21 x phi (circular capsule diameter)
    out property <length> nav-pill-height: 55px; // 34 x phi
    out property <length> nav-item-gap: 13px;
    out property <length> nav-pill-pad: 11px;
    // TRUE capsule radius for a 34px pill: exactly height/2 (straight sides, semicircle ends).
    // `radius-pill` (9999px) on a non-square rect renders an ELLIPSE (femtovg per-axis clamp; patterns.md).
    out property <length> nav-capsule-radius: nav-capsule / 2;  // 17px
    // Horizontal label inset inside a text capsule: nav-capsule / phi ≈ 21 (Fibonacci) —
    // HIG-generous padding so the label never crowds the rounded ends.
    out property <length> nav-capsule-pad: 21px;
    // Leading glyph size inside a text button (DangerButton's trash icon):
    // sized to read with a font-label (12px) line next to it.
    out property <length> button-icon: 16px;

    // Push button geometry (Primary / Secondary / DangerButton): shared hit-area + padding.
    // Vertical padding is ASYMMETRIC (9 top / 7 bottom) to optically center the label — do NOT tidy to 8/8.
    out property <length> button-min-h: 32px;
    out property <length> button-pad-x: 16px;
    out property <length> button-pad-top: 9px;
    out property <length> button-pad-bottom: 7px;

    // Nav search field sizing (issue 88: live library search). Length-only tokens; colors reuse
    // the surface/text/accent tokens above; the leading magnifier uses NavItem's idle text-mid tone.
    out property <length> nav-search-width: 220px;  // fixed field width (does not stretch / collapse)
    out property <length> nav-search-pad-x: 13px;   // horizontal inset for placeholder/text/icon
    out property <length> nav-search-cursor: 1px;   // TextInput caret width
    out property <length> nav-search-icon: 16px;    // leading magnifier glyph size
    out property <length> nav-divider-width: 1px;   // thin separator between search and the icon capsules
    // Golden-ratio corner radius for the search field: field height (nav-capsule 34px) / phi^2 (2.618)
    // ~= 13px = 0.382 * height. Below height/2 (17px), so it renders as a rounded rectangle, not a pill.
    out property <length> nav-search-radius: 13px;
    // Golden-ratio corner radius for the outer nav glass pill: bar height (nav-pill-height 55px) / phi^2 (2.618)
    // ~= 21px. Below height/2 (27.5px), so the pill is a rounded rectangle that matches the search field corners.
    out property <length> nav-pill-radius: 21px;

    // Viewer pill sizing (issue 85: page-jump glass pill). Width of the "<page> / total" jump
    // field; referenced twice (field width AND the pill's token-summed width) so it lives here.
    out property <length> viewer-jump-field-width: 142px; // holds a 4-digit page + "/ total" without clipping

    // Layout helper: pixel-snapping. Rounds a length to whole LOGICAL pixels so manual centering
    // doesn't land text/SVG on a fractional pixel (soft on 1x). Apply only to STATIC chrome, never animated.
    pure public function snap(v: length) -> length {
        return Math.round(v / 1px) * 1px;
    }
}
