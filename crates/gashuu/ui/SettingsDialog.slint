// Modal settings overlay for gashuu.
// Rendered as a full-area semi-transparent backdrop with a centered panel.
// Each setting change fires a callback so Rust can react. Display modes apply
// immediately; cache size and preload radius apply to newly opened books.
// Idempotency (no-op on equal values) is enforced on the Rust side to absorb the
// selection self-fire from the token-driven control atoms (Segmented / Stepper /
// Toggle replaced the native ComboBox / SpinBox / CheckBox in issue 102 / PR-A).
import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { Theme } from "Theme.slint";
import { Segmented } from "components/Segmented.slint";
import { Stepper } from "components/Stepper.slint";
import { Toggle } from "components/Toggle.slint";

export component SettingsDialog inherits Rectangle {
    // ── Full-area semi-transparent backdrop ──────────────────────────────────
    background: Theme.scrim;

    // ── In-out properties (two-way bound to UI controls) ─────────────────────
    // Index into ["Left to Right", "Right to Left"].
    in-out property <int> reading-direction-index;
    // Index into ["Single", "Double", "Auto"].
    in-out property <int> spread-mode-index;
    // Index into ["Standalone", "Paired"].
    in-out property <int> cover-mode-index;
    // Index into ["Whole", "Width", "Actual"].
    in-out property <int> fit-mode-index;
    // LRU cache size in pages (>=1).
    in-out property <int> cache-size;
    // Background prefetch radius in pages (0 = disabled).
    in-out property <int> preload-pages;
    // Whether recent-files tracking is enabled.
    in-out property <bool> track-recent;
    // Read-only reference text listing keyboard shortcuts (display only).
    in property <string> key-bindings-text;

    // ── Callbacks fired when the user changes a setting ───────────────────────
    callback set-reading-direction(int);
    callback set-spread-mode(int);
    callback set-cover-mode(int);
    callback set-fit-mode(int);
    callback set-cache-size(int);
    callback set-preload-pages(int);
    callback set-track-recent(bool);
    // Fired when the user clicks the Close button.
    callback close-settings();

    // ── Centered panel ────────────────────────────────────────────────────────
    Rectangle {
        // Fluid width: caps at 480 px on wide windows; shrinks to leave a
        // Theme.space-xl gutter on each side on narrow windows.
        width: min(480px, parent.width - 2 * Theme.space-xl);
        // Height is determined by content; anchor the panel at center.
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.surface-float;
        border-radius: Theme.radius-md;
        border-color: Theme.hairline-float;
        border-width: 1px;

        VerticalBox {
            padding: 20px;
            spacing: 12px;

            // ── Title ─────────────────────────────────────────────────────────
            Text {
                text: "Settings";
                font-size: Theme.font-title;
                color: Theme.text-high;
                horizontal-alignment: left;
            }

            // ── Reading direction ─────────────────────────────────────────────
            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Reading direction";
                    color: Theme.text-mid;
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Segmented {
                    model: ["Left to Right", "Right to Left"];
                    current-index <=> root.reading-direction-index;
                    a11y-label: "Reading direction";
                    selected(i) => { root.set-reading-direction(i); }
                    horizontal-stretch: 1;
                }
            }

            // ── Spread mode ───────────────────────────────────────────────────
            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Spread";
                    color: Theme.text-mid;
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Segmented {
                    model: ["Single", "Double", "Auto"];
                    current-index <=> root.spread-mode-index;
                    a11y-label: "Spread";
                    selected(i) => { root.set-spread-mode(i); }
                    horizontal-stretch: 1;
                }
            }

            // ── Cover mode ────────────────────────────────────────────────────
            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Cover";
                    color: Theme.text-mid;
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Segmented {
                    model: ["Standalone", "Paired"];
                    current-index <=> root.cover-mode-index;
                    a11y-label: "Cover";
                    selected(i) => { root.set-cover-mode(i); }
                    horizontal-stretch: 1;
                }
            }

            // ── Fit mode ──────────────────────────────────────────────────────
            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Fit";
                    color: Theme.text-mid;
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Segmented {
                    model: ["Whole", "Width", "Actual"];
                    current-index <=> root.fit-mode-index;
                    a11y-label: "Fit";
                    selected(i) => { root.set-fit-mode(i); }
                    horizontal-stretch: 1;
                }
            }

            // ── Cache size ────────────────────────────────────────────────────
            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Cache size (pages)";
                    color: Theme.text-mid;
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Stepper {
                    value <=> root.cache-size;
                    minimum: 1;
                    maximum: 9999;
                    a11y-label: "Cache size (pages)";
                    edited(v) => { root.set-cache-size(v); }
                    horizontal-stretch: 1;
                }
            }

            // ── Preload radius ────────────────────────────────────────────────
            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Preload radius";
                    color: Theme.text-mid;
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Stepper {
                    value <=> root.preload-pages;
                    minimum: 0;
                    maximum: 99;
                    a11y-label: "Preload radius";
                    edited(v) => { root.set-preload-pages(v); }
                    horizontal-stretch: 1;
                }
            }

            // ── Cache/preload note ────────────────────────────────────────────
            Text {
                text: "Cache & preload apply to newly opened books.";
                font-size: Theme.font-micro;
                color: Theme.text-dim;
                horizontal-alignment: left;
            }

            // ── Track recent files ────────────────────────────────────────────
            // PR-A interim: the Toggle carries no built-in label, so pair it with
            // a sibling Text (mirrors the other rows' label + control layout).
            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Track recent files";
                    color: Theme.text-mid;
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Toggle {
                    checked <=> root.track-recent;
                    a11y-label: "Track recent files";
                    toggled(b) => { root.set-track-recent(b); }
                }
            }

            // ── Keyboard shortcuts reference (read-only) ──────────────────────
            Text {
                text: "Keyboard shortcuts (reference)";
                font-size: Theme.font-body;
                color: Theme.text-mid;
                horizontal-alignment: left;
            }
            Text {
                text: root.key-bindings-text;
                font-size: Theme.font-label;
                color: Theme.text-dim;
                horizontal-alignment: left;
                wrap: word-wrap;
            }

            // ── Close button ──────────────────────────────────────────────────
            HorizontalBox {
                alignment: end;
                Button {
                    text: "Close";
                    clicked => { root.close-settings(); }
                }
            }
        }
    }
}
