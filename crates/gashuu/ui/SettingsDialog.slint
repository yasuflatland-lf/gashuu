// Modal settings overlay for gashuu — a content-hug "liquid glass" panel
// (issue 103, PR-B; visual polish: spec 2026-06-04 — the fixed φ outline was
// deliberately dropped; φ now lives in the component proportions instead:
// toggle track ratio, the 8/14/22 spacing ladder, segment padding).
//
// Form factor: 432px wide (clamped to the window so a narrow window keeps a
// space-md gutter each side), height hugging header + body + footer, radius 21px
// (shares NavBar's glass corner language), height CLAMPED to
// min(content, window.height − 2·space-huge) so a short window scrolls the
// body instead of overflowing (Marcotte). The panel is ONE fake-glass object —
// NavBar's four-layer fake-glass idiom (fill + 1px rim + 1px top highlight + one
// drop shadow), with layer 1 promoted from a solid fill to a top-sheen
// @linear-gradient. No nested glass / no second shadow. The sheen is a FILL
// gradient, not an opacity layer (opacity blurs text/SVG on HiDPI — patterns.md).
//
// Content: four whitespace-delineated sections (Reading / Display / Performance
// / General) of token-driven atoms (Segmented / Stepper / Toggle / Dropdown),
// each laid out by a SettingRow between the L1 seam (settings-control-x) and
// the shared right rail (fill segments span both; compact atoms trail on the
// rail). Section headers are text-dim sentence-case SEMIBOLD eyebrows (NOT
// accent — accent marks interactive/selected only). Rhythm: rows 14px apart,
// sections 22px apart (Fibonacci 8/13/21 ladder ≈ ×φ steps; spec 2026-06-04).
//
// Dismiss: Esc (FocusScope) + backdrop-click + Close button, all three. The panel
// absorbs clicks via a lowest-layer TouchArea so a click inside it does not bubble
// to the backdrop dismiss. The dialog's FocusScope (`fs`) WRAPS the panel content,
// so it is a genuine ANCESTOR of every control: when a focused atom's inner
// FocusScope rejects an unhandled key, Slint walks strictly up the focused item's
// parent chain (Slint 1.16 window.rs) — which now passes through `fs` — so Esc
// reaches `fs.key-pressed` even while a child control holds focus. (`fs` must be an
// ancestor, not a sibling, or that upward walk never visits it.) Verify by hand —
// the cargo gates don't exercise .slint key handling.
//
// Each setting change fires a callback so Rust can react; the Rust setters are
// idempotent (no-op on equal values) to absorb the atoms' selection self-fire.
// The Slint↔Rust contract (the *-index / value in-out props + set-* callbacks) is
// preserved exactly. key-bindings-text (parked in PR-B) is removed in PR-C; the
// shortcuts overlay (ShortcutsOverlay.slint) now owns that content.
import { Theme } from "Theme.slint";
import { Strings } from "Strings.slint";
import { PrimaryButton } from "components/PrimaryButton.slint";
import { GlassModal } from "components/GlassModal.slint";
import { ReadingSettings } from "settings/ReadingSettings.slint";
import { DisplaySettings } from "settings/DisplaySettings.slint";
import { PerformanceSettings } from "settings/PerformanceSettings.slint";
import { GeneralSettings } from "settings/GeneralSettings.slint";
import { DataSettings } from "settings/DataSettings.slint";
import { AboutSettings } from "settings/AboutSettings.slint";
import { SettingsNavRow } from "components/SettingsNavRow.slint";

// Slide wrapper for one drill-in screen (issue 351). Clips a horizontal entrance
// and hugs the inner content height, so `content.preferred-height` — hence the
// eased `panel-height` — still content-hugs the active screen. Detail screens
// enter from the RIGHT (drill-in, `from-left` default false); the top list enters
// from the LEFT on back-navigation (`from-left: true`). On the initial dialog open
// (`nav-animate` false) the content mounts in place at x: 0, so opening the dialog
// never slides. Each call site slots its own screen content via @children and its
// own focus `init` — the id it focuses is declared in the call site's scope, so
// the focus call must live there (an id inside an `if` subtree is unreachable from
// outside it).
//
// The entrance-flip is DEFERRED to after the first frame by a 1ms Timer, NOT done
// in `init`: a fresh if-gated instance that flips `entered` in `init` SNAPS — init
// runs before the inner `x` is first evaluated, so `x` mounts at 0 with no
// off-screen start (patterns.md — "a new instance snaps with no transition"). The
// Timer fires post-mount, so `x` mounts off-screen and then animates in. `running`
// self-stops once `entered` flips, so it fires exactly once and never on the
// static initial open (nav-animate false).
component SlideScreen inherits Rectangle {
    // Mirrors the dialog's `nav-animate`: false only for the static first open,
    // true for every later screen swap so it slides.
    in property <bool> nav-animate;
    // The top list enters from the left (back-navigation); detail screens from the
    // right (drill-in).
    in property <bool> from-left: false;
    // Inter-child gap for the slotted content (list rows: space-xs; General+Data:
    // space-xxl; single-child detail screens leave the 0 default).
    in property <length> content-spacing: 0px;
    property <bool> entered: false;
    // Off-screen start until `entered` flips: the left-entering list sits at
    // -width, the right-entering detail screens at +width.
    property <length> hidden-x: root.from-left ? -root.width : root.width;

    clip: true;
    height: mover.preferred-height;

    Timer {
        interval: 1ms;
        running: root.nav-animate && !root.entered;
        triggered => {
            root.entered = true;
        }
    }

    mover := VerticalLayout {
        width: root.width;
        x: (root.entered || !root.nav-animate) ? 0px : root.hidden-x;
        spacing: root.content-spacing;
        animate x {
            duration: Theme.motion-med;
            easing: ease-in-out;
        }
        @children
    }
}

export component SettingsDialog inherits GlassModal {
    // ── In-out properties (two-way bound to UI controls) ─────────────────────
    // Index into ["Left to Right", "Right to Left"].
    in-out property <int> reading-direction-index;
    // Index into ["Single", "Double", "Auto"].
    in-out property <int> spread-mode-index;
    // Index into ["Standalone", "Paired"].
    in-out property <int> cover-mode-index;
    // Index into ["Whole", "Width", "Actual"].
    in-out property <int> fit-mode-index;
    // LRU cache size in pages (>=1).
    in-out property <int> cache-size;
    // Background prefetch radius in pages (0 = disabled).
    in-out property <int> preload-pages;
    // Whether recent-files tracking is enabled.
    in-out property <bool> track-recent;
    // Whether RAR/CBR archive support is enabled.
    in-out property <bool> allow-rar-archives;
    // Index into the language dropdown model (En=0, Ja=1 — enum_adapters.rs
    // owns the authoritative ordering).
    in-out property <int> language-index;
    // ── About / auto-update (auto-update epic, Task 10) ───────────────────────
    // The running app's version (e.g. "0.11.0"), pre-composed in Rust from
    // CARGO_PKG_VERSION — a plain `in` prop, like `data-action-status` below.
    in property <string> app-version;
    // Whether the app checks GitHub Releases for a newer version on startup.
    in-out property <bool> auto-update-check: true;
    // Transient feedback for the manual "Check for updates now" button (e.g.
    // "Checking…" / "You're on the latest version." / "Couldn't check for
    // updates."). Empty string = no message shown, same convention as
    // `data-action-status` below. Rust clears it once a newer version is found
    // (the update-available dialog takes over), on the next manual check, and
    // on the next dialog open (on_open_settings sets it back to "").
    in property <string> update-status;
    // True when this dialog edits the CURRENT book's per-book settings (opened
    // from the Viewer): shows the per-book title and the reset-to-global button.
    in property <bool> show-reset-button: false;
    // Pre-composed feedback for the clear-history / clear-cache actions.
    // Empty string = no message shown. Rust pushes a transient string; it is
    // reset to empty the next time the dialog opens (on_open_settings sets it
    // back to "").
    in property <string> data-action-status;

    // ── Callbacks fired when the user changes a setting ───────────────────────
    callback set-reading-direction(int);
    callback set-spread-mode(int);
    callback set-cover-mode(int);
    callback set-fit-mode(int);
    callback set-cache-size(int);
    callback set-preload-pages(int);
    callback set-track-recent(bool);
    callback set-allow-rar-archives(bool);
    callback set-language(int);
    // Fired immediately when the user clicks "Clear reading history" — no confirmation.
    callback clear-reading-history();
    // Fired immediately when the user clicks "Clear cover cache" — no confirmation.
    callback clear-cover-cache();
    // Fired when the user toggles "Check for updates automatically".
    callback set-auto-update-check(bool);
    // Fired when the user clicks "Check for updates now".
    callback check-for-updates();
    // Fired on Esc, backdrop-click, or the Close button.
    callback close-settings();
    // Fired when the user activates the "Shortcuts" footer link (mouse click,
    // Return/Space, or accessible-action-default). ViewerWindow opens
    // ShortcutsOverlay in response and bumps focus-epoch on close.
    callback open-shortcuts();
    // Fired when the user clicks "Reset to global" (viewer context only).
    callback reset-to-global();

    // Bumped by ViewerWindow when the shortcuts overlay closes so this
    // still-mounted dialog reclaims keyboard focus. An if-gated dialog cannot be
    // reached by id from outside, so the parent signals through this property.
    in property <int> focus-epoch: 0;
    changed focus-epoch => {
        // Focuses the dialog's own FocusScope (not a child control like `init`
        // does) so Esc and Tab are immediately active on return from the overlay.
        // The first interactive control is intentionally not pre-selected — the
        // user left mid-task and returns to the same state they left.
        fs.focus();
    }

    // ── Drill-in navigation state (issue 348) ─────────────────────────────────
    // Which screen the GLOBAL (Library) dialog shows: 0 = the grouped top-level
    // list, 1..5 = a category detail (Reading / Display / Performance /
    // General+Data / About). The per-book (Viewer) dialog ignores this and stays
    // flat. `active-row` remembers which top-list row drilled in, so returning to
    // the list restores focus to it. Internal state — not part of the public
    // Slint↔Rust surface.
    property <int> current-screen: 0;
    property <int> active-row: 0;
    // Gates the drill-in slide so the dialog OPENS static (no slide on the first
    // mount): it flips true on the first navigation and stays true for the life of
    // the (re-instantiated-per-open) dialog. Each screen reads it to decide whether
    // to enter from off-screen or mount in place.
    property <bool> nav-animate: false;

    // ── Panel geometry + backdrop wiring (glass chrome lives in GlassModal) ────
    // Responsive width: shows the full 432px on roomy windows, but never
    // overflows a narrow one — it shrinks to leave a small space-md gutter
    // on each side (mirrors the height clamp below, which reads the same
    // `root` — the SettingsDialog root that fills the window).
    panel-width: min(Theme.settings-w, root.width - 2 * Theme.space-md);
    // Content-hug height inside the Marcotte clamp (spec 2026-06-04): the
    // panel is exactly header + body content + footer tall — no dead slack
    // for the Flickable to absorb — but never taller than the window minus a
    // gutter each side (then the body scrolls). A Flickable does NOT
    // propagate its content's preferred height (that's why it can scroll),
    // so the sum is assembled explicitly from the named parts.
    panel-height: min(
        Theme.space-lg + header-row.preferred-height + content.preferred-height + footer-block.height,
        max(0px, root.height - 2 * Theme.space-huge));
    // Ease the content-hug height so a drill-in that changes the active screen's
    // height glides instead of jumping. `animate` does NOT fire on the initial
    // binding, so the dialog still opens at its resting height with no animation;
    // only later screen swaps ease. (Only x and panel-height are animated — the
    // glass drop-shadow stays static, since animating drop-shadow-* is version-
    // fragile — docs/patterns.md.)
    animate panel-height {
        duration: Theme.motion-med;
        easing: ease-in-out;
    }
    backdrop-clicked => { root.close-settings(); }

    // ── FocusScope: Esc-to-close + initial focus on the first control ──────
    // WRAPS the panel content so it is a genuine ANCESTOR of every control:
    // on appear it hands focus to the first control (Segmented's public
    // focus-control()) — it does NOT keep focus itself, so arrow-key control
    // and first-control-focus both work. On Esc, closes; all other keys are
    // rejected so they reach the focused child control. A focused child atom's
    // FocusScope rejects unhandled keys; Slint then walks UP the focused item's
    // parent chain, which passes through this scope, so Esc fires here.
    // Slotted as GlassModal's @children, after GlassModal's click-absorber —
    // FocusScope does not intercept pointer events, so empty-panel clicks fall
    // through to that absorber regardless of declaration order; controls keep
    // hit-test priority over the absorber's TouchArea because they are declared
    // after it.
    fs := FocusScope {
        x: 0;
        y: 0;
        // Size to the glass PANEL, not `parent`. This FocusScope is slotted into
        // GlassModal's `panel` via @children, but @children only relocates where
        // the element DRAWS — in property expressions `parent` still resolves to
        // the lexical parent, i.e. this dialog's root (which fills the window).
        // `parent.width/height` would therefore stretch the content to the whole
        // window and overflow the panel; `root.panel-*` is the panel's true size.
        width: root.panel-width;
        height: root.panel-height;
        // Initial focus is set by each content screen's own `init` (which fires on
        // the initial mount, unlike `changed`): the per-book wrapper focuses its
        // first control, and the global top list focuses its first row. An id
        // declared inside an `if` subtree is not reachable from here, so the focus
        // must live where the id is in scope.
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                // Two-stage Esc for the global drill-in: from a detail screen, Esc
                // pops back to the top list; from the top list (or the flat
                // per-book dialog) it closes.
                if (!root.show-reset-button && root.current-screen > 0) {
                    root.nav-animate = true;
                    root.current-screen = 0;
                    return accept;
                }
                root.close-settings();
                return accept;
            }
            return reject;
        }

        // ── Panel content: sticky header, scrollable body, sticky footer ───
        body-col := VerticalLayout {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            padding-top: Theme.space-lg;

            // ── Sticky header ─────────────────────────────────────────────────
            // Adaptive: the top-level title on the flat per-book dialog and the
            // global top list (screen 0); a "‹ Settings" back control + category
            // name on the global detail screens (1..5). The back control stays in
            // the sticky header so it is always reachable while the body scrolls.
            header-row := HorizontalLayout {
                padding-left: Theme.space-xl;
                padding-right: Theme.space-xl;
                padding-bottom: Theme.space-md;
                spacing: Theme.space-sm;
                // Top-level title (per-book always; global only on the top list).
                if root.show-reset-button || root.current-screen == 0 : Text {
                    // "Book settings" when editing the current book's per-book
                    // override (opened from the Viewer); plain "Settings" for the
                    // global defaults (Library screen).
                    text: root.show-reset-button ? Strings.settings-book-title : Strings.settings-title;
                    font-size: Theme.font-title;
                    font-weight: Theme.weight-semibold;
                    color: Theme.text-high;
                    horizontal-alignment: left;
                    accessible-role: text;
                    accessible-label: root.show-reset-button ? Strings.settings-book-title : Strings.settings-title;
                }
                // Sub-screen header (global detail screens): back control + category.
                if !root.show-reset-button && root.current-screen != 0 : HorizontalLayout {
                    spacing: Theme.space-sm;
                    // Focusable "‹ Settings" back control: pops to the top list on
                    // click / Return / Space / AT default. Esc is rejected so it
                    // propagates to the ancestor `fs` (two-stage Esc).
                    back-control := FocusScope {
                        horizontal-stretch: 0;
                        width: back-label.preferred-width;
                        back-label := Text {
                            height: 100%;
                            text: "‹ " + Strings.settings-title;
                            font-size: Theme.font-title;
                            font-weight: Theme.weight-semibold;
                            color: parent.has-focus ? Theme.text-high : Theme.text-dim;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                        TouchArea {
                            width: back-label.preferred-width;
                            height: back-label.preferred-height;
                            clicked => {
                                root.nav-animate = true;
                                root.current-screen = 0;
                            }
                        }
                        key-pressed(event) => {
                            if (event.text == Key.Return || event.text == Key.Space) {
                                root.nav-animate = true;
                                root.current-screen = 0;
                                return accept;
                            }
                            return reject;
                        }
                        accessible-role: button;
                        accessible-label: Strings.settings-title;
                        accessible-action-default => {
                            root.nav-animate = true;
                            root.current-screen = 0;
                        }
                    }
                    Text {
                        text: root.current-screen == 1 ? Strings.settings-section-reading
                            : root.current-screen == 2 ? Strings.settings-section-display
                            : root.current-screen == 3 ? Strings.settings-section-performance
                            : root.current-screen == 4 ? Strings.settings-section-general
                            : Strings.settings-section-about;
                        font-size: Theme.font-title;
                        font-weight: Theme.weight-semibold;
                        color: Theme.text-high;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                        accessible-role: text;
                    }
                }
            }

            // ── Scrollable body ───────────────────────────────────────────────
            // A Flickable (not std ScrollView — its native scrollbar paints a
            // light palette that breaks the glass, design §6.3). The viewport
            // height is the intrinsic content height, so it scrolls ONLY when the
            // content overflows the visible body (clamped-window case).
            body := Flickable {
                vertical-stretch: 1;
                viewport-width: self.width;
                viewport-height: content.preferred-height;

                content := VerticalLayout {
                    padding-left: Theme.space-xl;
                    padding-right: Theme.space-xl;
                    // φ ladder (spec 2026-06-04): 22px between sections
                    // (≈ Fibonacci 21), and the same 22px below the last
                    // section so the footer hairline reads as the final
                    // section boundary.
                    spacing: Theme.space-xxl;
                    padding-bottom: Theme.space-xxl;
                    alignment: start;

                    // ══ Per-book (Viewer): flat — unchanged from the extraction ══
                    // Reading + Display + Performance with their eyebrows; the
                    // global-only General/Data/About are omitted, exactly as
                    // before. The drill-in navigation below is global-only.
                    if root.show-reset-button : VerticalLayout {
                        spacing: Theme.space-xxl;
                        init => {
                            book-reading.focus-first();
                        }
                        book-reading := ReadingSettings {
                            reading-direction-index <=> root.reading-direction-index;
                            spread-mode-index <=> root.spread-mode-index;
                            set-reading-direction(i) => {
                                root.set-reading-direction(i);
                            }
                            set-spread-mode(i) => {
                                root.set-spread-mode(i);
                            }
                        }
                        DisplaySettings {
                            cover-mode-index <=> root.cover-mode-index;
                            fit-mode-index <=> root.fit-mode-index;
                            set-cover-mode(i) => {
                                root.set-cover-mode(i);
                            }
                            set-fit-mode(i) => {
                                root.set-fit-mode(i);
                            }
                        }
                        PerformanceSettings {
                            cache-size <=> root.cache-size;
                            preload-pages <=> root.preload-pages;
                            track-recent <=> root.track-recent;
                            allow-rar-archives <=> root.allow-rar-archives;
                            set-cache-size(v) => {
                                root.set-cache-size(v);
                            }
                            set-preload-pages(v) => {
                                root.set-preload-pages(v);
                            }
                            set-track-recent(b) => {
                                root.set-track-recent(b);
                            }
                            set-allow-rar-archives(b) => {
                                root.set-allow-rar-archives(b);
                            }
                        }
                    }

                    // ══ Global (Library): HIG drill-in navigation ══
                    // Screen 0 — the grouped top-level list. Each row drills into a
                    // category. Value previews are added in a later batch step.
                    // Sub-screens are gated by `if current-screen == N` so their
                    // controls stay OUT of the Tab chain when inactive; only the
                    // active screen's content is instantiated, so
                    // `content.preferred-height` (hence panel-height) hugs it.
                    if !root.show-reset-button && root.current-screen == 0 : SlideScreen {
                        // The top list enters from the LEFT on a back-navigation.
                        from-left: true;
                        nav-animate: root.nav-animate;
                        content-spacing: Theme.space-xs;
                        // On (re)creation focus the originating row: the first row on
                        // the initial mount (active-row defaults 0) or the row the user
                        // drilled from when returning. `init` fires exactly when this
                        // list is mounted, so the row already exists. The row ids are
                        // declared in THIS if-subtree, so the focus init must live here.
                        init => {
                            if (root.active-row == 1) {
                                row-display.focus-row();
                            } else if (root.active-row == 2) {
                                row-performance.focus-row();
                            } else if (root.active-row == 3) {
                                row-general.focus-row();
                            } else if (root.active-row == 4) {
                                row-about.focus-row();
                            } else {
                                row-reading.focus-row();
                            }
                        }
                        row-reading := SettingsNavRow {
                            label: Strings.settings-section-reading;
                            // Live preview of the current reading direction (read
                            // only — reuses the direction option strings).
                            value: root.reading-direction-index == 1 ? Strings.settings-direction-rtl : Strings.settings-direction-ltr;
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 0;
                                root.current-screen = 1;
                            }
                        }
                        row-display := SettingsNavRow {
                            label: Strings.settings-section-display;
                            // Live preview of the current fit mode (reuses the fit
                            // option strings; index 0/1/2 = Whole/Width/Actual).
                            value: root.fit-mode-index == 0 ? Strings.settings-fit-whole
                                : root.fit-mode-index == 1 ? Strings.settings-fit-width
                                : Strings.settings-fit-actual;
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 1;
                                root.current-screen = 2;
                            }
                        }
                        row-performance := SettingsNavRow {
                            label: Strings.settings-section-performance;
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 2;
                                root.current-screen = 3;
                            }
                        }
                        row-general := SettingsNavRow {
                            label: Strings.settings-section-general;
                            // Language name in its OWN tongue (deliberately
                            // untranslated, matching the language dropdown).
                            value: root.language-index == 1 ? "日本語" : "English";
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 3;
                                root.current-screen = 4;
                            }
                        }
                        row-about := SettingsNavRow {
                            label: Strings.settings-section-about;
                            // Current app version (read only).
                            value: root.app-version;
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 4;
                                root.current-screen = 5;
                            }
                        }
                    }

                    // Screen 1 — Reading detail. Enters from the RIGHT on drill-in
                    // (SlideScreen default).
                    if !root.show-reset-button && root.current-screen == 1 : SlideScreen {
                        nav-animate: root.nav-animate;
                        init => {
                            reading-detail.focus-first();
                        }
                        reading-detail := ReadingSettings {
                            show-title: false;
                            reading-direction-index <=> root.reading-direction-index;
                            spread-mode-index <=> root.spread-mode-index;
                            set-reading-direction(i) => {
                                root.set-reading-direction(i);
                            }
                            set-spread-mode(i) => {
                                root.set-spread-mode(i);
                            }
                        }
                    }

                    // Screen 2 — Display detail.
                    if !root.show-reset-button && root.current-screen == 2 : SlideScreen {
                        nav-animate: root.nav-animate;
                        init => {
                            display-detail.focus-first();
                        }
                        display-detail := DisplaySettings {
                            show-title: false;
                            cover-mode-index <=> root.cover-mode-index;
                            fit-mode-index <=> root.fit-mode-index;
                            set-cover-mode(i) => {
                                root.set-cover-mode(i);
                            }
                            set-fit-mode(i) => {
                                root.set-fit-mode(i);
                            }
                        }
                    }

                    // Screen 3 — Performance detail.
                    if !root.show-reset-button && root.current-screen == 3 : SlideScreen {
                        nav-animate: root.nav-animate;
                        init => {
                            performance-detail.focus-first();
                        }
                        performance-detail := PerformanceSettings {
                            show-title: false;
                            cache-size <=> root.cache-size;
                            preload-pages <=> root.preload-pages;
                            track-recent <=> root.track-recent;
                            allow-rar-archives <=> root.allow-rar-archives;
                            set-cache-size(v) => {
                                root.set-cache-size(v);
                            }
                            set-preload-pages(v) => {
                                root.set-preload-pages(v);
                            }
                            set-track-recent(b) => {
                                root.set-track-recent(b);
                            }
                            set-allow-rar-archives(b) => {
                                root.set-allow-rar-archives(b);
                            }
                        }
                    }

                    // Screen 4 — General + Data detail. Data keeps its eyebrow as a
                    // sub-heading within the General screen (spec).
                    if !root.show-reset-button && root.current-screen == 4 : SlideScreen {
                        nav-animate: root.nav-animate;
                        content-spacing: Theme.space-xxl;
                        init => {
                            general-detail.focus-first();
                        }
                        general-detail := GeneralSettings {
                            show-title: false;
                            language-index <=> root.language-index;
                            set-language(i) => {
                                root.set-language(i);
                            }
                        }
                        DataSettings {
                            show-title: true;
                            data-action-status: root.data-action-status;
                            clear-reading-history() => {
                                root.clear-reading-history();
                            }
                            clear-cover-cache() => {
                                root.clear-cover-cache();
                            }
                        }
                    }

                    // Screen 5 — About detail. AboutSettings has no focusable-first
                    // seam (its first control is a Toggle), so focus falls to the
                    // dialog scope: Esc / back / Tab all work and the back control is
                    // the first Tab stop. About now hosts the Shortcuts row, forwarded
                    // to the dialog's existing open-shortcuts() callback.
                    if !root.show-reset-button && root.current-screen == 5 : SlideScreen {
                        nav-animate: root.nav-animate;
                        init => {
                            fs.focus();
                        }
                        AboutSettings {
                            show-title: false;
                            app-version: root.app-version;
                            auto-update-check <=> root.auto-update-check;
                            update-status: root.update-status;
                            set-auto-update-check(b) => {
                                root.set-auto-update-check(b);
                            }
                            check-for-updates() => {
                                root.check-for-updates();
                            }
                            open-shortcuts() => {
                                root.open-shortcuts();
                            }
                        }
                    }
                }
            }

            // ── Sticky footer ─────────────────────────────────────────────────
            footer-block := Rectangle {
                vertical-stretch: 0;
                // Symmetric space-lg above/below the row — 14px ≈ Fib 13,
                // the SAME ladder rung as the body's row gap, so the footer
                // breathes on the row rhythm (bumped from space-md after
                // visual review: 10px read cramped around the 32px buttons
                // beside the 21px bottom corner). The panel's bottom inset
                // is owned HERE (body-col padding-bottom is gone).
                height: footer-row.preferred-height + 2 * Theme.space-lg;

                // 1px hairline top edge honestly marks the scroll boundary.
                Rectangle {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: 1px;
                    background: Theme.hairline;
                }

                // Footer order: [Shortcuts?] … [Reset to global?] [Close]. The
                // GLOBAL dialog moved its Shortcuts link into the About sub-screen,
                // so its footer is Close-only on every screen. The per-book (Viewer)
                // dialog has no About screen — and the settings dialog is the only
                // path to the shortcuts overlay — so it keeps the left Shortcuts
                // link (gated on show-reset-button), giving [Shortcuts] … [Reset]
                // [Close]. A single stretch spacer owns the slack and pins the
                // action button(s) hard RIGHT (both-ends, HIG; spec 2026-06-04). A
                // literal `alignment: start` DISABLES child stretch factors — the
                // old bug that glued Close to Shortcuts (docs/patterns.md). The Reset
                // button only appears in the per-book context; its label is shortened
                // to "Reset to global" (the accessible-label carries the full intent).
                footer-row := HorizontalLayout {
                    x: 0;
                    y: Theme.space-lg;
                    width: parent.width;
                    // EXPLICIT height: an element placed outside a layout
                    // defaults to its PARENT's size, so without this the row
                    // filled the whole footer-block, its y-offset pushed it
                    // space-md past the panel bottom, and the cross-axis
                    // stretch inflated the Close button to the full block
                    // height (docs/patterns.md). Content height restores the
                    // symmetric space-md insets the block height budgets for.
                    height: self.preferred-height;
                    padding-left: Theme.space-xl;
                    padding-right: Theme.space-xl;
                    spacing: Theme.space-md;

                    // LEFT (per-book only): a focusable "Shortcuts" link. The GLOBAL
                    // dialog relocated Shortcuts into the About sub-screen, but the
                    // per-book (Viewer) dialog has no About screen — and the settings
                    // dialog is the only path to the shortcuts overlay — so the
                    // per-book footer keeps the link. Activates on mouse click /
                    // Return / Space / AT default; Esc is rejected so it walks up to
                    // the ancestor `fs` and closes the dialog.
                    if root.show-reset-button : FocusScope {
                        horizontal-stretch: 0;
                        width: shortcuts-label.preferred-width;
                        // Idle text-dim (static affordance); focus brightens to
                        // text-high so the Tab ring shows without an accent rule.
                        shortcuts-label := Text {
                            height: 100%;
                            text: Strings.settings-shortcuts-label;
                            font-size: Theme.font-label;
                            color: parent.has-focus ? Theme.text-high : Theme.text-dim;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                        TouchArea {
                            width: shortcuts-label.preferred-width;
                            height: shortcuts-label.preferred-height;
                            clicked => {
                                root.open-shortcuts();
                            }
                        }
                        key-pressed(event) => {
                            if (event.text == Key.Return || event.text == Key.Space) {
                                root.open-shortcuts();
                                return accept;
                            }
                            return reject;
                        }
                        accessible-role: button;
                        accessible-label: Strings.shortcuts-title;
                        accessible-action-default => { root.open-shortcuts(); }
                    }

                    // Stretch spacer: owns the slack and pushes the action button(s)
                    // hard right. On the global dialog (no Shortcuts link) this is the
                    // first footer child, so the footer reads as Close-only.
                    Rectangle { horizontal-stretch: 1; }

                    // RIGHT (per-book only): reset the current book's overrides
                    // back to the global defaults. Reuses PrimaryButton (no
                    // secondary variant exists); Close stays the rightmost,
                    // last-resort action. Shown only in the viewer context.
                    if root.show-reset-button : PrimaryButton {
                        text: Strings.settings-reset-to-global;
                        clicked => {
                            root.reset-to-global();
                        }
                    }

                    // RIGHT: Close — the reused PrimaryButton, always visible in
                    // the sticky footer even while the body scrolls.
                    PrimaryButton {
                        text: Strings.common-close;
                        clicked => {
                            root.close-settings();
                        }
                    }
                }
            }
        }

        // ── Self-drawn scroll indicator ───────────────────────────────────
        // Only when the body content overflows its visible height. A thin rail
        // (track-prog) with an accent thumb whose size/offset derive from the
        // Flickable viewport geometry. Show/hide via `visible:` ONLY (no
        // opacity — HiDPI blur rule). No edge fades. Declared as a sibling of
        // the content layout inside `fs`, so its y is computed in THIS scope's
        // space: body-col.y (the content layout’s own offset within fs) + body.y
        // (the body Flickable’s y within that layout). Deriving y this way
        // — rather than from a bare `body.y` — keeps the rail aligned even if
        // the content layout is ever given a non-zero offset within `fs`.
        Rectangle {
            visible: body.viewport-height > body.height;
            x: parent.width - Theme.settings-scroll-indicator-w - Theme.space-xxs;
            y: body-col.y + body.y;
            width: Theme.settings-scroll-indicator-w;
            height: body.height;
            background: Theme.track-prog;
            border-radius: Theme.settings-scroll-indicator-w / 2;
            // Clip the thumb so elastic overscroll (viewport-y briefly positive)
            // cannot render the thumb above the rail bounds.
            clip: true;

            // Thumb: proportional size and offset from the scroll position.
            Rectangle {
                x: 0;
                width: parent.width;
                height: parent.height * (body.height / max(body.viewport-height, 1px));
                y: -body.viewport-y * (parent.height / max(body.viewport-height, 1px));
                background: Theme.accent;
                border-radius: Theme.settings-scroll-indicator-w / 2;
            }
        }
    }
}
