// Modal settings overlay (issue 103): content-hug "liquid glass" panel. Rust setters
// are idempotent (no-op on equal values) to absorb the atoms' selection self-fire.
import { Theme } from "Theme.slint";
import { Strings } from "Strings.slint";
import { PrimaryButton } from "components/PrimaryButton.slint";
import { GlassModal } from "components/GlassModal.slint";
import { ReadingSettings } from "settings/ReadingSettings.slint";
import { DisplaySettings } from "settings/DisplaySettings.slint";
import { PerformanceSettings } from "settings/PerformanceSettings.slint";
import { GeneralSettings } from "settings/GeneralSettings.slint";
import { DataSettings } from "settings/DataSettings.slint";
import { AboutSettings } from "settings/AboutSettings.slint";
import { SettingsNavRow } from "components/SettingsNavRow.slint";
import { ScrollIndicator } from "components/ScrollIndicator.slint";

// Slide wrapper for one drill-in screen (issue 351). Entrance-flip is DEFERRED to the
// first frame via a 1ms Timer, NOT init (init runs before x is evaluated → snaps; patterns.md).
component SlideScreen inherits Rectangle {
    // Mirrors the dialog's `nav-animate`: false only for the static first open,
    // true for every later screen swap so it slides.
    in property <bool> nav-animate;
    // The top list enters from the left (back-navigation); detail screens from the
    // right (drill-in).
    in property <bool> from-left: false;
    // Inter-child gap for the slotted content (list rows: space-xs; General+Data:
    // space-xxl; single-child detail screens leave the 0 default).
    in property <length> content-spacing: 0px;
    property <bool> entered: false;
    // Off-screen start until `entered` flips: the left-entering list sits at
    // -width, the right-entering detail screens at +width.
    property <length> hidden-x: root.from-left ? -root.width : root.width;

    clip: true;
    height: mover.preferred-height;

    Timer {
        interval: 1ms;
        running: root.nav-animate && !root.entered;
        triggered => {
            root.entered = true;
        }
    }

    mover := VerticalLayout {
        width: root.width;
        x: (root.entered || !root.nav-animate) ? 0px : root.hidden-x;
        spacing: root.content-spacing;
        animate x {
            duration: Theme.motion-med;
            easing: ease-in-out;
        }
        @children
    }
}

export component SettingsDialog inherits GlassModal {
    // ── In-out properties (two-way bound to UI controls) ─────────────────────
    // Index into ["Left to Right", "Right to Left"].
    in-out property <int> reading-direction-index;
    // Index into ["Single", "Double", "Auto"].
    in-out property <int> spread-mode-index;
    // Index into ["Standalone", "Paired"].
    in-out property <int> cover-mode-index;
    // Index into ["Whole", "Width", "Actual"].
    in-out property <int> fit-mode-index;
    // LRU cache size in pages (>=1).
    in-out property <int> cache-size;
    // Background prefetch radius in pages (0 = disabled).
    in-out property <int> preload-pages;
    // Whether recent-files tracking is enabled.
    in-out property <bool> track-recent;
    // Whether RAR/CBR archive support is enabled.
    in-out property <bool> allow-rar-archives;
    // Index into the language dropdown model (En=0, Ja=1 — enum_adapters.rs
    // owns the authoritative ordering).
    in-out property <int> language-index;
    // About / auto-update (auto-update epic, Task 10). The running app's version
    // (e.g. "0.11.0"), pre-composed in Rust from CARGO_PKG_VERSION — a plain `in` prop.
    in property <string> app-version;
    // Whether the app checks GitHub Releases for a newer version on startup.
    in-out property <bool> auto-update-check: true;
    // Transient feedback for "Check for updates now" (e.g. "Checking…"/"…latest version.").
    // Empty = no message; Rust clears it once a newer version is found, on next check, and on open.
    in property <string> update-status;
    // True when this dialog edits the CURRENT book's per-book settings (opened
    // from the Viewer): shows the per-book title and the reset-to-global button.
    in property <bool> show-reset-button: false;
    // Pre-composed feedback for the clear-history / clear-cache actions. Empty = no
    // message; Rust pushes a transient string, reset to empty on the next dialog open.
    in property <string> data-action-status;

    // ── Callbacks fired when the user changes a setting ───────────────────────
    callback set-reading-direction(int);
    callback set-spread-mode(int);
    callback set-cover-mode(int);
    callback set-fit-mode(int);
    callback set-cache-size(int);
    callback set-preload-pages(int);
    callback set-track-recent(bool);
    callback set-allow-rar-archives(bool);
    callback set-language(int);
    // Fired immediately when the user clicks "Clear reading history" — no confirmation.
    callback clear-reading-history();
    // Fired immediately when the user clicks "Clear cover cache" — no confirmation.
    callback clear-cover-cache();
    // Fired when the user toggles "Check for updates automatically".
    callback set-auto-update-check(bool);
    // Fired when the user clicks "Check for updates now".
    callback check-for-updates();
    // Fired on Esc, backdrop-click, or the Close button.
    callback close-settings();
    // Fired when the user activates the "Shortcuts" footer link. ViewerWindow opens
    // ShortcutsOverlay in response and bumps focus-epoch on close.
    callback open-shortcuts();
    // Fired when the user clicks "Reset to global" (viewer context only).
    callback reset-to-global();

    // Bumped by ViewerWindow when the shortcuts overlay closes so this still-mounted
    // dialog reclaims focus. An if-gated dialog is unreachable by id, so signal via a property.
    in property <int> focus-epoch: 0;
    changed focus-epoch => {
        // Focuses the dialog's own FocusScope (not a child control) so Esc/Tab are active
        // on return; the first control is intentionally not pre-selected (user returns mid-task).
        fs.focus();
    }

    // Drill-in navigation state (issue 348). current-screen: 0 = grouped top list,
    // 1..5 = category detail; per-book ignores it. active-row restores focus on return.
    property <int> current-screen: 0;
    property <int> active-row: 0;
    // Gates the drill-in slide so the dialog OPENS static: flips true on the first
    // navigation and stays true for the dialog's life; each screen reads it to slide or not.
    property <bool> nav-animate: false;

    // Panel geometry + backdrop wiring (glass chrome lives in GlassModal). Responsive
    // width: full 432px on roomy windows, shrinks to a space-md gutter each side on narrow ones.
    panel-width: min(Theme.settings-w, root.width - 2 * Theme.space-md);
    // Content-hug height (Marcotte clamp): header + body + footer, capped at window
    // height (then body scrolls). A Flickable doesn't propagate content height, so sum the parts.
    panel-height: min(
        Theme.space-lg + header-row.preferred-height + content.preferred-height + footer-block.height,
        max(0px, root.height - 2 * Theme.space-huge));
    // Ease the content-hug height so drill-in screen swaps glide. `animate` doesn't fire on
    // the initial binding (opens static); drop-shadow stays static — animating it is version-fragile.
    animate panel-height {
        duration: Theme.motion-med;
        easing: ease-in-out;
    }
    backdrop-clicked => { root.close-settings(); }

    // FocusScope WRAPS the panel content as a genuine ANCESTOR of every control: a key rejected
    // by a focused atom walks UP the parent chain to reach Esc here; it doesn't keep focus so arrows work.
    fs := FocusScope {
        x: 0;
        y: 0;
        // Size to the glass PANEL, not `parent`: @children only relocates where an element
        // DRAWS — `parent` still resolves to the lexical root (fills window), so use root.panel-*.
        width: root.panel-width;
        height: root.panel-height;
        // Initial focus is set by each screen's own `init` (fires on mount, unlike `changed`):
        // an id inside an `if` subtree isn't reachable here, so focus must live where the id is.
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                // Two-stage Esc (global drill-in): from a detail screen Esc pops to the top
                // list; from the top list (or the flat per-book dialog) it closes.
                if (!root.show-reset-button && root.current-screen > 0) {
                    root.nav-animate = true;
                    root.current-screen = 0;
                    return accept;
                }
                root.close-settings();
                return accept;
            }
            return reject;
        }

        // ── Panel content: sticky header, scrollable body, sticky footer ───
        body-col := VerticalLayout {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            padding-top: Theme.space-lg;

            // Sticky header (adaptive): top-level title on the flat/top-list screens; a
            // "‹ Settings" back control + category on detail screens, kept sticky so it stays reachable.
            header-row := HorizontalLayout {
                padding-left: Theme.space-xl;
                padding-right: Theme.space-xl;
                padding-bottom: Theme.space-md;
                spacing: Theme.space-sm;
                // Top-level title (per-book always; global only on the top list).
                if root.show-reset-button || root.current-screen == 0 : Text {
                    // "Book settings" when editing the current book's per-book override
                    // (from the Viewer); plain "Settings" for the global defaults (Library).
                    text: root.show-reset-button ? Strings.settings-book-title : Strings.settings-title;
                    font-size: Theme.font-title;
                    font-weight: Theme.weight-semibold;
                    color: Theme.text-high;
                    horizontal-alignment: left;
                    accessible-role: text;
                    accessible-label: root.show-reset-button ? Strings.settings-book-title : Strings.settings-title;
                }
                // Sub-screen header (global detail screens): back control + category.
                if !root.show-reset-button && root.current-screen != 0 : HorizontalLayout {
                    spacing: Theme.space-sm;
                    // Focusable "‹ Settings" back control: pops to the top list on click /
                    // Return / Space / AT default. Esc is rejected so it reaches ancestor `fs`.
                    back-control := FocusScope {
                        horizontal-stretch: 0;
                        width: back-label.preferred-width;
                        back-label := Text {
                            height: 100%;
                            text: "‹ " + Strings.settings-title;
                            font-size: Theme.font-title;
                            font-weight: Theme.weight-semibold;
                            color: parent.has-focus ? Theme.text-high : Theme.text-dim;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                        TouchArea {
                            width: back-label.preferred-width;
                            height: back-label.preferred-height;
                            clicked => {
                                root.nav-animate = true;
                                root.current-screen = 0;
                            }
                        }
                        key-pressed(event) => {
                            if (event.text == Key.Return || event.text == Key.Space) {
                                root.nav-animate = true;
                                root.current-screen = 0;
                                return accept;
                            }
                            return reject;
                        }
                        accessible-role: button;
                        accessible-label: Strings.settings-title;
                        accessible-action-default => {
                            root.nav-animate = true;
                            root.current-screen = 0;
                        }
                    }
                    Text {
                        text: root.current-screen == 1 ? Strings.settings-section-reading
                            : root.current-screen == 2 ? Strings.settings-section-display
                            : root.current-screen == 3 ? Strings.settings-section-performance
                            : root.current-screen == 4 ? Strings.settings-section-general
                            : Strings.settings-section-about;
                        font-size: Theme.font-title;
                        font-weight: Theme.weight-semibold;
                        color: Theme.text-high;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                        accessible-role: text;
                    }
                }
            }

            // Scrollable body — a Flickable, not std ScrollView (its native scrollbar paints a
            // light palette that breaks the glass, design §6.3). Scrolls only when content overflows.
            body := Flickable {
                vertical-stretch: 1;
                viewport-width: self.width;
                viewport-height: content.preferred-height;

                content := VerticalLayout {
                    padding-left: Theme.space-xl;
                    padding-right: Theme.space-xl;
                    // φ ladder (spec 2026-06-04): 22px (≈ Fibonacci 21) between sections and below
                    // the last, so the footer hairline reads as the final section boundary.
                    spacing: Theme.space-xxl;
                    padding-bottom: Theme.space-xxl;
                    alignment: start;

                    // Per-book (Viewer): flat — Reading + Display + Performance with eyebrows;
                    // the global-only General/Data/About are omitted. Drill-in below is global-only.
                    if root.show-reset-button : VerticalLayout {
                        spacing: Theme.space-xxl;
                        init => {
                            book-reading.focus-first();
                        }
                        book-reading := ReadingSettings {
                            reading-direction-index <=> root.reading-direction-index;
                            spread-mode-index <=> root.spread-mode-index;
                            set-reading-direction(i) => {
                                root.set-reading-direction(i);
                            }
                            set-spread-mode(i) => {
                                root.set-spread-mode(i);
                            }
                        }
                        DisplaySettings {
                            cover-mode-index <=> root.cover-mode-index;
                            fit-mode-index <=> root.fit-mode-index;
                            set-cover-mode(i) => {
                                root.set-cover-mode(i);
                            }
                            set-fit-mode(i) => {
                                root.set-fit-mode(i);
                            }
                        }
                        PerformanceSettings {
                            cache-size <=> root.cache-size;
                            preload-pages <=> root.preload-pages;
                            track-recent <=> root.track-recent;
                            allow-rar-archives <=> root.allow-rar-archives;
                            set-cache-size(v) => {
                                root.set-cache-size(v);
                            }
                            set-preload-pages(v) => {
                                root.set-preload-pages(v);
                            }
                            set-track-recent(b) => {
                                root.set-track-recent(b);
                            }
                            set-allow-rar-archives(b) => {
                                root.set-allow-rar-archives(b);
                            }
                        }
                    }

                    // Global (Library): HIG drill-in. Screen 0 = grouped top list; sub-screens are
                    // `if`-gated so only the active one joins the Tab chain and drives panel-height.
                    if !root.show-reset-button && root.current-screen == 0 : SlideScreen {
                        // The top list enters from the LEFT on a back-navigation.
                        from-left: true;
                        nav-animate: root.nav-animate;
                        content-spacing: Theme.space-xs;
                        // On (re)creation focus the originating row (first row on initial mount, or the
                        // drilled-from row on return). Row ids live in this if-subtree, so init must be here.
                        init => {
                            if (root.active-row == 1) {
                                row-display.focus-row();
                            } else if (root.active-row == 2) {
                                row-performance.focus-row();
                            } else if (root.active-row == 3) {
                                row-general.focus-row();
                            } else if (root.active-row == 4) {
                                row-about.focus-row();
                            } else {
                                row-reading.focus-row();
                            }
                        }
                        row-reading := SettingsNavRow {
                            label: Strings.settings-section-reading;
                            // Live preview of the current reading direction (read
                            // only — reuses the direction option strings).
                            value: root.reading-direction-index == 1 ? Strings.settings-direction-rtl : Strings.settings-direction-ltr;
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 0;
                                root.current-screen = 1;
                            }
                        }
                        row-display := SettingsNavRow {
                            label: Strings.settings-section-display;
                            // Live preview of the current fit mode (reuses the fit
                            // option strings; index 0/1/2 = Whole/Width/Actual).
                            value: root.fit-mode-index == 0 ? Strings.settings-fit-whole
                                : root.fit-mode-index == 1 ? Strings.settings-fit-width
                                : Strings.settings-fit-actual;
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 1;
                                root.current-screen = 2;
                            }
                        }
                        row-performance := SettingsNavRow {
                            label: Strings.settings-section-performance;
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 2;
                                root.current-screen = 3;
                            }
                        }
                        row-general := SettingsNavRow {
                            label: Strings.settings-section-general;
                            // Language name in its OWN tongue (deliberately
                            // untranslated, matching the language dropdown).
                            value: root.language-index == 1 ? "日本語" : "English";
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 3;
                                root.current-screen = 4;
                            }
                        }
                        row-about := SettingsNavRow {
                            label: Strings.settings-section-about;
                            // Current app version (read only).
                            value: root.app-version;
                            clicked => {
                                root.nav-animate = true;
                                root.active-row = 4;
                                root.current-screen = 5;
                            }
                        }
                    }

                    // Screen 1 — Reading detail. Enters from the RIGHT on drill-in
                    // (SlideScreen default).
                    if !root.show-reset-button && root.current-screen == 1 : SlideScreen {
                        nav-animate: root.nav-animate;
                        init => {
                            reading-detail.focus-first();
                        }
                        reading-detail := ReadingSettings {
                            show-title: false;
                            reading-direction-index <=> root.reading-direction-index;
                            spread-mode-index <=> root.spread-mode-index;
                            set-reading-direction(i) => {
                                root.set-reading-direction(i);
                            }
                            set-spread-mode(i) => {
                                root.set-spread-mode(i);
                            }
                        }
                    }

                    // Screen 2 — Display detail.
                    if !root.show-reset-button && root.current-screen == 2 : SlideScreen {
                        nav-animate: root.nav-animate;
                        init => {
                            display-detail.focus-first();
                        }
                        display-detail := DisplaySettings {
                            show-title: false;
                            cover-mode-index <=> root.cover-mode-index;
                            fit-mode-index <=> root.fit-mode-index;
                            set-cover-mode(i) => {
                                root.set-cover-mode(i);
                            }
                            set-fit-mode(i) => {
                                root.set-fit-mode(i);
                            }
                        }
                    }

                    // Screen 3 — Performance detail.
                    if !root.show-reset-button && root.current-screen == 3 : SlideScreen {
                        nav-animate: root.nav-animate;
                        init => {
                            performance-detail.focus-first();
                        }
                        performance-detail := PerformanceSettings {
                            show-title: false;
                            cache-size <=> root.cache-size;
                            preload-pages <=> root.preload-pages;
                            track-recent <=> root.track-recent;
                            allow-rar-archives <=> root.allow-rar-archives;
                            set-cache-size(v) => {
                                root.set-cache-size(v);
                            }
                            set-preload-pages(v) => {
                                root.set-preload-pages(v);
                            }
                            set-track-recent(b) => {
                                root.set-track-recent(b);
                            }
                            set-allow-rar-archives(b) => {
                                root.set-allow-rar-archives(b);
                            }
                        }
                    }

                    // Screen 4 — General + Data detail. Data keeps its eyebrow as a
                    // sub-heading within the General screen (spec).
                    if !root.show-reset-button && root.current-screen == 4 : SlideScreen {
                        nav-animate: root.nav-animate;
                        content-spacing: Theme.space-xxl;
                        init => {
                            general-detail.focus-first();
                        }
                        general-detail := GeneralSettings {
                            show-title: false;
                            language-index <=> root.language-index;
                            set-language(i) => {
                                root.set-language(i);
                            }
                        }
                        DataSettings {
                            show-title: true;
                            data-action-status: root.data-action-status;
                            clear-reading-history() => {
                                root.clear-reading-history();
                            }
                            clear-cover-cache() => {
                                root.clear-cover-cache();
                            }
                        }
                    }

                    // Screen 5 — About detail. AboutSettings has no focusable-first seam, so focus
                    // falls to the dialog scope (Esc/back/Tab work). It hosts the Shortcuts row.
                    if !root.show-reset-button && root.current-screen == 5 : SlideScreen {
                        nav-animate: root.nav-animate;
                        init => {
                            fs.focus();
                        }
                        AboutSettings {
                            show-title: false;
                            app-version: root.app-version;
                            auto-update-check <=> root.auto-update-check;
                            update-status: root.update-status;
                            set-auto-update-check(b) => {
                                root.set-auto-update-check(b);
                            }
                            check-for-updates() => {
                                root.check-for-updates();
                            }
                            open-shortcuts() => {
                                root.open-shortcuts();
                            }
                        }
                    }
                }
            }

            // ── Sticky footer ─────────────────────────────────────────────────
            footer-block := Rectangle {
                vertical-stretch: 0;
                // Symmetric space-lg above/below the row (14px ≈ Fib 13, the body row-gap rung),
                // bumped from space-md (10px read cramped). Panel bottom inset is owned HERE.
                height: footer-row.preferred-height + 2 * Theme.space-lg;

                // 1px hairline top edge honestly marks the scroll boundary.
                Rectangle {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: 1px;
                    background: Theme.hairline;
                }

                // Footer order: [Shortcuts?] … [Reset?] [Close]; a stretch spacer pins the actions
                // hard right. `alignment: start` DISABLES child stretch (old bug gluing Close to Shortcuts).
                footer-row := HorizontalLayout {
                    x: 0;
                    y: Theme.space-lg;
                    width: parent.width;
                    // EXPLICIT height: an element outside a layout defaults to its PARENT's size, which
                    // inflated the row and the Close button to the full block (docs/patterns.md).
                    height: self.preferred-height;
                    padding-left: Theme.space-xl;
                    padding-right: Theme.space-xl;
                    spacing: Theme.space-md;

                    // LEFT (per-book only): focusable "Shortcuts" link — the per-book dialog has no
                    // About screen so it keeps it. Esc is rejected so it walks up to ancestor `fs` to close.
                    if root.show-reset-button : FocusScope {
                        horizontal-stretch: 0;
                        width: shortcuts-label.preferred-width;
                        // Idle text-dim (static affordance); focus brightens to
                        // text-high so the Tab ring shows without an accent rule.
                        shortcuts-label := Text {
                            height: 100%;
                            text: Strings.settings-shortcuts-label;
                            font-size: Theme.font-label;
                            color: parent.has-focus ? Theme.text-high : Theme.text-dim;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                        TouchArea {
                            width: shortcuts-label.preferred-width;
                            height: shortcuts-label.preferred-height;
                            clicked => {
                                root.open-shortcuts();
                            }
                        }
                        key-pressed(event) => {
                            if (event.text == Key.Return || event.text == Key.Space) {
                                root.open-shortcuts();
                                return accept;
                            }
                            return reject;
                        }
                        accessible-role: button;
                        accessible-label: Strings.shortcuts-title;
                        accessible-action-default => { root.open-shortcuts(); }
                    }

                    // Stretch spacer: owns the slack and pushes the action button(s) hard right.
                    // On the global dialog (no Shortcuts link) it's the first child, so footer is Close-only.
                    Rectangle { horizontal-stretch: 1; }

                    // RIGHT (per-book only): reset the current book's overrides to the global
                    // defaults. Reuses PrimaryButton (no secondary variant); Close stays rightmost.
                    if root.show-reset-button : PrimaryButton {
                        text: Strings.settings-reset-to-global;
                        clicked => {
                            root.reset-to-global();
                        }
                    }

                    // RIGHT: Close — the reused PrimaryButton, always visible in
                    // the sticky footer even while the body scrolls.
                    PrimaryButton {
                        text: Strings.common-close;
                        clicked => {
                            root.close-settings();
                        }
                    }
                }
            }
        }

        // Self-drawn scroll indicator (shared ScrollIndicator atom). Its y is body-col.y + body.y
        // (this scope's space) so the rail stays aligned even if the content layout gains an offset.
        ScrollIndicator {
            x: parent.width - Theme.settings-scroll-indicator-w - Theme.space-xxs;
            y: body-col.y + body.y;
            height: body.height;
            content-height: body.viewport-height;
            viewport-y: body.viewport-y;
        }
    }
}
