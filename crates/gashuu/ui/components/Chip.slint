// Pill chip molecule (DESIGN.md components.chip): a rounded background carrying
// a short label. Per DESIGN the chip role spans several uses (page counter, the
// "↑ Library" affordance, key hints), but today it is wired only as the page
// counter (numeric token, e.g. "142 / 340"). Background {colors.chip}, text
// {colors.text-mid}, {typography.ui-label} (numeric token when `tabular`),
// padding 3×10, {rounded.pill}. All colors come from Theme.* — no inline hex.
import { Theme } from "../Theme.slint";

export component Chip inherits Rectangle {
    in property <string> text;
    // Use the tabular-figure (numeric) font for page counters so digits don't
    // jitter; plain label font otherwise.
    in property <bool> tabular;

    background: Theme.chip;
    border-radius: Theme.radius-pill;

    // A layout sizes the chip to the label's preferred size plus the DESIGN
    // padding (3px vertical, 10px horizontal). These literals stay raw px —
    // only color hex is token-guarded. The single Text is centered both axes.
    HorizontalLayout {
        padding-top: 3px;
        padding-bottom: 3px;
        padding-left: 10px;
        padding-right: 10px;

        Text {
            text: root.text;
            color: Theme.text-mid;
            font-size: root.tabular ? Theme.font-numeric : Theme.font-label;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
