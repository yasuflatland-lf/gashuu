// SelectionToolbar — glass pill shown BELOW the NavBar during bulk-selection.
// Cells: count pill (accent MODE INDICATOR, never danger), select-all capsule
// (HIG bordered; collapses to check.svg when `narrow`), and a NavItem exit whose
// `active` gate maps onto NavItem's `enabled`.
//
// Layout gotchas: width HUGS content only as a LAYOUT CHILD — an absolute (x/y)
// instance defaults to its PARENT's width, so Carousel wraps it in a centering
// HorizontalLayout. Text cells take explicit widths from label preferred-width
// because an `if`-gated inner layout does NOT propagate it (that clipped select-all).
// Count pill radius-pill on a non-square rect renders an ELLIPSE (femtovg per-axis
// clamp). Strings-agnostic: all visible text comes from Rust. Theme.* only.
import { Theme } from "../Theme.slint";
import { DangerButton } from "DangerButton.slint";
import { NavItem } from "NavItem.slint";

export component SelectionToolbar inherits Rectangle {
    // ── Public API ────────────────────────────────────────────────────────────
    // Pre-composed count label from Rust (e.g. "3 selected (1 outside search)").
    in property <string> count-text;
    // Flips between "Select all" and "Deselect all" based on Rust state.
    in property <string> select-all-label;
    // Consumer binds Strings.selection-exit-a11y.
    in property <string> exit-a11y;
    // Consumer binds Carousel's narrow breakpoint; collapses select-all to icon-only.
    in property <bool> narrow;
    // Pre-composed destructive label from Rust (e.g. "Delete (3)…"). Drives the
    // DangerButton's text at all widths (see the narrow-mode note on the cell).
    in property <string> delete-label;
    // Gates the DangerButton: hidden at N=0 (decision D2 — hidden, not disabled).
    in property <bool> has-selection;
    // True only while this toolbar is the VISIBLE (slid-in) bar; it stays
    // instantiated in a `clip: true` strip and slides out when inactive. ANDed into
    // every enabled/a11y guard so a slid-away bar takes no input if clip leaks.
    in property <bool> active: true;
    callback select-all();
    callback exit();
    // Fired by the DangerButton (pointer / screen-reader). Forwarded to Rust,
    // which opens the ConfirmDialog.
    callback request-delete();

    // No explicit width: the root adopts its HorizontalLayout's preferred size —
    // no binding-loop risk since nothing reads its own preferred-width.
    height: Theme.nav-pill-height;
    horizontal-stretch: 0;
    vertical-stretch: 0;

    // Glass layers 1/2/4 as in NavBar, with two departures: accent border for
    // mode-context (spec 2.5), and the drop shadow is active-gated (see below).
    background: Theme.glass-fill;
    border-radius: Theme.nav-pill-radius;
    border-width: 1px;
    border-color: Theme.accent;
    // Drop shadow ONLY while visible (slid-in). Parked (active == false), the
    // toolbar sits at y: -height inside the `clip: true` strip, so its offset/blur
    // shadow would bleed into the visible strip (clip cuts only what's OUTSIDE it).
    // Gating the color to `transparent` makes draw_box_shadow early-return (alpha 0).
    // Direct ternary, not states[] (root's own prop). NO opacity (HiDPI child-blur).
    drop-shadow-color: root.active ? Theme.shadow-popover : transparent;
    drop-shadow-blur: Theme.shadow-blur-float;
    drop-shadow-offset-y: Theme.shadow-offset-float;

    // Glass layer 3: top highlight rim, inset horizontally by half the pill height
    // so it stays inside the rounded corners (same as NavBar).
    Rectangle {
        x: Theme.nav-pill-height / 2;
        y: 1px;
        width: parent.width - Theme.nav-pill-height;
        height: 1px;
        background: Theme.glass-highlight;
    }

    // ── Items ─────────────────────────────────────────────────────────────────
    HorizontalLayout {
        spacing: Theme.nav-item-gap;
        padding: Theme.nav-pill-pad;
        alignment: center;

        // Count pill — accent MODE INDICATOR (accent border + glow). Read-only text,
        // not a button; never red/danger — selection is strictly accent language.
        count-pill := Rectangle {
            height: Theme.nav-capsule;
            // Explicit width from the label + HIG inset; Math.max floors it at a circle
            // (Slint rejects width + min-width together, so the floor is in-expression).
            width: Math.max(Theme.nav-capsule, count-label.preferred-width + 2 * Theme.nav-capsule-pad);
            horizontal-stretch: 0;
            border-radius: Theme.nav-capsule-radius;
            background: Theme.accent-glow;
            border-width: 1px;
            border-color: Theme.accent;

            count-label := Text {
                text: root.count-text;
                color: Theme.accent;
                font-size: Theme.font-label;
                font-weight: Theme.weight-medium;
                x: (parent.width - self.width) / 2;
                // Optical centering: metric-center + 1px down so the descender-less
                // glyph reads centered (docs/patterns.md metric line box; DangerButton 9/7).
                y: (parent.height - self.height) / 2 + 1px;
                horizontal-alignment: center;
                vertical-alignment: center;
                // Bright accent for the mode indicator (same hue as the pill border).
            }

            // Accessibility: count is a read-only text element.
            accessible-role: text;
            accessible-label: root.count-text;
        }

        // Select-all capsule — HIG bordered: idle chip fill + hairline ring (reads
        // as a button), accent on hover/press. Narrow mode collapses to check.svg
        // icon-only; the full select-all-label is always the accessible-label.
        select-all-capsule := Rectangle {
            height: Theme.nav-capsule;
            // Explicit width: circle in narrow mode, else measured label + HIG inset.
            // The label Text is UNCONDITIONAL (visible-gated) to stay measurable — an
            // if-gated layout won't propagate preferred width (that let exit overlap it).
            width: root.narrow
                ? Theme.nav-capsule
                : sa-label.preferred-width + 2 * Theme.nav-capsule-pad;
            horizontal-stretch: 0;
            border-radius: Theme.nav-capsule-radius;

            // Default appearance: chip ground + hairline ring (HIG bordered);
            // the ring slot is reserved at 1px, so hover restyles without reflow.
            background: Theme.chip;
            border-width: 1px;
            border-color: Theme.hairline-float;
            animate background, border-color { duration: Theme.motion-fast; }

            // States: pressed > hover (first match wins in Slint states[]).
            // Only root-level properties — child colorize uses a binding below.
            states [
                pressed when sa-touch.pressed : {
                    select-all-capsule.background: Theme.accent-glow.darker(0.10);
                    select-all-capsule.border-color: Theme.accent;
                }
                hover when sa-touch.has-hover : {
                    select-all-capsule.background: Theme.accent-glow;
                    select-all-capsule.border-color: Theme.accent;
                    select-all-capsule.drop-shadow-color: Theme.accent-glow;
                    select-all-capsule.drop-shadow-blur: Theme.glow-blur;
                }
            ]

            // Narrow mode: icon-only — centered check.svg glyph.
            // Wide mode: centered text label.
            if root.narrow : Image {
                source: @image-url("../assets/check.svg");
                width: Theme.nav-icon;
                height: Theme.nav-icon;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                image-fit: contain;
                // Brighten on hover/press; idle at text-mid (SelectionBadge idiom).
                colorize: sa-touch.has-hover || sa-touch.pressed ? Theme.text-high : Theme.text-mid;
            }

            // Unconditional (visible-gated, not if-gated): the width binding reads
            // sa-label.preferred-width, so it must always exist and stay measurable.
            sa-label := Text {
                visible: !root.narrow;
                text: root.select-all-label;
                // Brighten on hover/press; idle at text-mid (NavItem icon idiom).
                color: sa-touch.has-hover || sa-touch.pressed ? Theme.text-high : Theme.text-mid;
                font-size: Theme.font-label;
                font-weight: Theme.weight-medium;
                x: (parent.width - self.width) / 2;
                // Optical centering nudge — same 1px downward correction as
                // count-label above; keeps all text cells on one idiom.
                y: (parent.height - self.height) / 2 + 1px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            // Accessibility: always expose the full label, even icon-only. Action
            // gated on `active` so a slid-away bar exposes no working a11y action.
            accessible-role: button;
            accessible-label: root.select-all-label;
            accessible-action-default => { if (root.active) { root.select-all(); } }

            sa-touch := TouchArea {
                // Slid-away bars must never take input even if clip hit-testing leaks.
                enabled: root.active;
                clicked => { root.select-all(); }
            }
        }

        // Delete button — the ONLY red element in the app chrome; `if`-gated on
        // has-selection so at N=0 it is HIDDEN not disabled (decision D2; an `if`
        // costs zero layout space, unlike visible:). TouchArea-based/non-focusable,
        // so focus stays on the carousel. KEEPS its full text label at every width —
        // hiding the label on a destructive control is a safety hazard (approved).
        if root.has-selection : DangerButton {
            text: root.delete-label;
            // Leading trash glyph (delete.svg, recolored white by the button);
            // the label stays — the icon supplements, never replaces it.
            icon: @image-url("../assets/delete.svg");
            // DangerButton owns its TouchArea (no `enabled` pass-through), so gate the
            // forwarded action on `active` — a slid-away bar must not open the dialog.
            clicked => { if (root.active) { root.request-delete(); } }
        }

        // Exit capsule — a NavItem close button. `enabled: root.active` maps the
        // toolbar's visible gate onto NavItem's input + a11y gate, so a parked bar
        // exposes no working action. `active` stays default-false: no lit ring.
        NavItem {
            icon: @image-url("../assets/close.svg");
            a11y-label: root.exit-a11y;
            enabled: root.active;
            clicked => { root.exit(); }
        }
    }
}
