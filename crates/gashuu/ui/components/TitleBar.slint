// Title bar molecule (DESIGN.md components.title-bar): a quiet raised chrome
// strip with a 1px bottom hairline, the document/library name centered in a
// muted label, left-aligned action affordances, and an optional right-aligned
// page-count chip. Background {colors.surface-raised}, bottom border 1px
// {colors.hairline}, text {colors.text-muted}, {typography.ui-label}, padding
// 8×14. All colors come from Theme.* — no inline hex.
//
// This component only EMITS its callbacks; the FocusScope.focus() keyboard
// recovery after a click (see docs/patterns.md "Slint focus after a Button
// click") is the consuming ViewerWindow's responsibility, not ours.
import { Theme } from "../Theme.slint";
import { Chip } from "./Chip.slint";

// Private themed text button — a Rectangle + TouchArea + Text driven entirely by
// Theme.* tokens (std Button renders in the build-time fluent-dark style; a
// token-driven affordance keeps the title bar fully on the palette). Hover lifts
// the label from muted to mid; press shows a faint chip-toned surface.
component TitleBarButton inherits Rectangle {
    in property <string> text;
    callback clicked;

    border-radius: Theme.radius-md;
    background: ta.pressed ? Theme.chip : transparent;
    horizontal-stretch: 0;

    HorizontalLayout {
        padding-top: Theme.space-xxs;
        padding-bottom: Theme.space-xxs;
        padding-left: Theme.space-sm;
        padding-right: Theme.space-sm;
        Text {
            text: root.text;
            color: ta.has-hover ? Theme.text-mid : Theme.text-muted;
            font-size: Theme.font-label;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component TitleBar inherits Rectangle {
    in property <string> title;
    in property <string> count-text;
    in property <bool> show-count;
    callback open-folder;
    callback open-archive;
    callback toggle-thumbnails;
    callback open-settings;

    background: Theme.surface-raised;

    HorizontalLayout {
        // DESIGN padding 8×14 (raw px — only color hex is token-guarded; spacing
        // tokens space-sm/space-lg happen to match but the spec states literals).
        padding-top: 8px;
        padding-bottom: 8px;
        padding-left: 14px;
        padding-right: 14px;
        spacing: Theme.space-sm;

        // ── Left: action affordances ──────────────────────────────────────────
        TitleBarButton {
            text: "Open Folder…";
            clicked => {
                root.open-folder();
            }
        }
        TitleBarButton {
            text: "Open Archive…";
            clicked => {
                root.open-archive();
            }
        }
        TitleBarButton {
            text: "Thumbnails";
            clicked => {
                root.toggle-thumbnails();
            }
        }
        TitleBarButton {
            text: "Settings…";
            clicked => {
                root.open-settings();
            }
        }

        // ── Center: document/library name, centered in the stretching slot ─────
        Text {
            horizontal-stretch: 1;
            text: root.title;
            color: Theme.text-muted;
            font-size: Theme.font-label;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }

        // ── Right: optional page-count chip (numeric token) ───────────────────
        if root.show-count : Chip {
            text: root.count-text;
            tabular: true;
        }
    }

    // ── 1px bottom hairline ───────────────────────────────────────────────────
    // `inherits Rectangle` exposes a single border-color on all four sides, so a
    // bottom-only hairline needs a dedicated child pinned to the bottom edge.
    Rectangle {
        x: 0;
        y: parent.height - self.height;
        width: 100%;
        height: 1px;
        background: Theme.hairline;
    }
}
