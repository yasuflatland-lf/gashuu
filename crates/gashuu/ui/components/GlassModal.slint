// GlassModal — shared glass-panel modal shell (scrim backdrop + centered glass panel).
// @children slot INTO the panel so the dialog's FocusScope stays a genuine ancestor of controls.
import { Theme } from "../Theme.slint";

export component GlassModal inherits Rectangle {
    // Panel geometry strategy differs per dialog → received as in-props.
    in property <length> panel-width;
    in property <length> panel-height;
    // Fired when the scrim outside the panel is clicked.
    callback backdrop-clicked();

    // ── Full-area semi-transparent backdrop ───────────────────────────────────
    background: Theme.scrim;

    // Backdrop dismiss: a click on the scrim (outside the panel) dismisses. Clicks
    // inside the panel are absorbed by its lowest-layer TouchArea, never reaching here.
    TouchArea {
        clicked => {
            root.backdrop-clicked();
        }
    }

    // ── Glass panel ───────────────────────────────────────────────────────────
    panel := Rectangle {
        width: root.panel-width;
        height: root.panel-height;
        x: Theme.snap((parent.width - self.width) / 2);
        y: Theme.snap((parent.height - self.height) / 2);

        // Glass layers 1, 2, 4: a top-sheen FILL gradient (not opacity), a 1px
        // soft rim, and ONE drop shadow. No nested glass / no second shadow.
        background: @linear-gradient(180deg, Theme.glass-sheen-top 0%, Theme.glass-fill 46%);
        border-radius: Theme.settings-radius;
        border-width: 1px;
        border-color: Theme.glass-border;
        drop-shadow-color: Theme.shadow-popover;
        drop-shadow-blur: 22px;
        drop-shadow-offset-y: 8px;

        // Layer 3: 1px top inner highlight, inset horizontally by ~half the radius
        // so it stays inside the rounded corners (NavBar idiom).
        Rectangle {
            x: Theme.space-md;
            y: 1px;
            width: parent.width - 2 * Theme.space-md;
            height: 1px;
            background: Theme.glass-highlight;
        }

        // Panel click absorber: declared BEFORE @children so a click on the panel (not a
        // control) stops here, not bubbling to the backdrop; @children keep hit-test priority.
        TouchArea { }

        // The dialog's FocusScope + content.
        @children
    }
}
