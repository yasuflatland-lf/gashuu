// BookmarkRibbon — a quiet, NON-INTERACTIVE "continue reading" cover signifier. White,
// since accent is reserved for interactive; the consumer (Carousel) owns positioning.
import { Theme } from "../Theme.slint";
import { Strings } from "../Strings.slint";

export component BookmarkRibbon inherits Image {
    source: @image-url("../assets/bookmark.svg");
    width: Theme.space-huge;
    height: Theme.space-huge;
    image-fit: contain;
    colorize: Theme.text;

    // Accessibility: `image` is the correct non-interactive, non-focusable role for a
    // pure visual signifier; the label below supplies the meaning for assistive tech.
    accessible-role: image;
    accessible-label: Strings.continue-reading;
}
