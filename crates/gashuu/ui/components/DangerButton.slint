// DangerButton — DESIGN.md `components.button-danger`. The filled destructive
// button: a structural clone of PrimaryButton with the deeper Theme.danger red
// (white label passes WCAG AA) + a danger-glow hover/press ring. Vertical padding
// is split 9/7 for optical centering. Colors via Theme only; a11y hooks match the
// other push buttons.

import { Theme } from "../Theme.slint";

export component DangerButton inherits Rectangle {
    // ── Public API ────────────────────────────────────────────────────────────
    in property <string> text;
    // Optional leading glyph. Unset by default — an empty image has width 0, so the
    // Image gates out and existing consumers render label-only, unchanged. The icon
    // NEVER replaces the label: text on a destructive control is a safety requirement.
    in property <image> icon;
    callback clicked;

    // Sizing: root sizes to content (layout min-size drives width, padding drives
    // height); min-height 32px meets the DESIGN hit-area requirement.
    min-height: Theme.button-min-h;
    horizontal-stretch: 0;
    vertical-stretch: 0;

    // ── Default appearance ────────────────────────────────────────────────────
    background: Theme.danger;
    border-radius: Theme.radius-md;

    animate background { duration: Theme.motion-fast; }

    // States — pressed listed before hover (Slint: first match wins). Only ROOT
    // props here (Slint 1.x can't set child props from states[]); the glow is
    // root-level drop-shadow-*, with the blur NOT animated (animating drop-shadow is
    // version-fragile — see NavItem). Unlike NavItem, the glow lights on BOTH pressed
    // and hover, for more emphatic feedback on a destructive action.
    states [
        pressed when touch.pressed : {
            root.background: Theme.danger.darker(0.20);
            root.drop-shadow-color: Theme.danger-glow;
            root.drop-shadow-blur: Theme.glow-blur;
        }
        hover when touch.has-hover : {
            root.background: Theme.danger.darker(0.08);
            root.drop-shadow-color: Theme.danger-glow;
            root.drop-shadow-blur: Theme.glow-blur;
        }
    ]

    // ── Label ─────────────────────────────────────────────────────────────────
    HorizontalLayout {
        padding-left: Theme.button-pad-x;
        padding-right: Theme.button-pad-x;
        // Optical centering: Slint metric-centers the full font line box, sitting a
        // descender-less label ~1px high. The layout owns the label's y, so the nudge
        // is an asymmetric vertical-padding split (9/7, 16px total), not a `y:` binding.
        padding-top: Theme.button-pad-top;
        padding-bottom: Theme.button-pad-bottom;
        spacing: Theme.space-xs;
        alignment: center;

        // Leading glyph (only when a consumer supplies an icon). Recolored white via
        // `colorize`; wrapped in a VerticalLayout so it centers on the label's line box.
        if root.icon.width > 0 : VerticalLayout {
            alignment: center;
            Image {
                source: root.icon;
                width: Theme.button-icon;
                height: Theme.button-icon;
                image-fit: contain;
                colorize: Theme.text;
            }
        }

        Text {
            text: root.text;
            color: Theme.text;
            font-size: Theme.font-label;
            font-weight: Theme.weight-medium;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // ── Accessibility ─────────────────────────────────────────────────────────
    accessible-role: button;
    accessible-label: root.text;
    // Let a screen-reader activation gesture fire the same callback as a click.
    accessible-action-default => { root.clicked(); }

    // TouchArea is non-focusable in Slint — it does NOT steal keyboard focus from
    // any parent FocusScope (docs/patterns.md "TouchArea click focus recovery").
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
