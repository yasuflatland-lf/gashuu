// SecondaryButton — DESIGN.md `components.button-secondary`: a geometry clone of
// PrimaryButton but bordered-neutral (chip fill + ring). NOT red — danger is reserved.

import { Theme } from "../Theme.slint";

export component SecondaryButton inherits Rectangle {
    // ── Public API (drop-in sibling of PrimaryButton) ───────────────────────────
    in property <string> text;
    callback clicked;

    // Sizing: root sizes to content (layout min-size drives width; padding drives
    // height). min-height 32px matches PrimaryButton and the DESIGN hit-area floor.
    min-height: Theme.button-min-h;
    horizontal-stretch: 0;
    vertical-stretch: 0;

    // ── Default appearance: bordered neutral (chip fill + hairline ring) ─────
    background: Theme.chip;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.hairline-float;

    animate background { duration: Theme.motion-fast; }
    animate border-color { duration: Theme.motion-fast; }

    // States: pressed > hover — Slint's first matching state wins, so list pressed
    // before hover (same ordering as PrimaryButton / NavItem).
    states [
        pressed when touch.pressed : {
            root.background: Theme.chip.darker(0.08);
            root.border-color: Theme.hairline-float;
        }
        hover when touch.has-hover : {
            root.background: Theme.chip.brighter(0.06);
            root.border-color: Theme.hairline-float.brighter(0.10);
        }
    ]

    // ── Label ─────────────────────────────────────────────────────────────────
    HorizontalLayout {
        padding-left: Theme.button-pad-x;
        padding-right: Theme.button-pad-x;
        // Optical centering: Slint metric-centers the full line box, so descender-less
        // labels sit ~1px high; the 9/7 pad split (button-pad-*) nudges down, not a `y:`.
        padding-top: Theme.button-pad-top;
        padding-bottom: Theme.button-pad-bottom;
        alignment: center;

        Text {
            text: root.text;
            color: Theme.text;
            font-size: Theme.font-label;
            font-weight: Theme.weight-medium;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // ── Accessibility ─────────────────────────────────────────────────────────
    accessible-role: button;
    accessible-label: root.text;
    // Let a screen-reader activation gesture fire the same callback as a click.
    accessible-action-default => { root.clicked(); }

    // TouchArea is non-focusable — it never steals keyboard focus from a parent
    // FocusScope (docs/patterns.md "TouchArea click focus recovery").
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
