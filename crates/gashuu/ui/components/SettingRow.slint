// SettingRow — L1 alignment molecule (issue 103): a fixed-width label column + an
// @children control slot from the shared seam to the right rail. `stacked` is an L4 stub.
import { Theme } from "../Theme.slint";

export component SettingRow inherits Rectangle {
    in property <string> label;
    // STUB (issue 103): stacked (L4) geometry is INCOMPLETE — row height not yet adapted
    // (a 30px control overflows the ~17px half-slot). Do NOT set stacked: true anywhere yet.
    in property <bool> stacked: false;   // L4 escape hatch (default = L1 horizontal)
    // Right-rail variant: compact atoms (Stepper/Toggle) opt in so their RIGHT
    // edge lands on the shared rail; fill atoms (Segmented) keep the default.
    in property <bool> trailing: false;

    height: Theme.settings-row-h;

    // Label: L1 at the left margin in the fixed label column; L4 (stacked) above the
    // control. overflow CLIPS (not elide) so the seam never drifts; text-mid, not accent.
    Text {
        x: 0;
        y: 0;
        width: root.stacked ? root.width : Theme.settings-label-col;
        height: root.stacked ? root.height / 2 : root.height;
        text: root.label;
        color: Theme.text-mid;
        font-size: Theme.font-body;
        horizontal-alignment: left;
        vertical-alignment: center;
        wrap: no-wrap;
        overflow: clip;
    }

    // Control slot: L1 from the seam to the right rail (centering a 30px atom in the
    // 34px row); L4 drops below the label. Fill stretches; trailing is pushed by the spacer.
    Rectangle {
        x: root.stacked ? 0px : Theme.settings-control-x;
        y: root.stacked ? root.height / 2 : 0px;
        width: parent.width - self.x;
        height: root.stacked ? root.height / 2 : root.height;
        HorizontalLayout {
            // No literal `alignment:` — it would disable child stretch factors. Fill rows
            // span seam → rail via the atom's stretch 1; trailing rows use this spacer.
            if root.trailing : Rectangle { horizontal-stretch: 1; }
            @children
        }
    }
}
