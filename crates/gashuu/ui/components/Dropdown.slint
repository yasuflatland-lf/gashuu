// Dropdown — HIG pull-down button; same model/current-index/selected shape as Segmented.
// FIRST PopupWindow: lowered to the window root so the menu escapes the clipping Flickable.
import { Theme } from "../Theme.slint";

export component Dropdown inherits Rectangle {
    // ── Public API (mirrors Segmented) ──────────────────────────────────────────
    in property <[string]> model;
    in-out property <int> current-index;
    in property <string> a11y-label;
    callback selected(int);

    // Externally focus this control (same `focus-control` seam as Segmented —
    // `focus` is a reserved builtin on the inherited Rectangle).
    public function focus-control() {
        fs.focus();
    }

    // ── Button capsule (same ground language as Segmented) ──────────────────────
    width: Theme.settings-dropdown-w;
    height: Theme.settings-control-h;
    background: Theme.surface-sunken;
    border-radius: Theme.radius-sm;
    border-width: 1px;
    border-color: fs.has-focus ? Theme.accent : Theme.hairline-float;
    // Soft accent-glow focus halo (one drop-shadow, no spread; discrete change —
    // animating drop-shadow is version-fragile, so only the border-color fades).
    drop-shadow-color: fs.has-focus ? Theme.accent-glow : transparent;
    drop-shadow-blur: fs.has-focus ? Theme.space-sm : 0px;
    animate border-color { duration: Theme.motion-fast; }

    // Sole mutator: update the selection and notify Rust. The Rust setter is
    // idempotent, so it absorbs the self-fire and there is no feedback loop.
    function pick(i: int) {
        root.current-index = i;
        root.selected(i);
    }

    // ── Keyboard (one Tab stop; menu rows use non-focusable TouchAreas) ─────────
    fs := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Space || event.text == Key.Return) {
                menu.show();
                return accept;
            }
            if (event.text == Key.UpArrow) {
                if (root.current-index > 0) { root.pick(root.current-index - 1); }
                return accept;
            }
            if (event.text == Key.DownArrow) {
                if (root.current-index < root.model.length - 1) { root.pick(root.current-index + 1); }
                return accept;
            }
            return reject;
        }
    }

    // ── Button face: current value + trailing chevron ───────────────────────────
    Text {
        x: Theme.space-sm;
        width: parent.width - Theme.space-sm * 2 - Theme.settings-dropdown-chevron - Theme.space-xs;
        height: parent.height;
        // Optical centering: Slint centers the full line box, but descender-less labels
        // sit ~1px high, so nudge down (y:1px) to center the GLYPHS (mirrors Segmented).
        y: 1px;
        text: root.model[root.current-index];
        color: Theme.text-high;
        font-size: Theme.font-label;
        vertical-alignment: center;
        horizontal-alignment: left;
        overflow: elide;
    }
    Image {
        source: @image-url("../assets/chevron-down.svg");
        width: Theme.settings-dropdown-chevron;
        height: Theme.settings-dropdown-chevron;
        x: parent.width - self.width - Theme.space-sm;
        y: (parent.height - self.height) / 2;
        image-fit: contain;
        // colorize overrides the SVG's own stroke color (assets precedent).
        colorize: Theme.text-dim;
    }

    TouchArea {
        clicked => {
            fs.focus();
            menu.show();
        }
    }

    // Menu (PopupWindow, lowered to window root — escapes the Flickable). Padded by
    // `shadow-pad` so the panel's drop shadow blurs inside the popup bounds, not clipped.
    property <length> shadow-pad: Theme.space-xl;
    property <length> menu-h: root.model.length * Theme.settings-control-h + 2 * Theme.space-xxs;

    menu := PopupWindow {
        x: -root.shadow-pad;
        y: root.height + Theme.space-xxs - root.shadow-pad;
        width: root.width + 2 * root.shadow-pad;
        height: root.menu-h + 2 * root.shadow-pad;

        Rectangle {
            x: root.shadow-pad;
            y: root.shadow-pad;
            width: root.width;
            height: root.menu-h;
            background: Theme.surface-raised;
            border-radius: Theme.radius-sm;
            border-width: 1px;
            border-color: Theme.glass-border;
            drop-shadow-color: Theme.shadow-popover;
            drop-shadow-blur: 12px;
            drop-shadow-offset-y: 4px;

            VerticalLayout {
                padding: Theme.space-xxs;
                spacing: 0px;
                for item[idx] in root.model : Rectangle {
                    height: Theme.settings-control-h;
                    // HIG menu hover: accent fill + white text (direct bindings —
                    // a states[] block cannot touch these child props).
                    background: ta.has-hover ? Theme.accent : transparent;
                    border-radius: Theme.radius-xs;
                    animate background { duration: Theme.motion-fast; }

                    // a11y: each row is a selectable list item; AT activation
                    // selects it (the same path a click takes).
                    accessible-role: list-item;
                    accessible-label: item;
                    accessible-item-index: idx;
                    accessible-item-selectable: true;
                    accessible-item-selected: idx == root.current-index;
                    accessible-action-default => { root.pick(idx); }

                    HorizontalLayout {
                        padding-left: Theme.space-sm;
                        padding-right: Theme.space-sm;
                        spacing: Theme.space-xs;

                        // Check-mark column: fixed width so labels align whether or not
                        // the row is selected. Same 1px optical nudge as the button face.
                        Text {
                            width: Theme.font-label;
                            y: 1px;
                            text: idx == root.current-index ? "\u{2713}" : "";
                            color: ta.has-hover ? Theme.text : Theme.accent;
                            font-size: Theme.font-label;
                            vertical-alignment: center;
                        }
                        Text {
                            y: 1px;
                            text: item;
                            color: ta.has-hover ? Theme.text : Theme.text-high;
                            font-size: Theme.font-label;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }

                    ta := TouchArea {
                        // The popup's close-on-click policy dismisses the menu
                        // after this fires — no explicit close() needed.
                        clicked => {
                            root.pick(idx);
                        }
                    }
                }
            }
        }
    }

    // ── a11y (root) ─────────────────────────────────────────────────────────────
    accessible-role: combobox;
    accessible-label: root.a11y-label;
    accessible-value: root.model[root.current-index];
    accessible-action-default => { menu.show(); }
}
