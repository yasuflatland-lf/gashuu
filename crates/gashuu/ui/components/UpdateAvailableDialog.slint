// UpdateAvailableDialog — notifies the user a newer gashuu release is available
// (auto-update epic). GENERIC three-choice modal on GlassModal, mirroring
// ConfirmDialog's FocusScope/key-trap structure (see that file's header for the
// full i-slint-core rationale), with THREE actions: Update now / Later / Skip.
//
// KEY MODEL: backdrop click, Esc, and Enter/Return ALL map to later(). Update now
// is NEVER bound to Enter (reachable only by click or Tab→Space, even while it holds
// focus); every OTHER key is swallowed. `fs` WRAPS the panel so it's a genuine
// ANCESTOR of the buttons (upward key walk).
//
// DEFAULT FOCUS: Later (safe, non-committing). Set on `fs.init`; re-instantiated on
// every `if` mount (ViewerWindow usage contract), so no focus-epoch needed (never
// stacked). TAB ORDER: Update now → Later → Skip → wrap; unlike ConfirmDialog's
// 2-stop toggle, 3 stops need direction, so the handler distinguishes Tab (forward)
// from Backtab / shift+Tab (backward).
//
// Buttons are TouchArea-based/non-focusable, each wrapped in the shared FocusButton
// (issue 362). The RELEASE NOTES LINK is mouse/AT-only and NOT in the Tab cycle: it
// is `if`-gated, so its id lives in a child scope the ancestor `fs` cannot name — the
// three real decisions stay fully keyboard-reachable, which is what matters.
import { Theme } from "../Theme.slint";
import { Strings } from "../Strings.slint";
import { PrimaryButton } from "PrimaryButton.slint";
import { SecondaryButton } from "SecondaryButton.slint";
import { GlassModal } from "GlassModal.slint";
import { FocusButton } from "FocusButton.slint";

export component UpdateAvailableDialog inherits GlassModal {
    // ── Public API (pinned — auto-update epic Task 9 signature) ───────────────
    in property <string> current-version;
    in property <string> latest-version;
    // Whether the release has notes to show (gates the "Release notes" link).
    in property <bool> notes-available: true;
    // True while a download/self-replace is running (shows `status-text`).
    in property <bool> in-progress: false;
    // Pre-composed transient status (e.g. "Downloading…", "Verifying…").
    in property <string> status-text;

    // Fired on the "Update now" button (pointer click or Tab→Space).
    callback accept();
    // Fired on Esc, Return/Enter, backdrop click, or the "Later" button.
    callback later();
    // Fired on the "Skip this version" button.
    callback skip();
    // Fired on the "Release notes" link.
    callback notes();

    // Panel geometry + backdrop (glass chrome in GlassModal). Same fluid-width
    // clamp as ConfirmDialog (settings-w token); height hugs the content.
    panel-width: min(Theme.settings-w, root.width - 2 * Theme.space-xl);
    panel-height: body-col.preferred-height;
    backdrop-clicked => { root.later(); }

    // FocusScope: Esc/Enter → later, Tab/Backtab rotate 3 stops. WRAPS the panel as
    // a genuine ANCESTOR of the button scopes (see the header for the rationale).
    fs := FocusScope {
        x: 0;
        y: 0;
        // Size to the glass PANEL, not `parent` (see ConfirmDialog): @children content
        // is sized to the WINDOW; `root.panel-*` is the panel's true size.
        width: root.panel-width;
        height: root.panel-height;
        init => {
            later-scope.focus();
        }
        key-pressed(event) => {
            // Esc and Return/Enter BOTH defer to later() — the safe choice, so a
            // reflexive press never fires accept(), even when Update now holds focus
            // (its scope rejects all but Space, so Return bubbles up here).
            if (event.text == Key.Escape || event.text == Key.Return) {
                root.later();
                return EventResult.accept;
            }
            // Forward Tab: Update now → Later → Skip this version → (wrap).
            if (event.text == Key.Tab && !event.modifiers.shift) {
                if (accept-scope.has-focus) {
                    later-scope.focus();
                } else if (later-scope.has-focus) {
                    skip-scope.focus();
                } else {
                    accept-scope.focus();
                }
                return EventResult.accept;
            }
            // Backward (Backtab, or shift+Tab — backend-dependent, same caveat as
            // ConfirmDialog): Skip → Later → Update now → (wrap).
            if (event.text == Key.Backtab || (event.text == Key.Tab && event.modifiers.shift)) {
                if (skip-scope.has-focus) {
                    later-scope.focus();
                } else if (later-scope.has-focus) {
                    accept-scope.focus();
                } else {
                    skip-scope.focus();
                }
                return EventResult.accept;
            }
            // Catch-all: swallow every other key. NOTE: bare `accept`/`reject` are
            // ambiguous here because this component declares an `accept()` callback,
            // so use the qualified `EventResult.accept` (bare `accept` resolves to the
            // callback → "Callback must be called").
            return EventResult.accept;
        }

        // ── Panel content: title, version row, notes link, status, buttons ────
        body-col := VerticalLayout {
            x: 0;
            y: 0;
            width: parent.width;
            padding: Theme.space-xl;
            spacing: Theme.space-lg;

            // ── Title ──────────────────────────────────────────────────────
            Text {
                text: Strings.update-available-title;
                font-size: Theme.font-title;
                font-weight: Theme.weight-semibold;
                color: Theme.text-high;
                horizontal-alignment: left;
                wrap: word-wrap;
                accessible-role: text;
                accessible-label: Strings.update-available-title;
            }

            // ── "current → latest" row ────────────────────────────────────
            Text {
                text: root.current-version + " \u{2192} " + root.latest-version;
                font-size: Theme.font-body;
                color: Theme.text-mid;
                horizontal-alignment: left;
                wrap: word-wrap;
            }

            // ── Release notes link (mouse/screen-reader only — see header) ──
            if root.notes-available : Rectangle {
                height: notes-label.preferred-height;
                notes-label := Text {
                    text: Strings.update-notes-label;
                    font-size: Theme.font-label;
                    font-weight: Theme.weight-medium;
                    color: Theme.accent;
                    horizontal-alignment: left;
                }
                TouchArea {
                    width: notes-label.preferred-width;
                    height: notes-label.preferred-height;
                    clicked => {
                        root.notes();
                    }
                }
                accessible-role: button;
                accessible-label: Strings.update-notes-label;
                accessible-action-default => { root.notes(); }
            }

            // ── Transient status (download/verify progress) ─────────────────
            if root.in-progress : Text {
                text: root.status-text;
                font-size: Theme.font-label;
                color: Theme.text-dim;
                horizontal-alignment: left;
                wrap: word-wrap;
            }

            // Action row, pinned right by a leading stretch spacer (same idiom as
            // ConfirmDialog — a literal `alignment:` would DISABLE the stretch).
            HorizontalLayout {
                spacing: Theme.space-md;

                Rectangle { horizontal-stretch: 1; }

                // Update now — the affirmative action, the single accent CTA (never
                // destructive, so PrimaryButton not DangerButton).
                accept-scope := FocusButton {
                    pressed => { root.accept(); }
                    PrimaryButton {
                        text: Strings.update-accept-label;
                        clicked => {
                            root.accept();
                        }
                    }
                }

                // Later — holds the default focus on open; the safe,
                // non-committing choice (same role as ConfirmDialog's Cancel).
                later-scope := FocusButton {
                    pressed => { root.later(); }
                    SecondaryButton {
                        text: Strings.update-later-label;
                        clicked => {
                            root.later();
                        }
                    }
                }

                // Skip this version — a low-prominence utility action (bordered
                // neutral, like the Settings dialog's utility actions).
                skip-scope := FocusButton {
                    pressed => { root.skip(); }
                    SecondaryButton {
                        text: Strings.update-skip-label;
                        clicked => {
                            root.skip();
                        }
                    }
                }
            }
        }
    }
}
