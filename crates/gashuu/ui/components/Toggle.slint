// Toggle — token-driven on/off switch (issue 102, PR-A/3).
//
// Drop-in replacement for the std-widgets `CheckBox` row in the settings dialog:
// SAME `checked` (two-way) + `toggled(bool)` shape, painted from `Theme.*`. A
// capsule (radius = height/2) whose track is `accent` when on / `track-prog` when off
// (the darker `track` tone sat too close to the glass fill to read as a track —
// HIG switches keep the off state plainly visible); a white knob with a subtle
// depth shadow slides left↔right by animating its `x` (NOT opacity — HiDPI
// blur) on the Carousel's spring curve. In the PR-A interim layout it is paired
// with a sibling label `Text`.
//
// Keyboard (when focused): Space/Enter toggles. Focus shows an `accent` border +
// a soft `accent-glow` halo. All colors/lengths are `Theme.*` (check-tokens.sh).
import { Theme } from "../Theme.slint";

export component Toggle inherits Rectangle {
    // ── Public API (mirrors the CheckBox it replaces) ───────────────────────────
    in-out property <bool> checked;
    in property <string> a11y-label;
    callback toggled(bool);

    // ── Pill (fixed φ-proportion track — Apple's 51×31 switch ratio). WIDTH and
    //    HEIGHT are explicit bindings, not min-*: a layout stretches children
    //    across its cross axis past min-height, so inside the SettingRow slot the
    //    30px track inflated to the 34px row height (breaking φ and bloating the
    //    knob) — the atom pins its own size. ────────────────────────────────────
    width: Theme.toggle-track-w;
    height: Theme.settings-control-h;
    horizontal-stretch: 0;
    vertical-stretch: 0;
    // TRUE capsule (radius = height/2), like Apple's switch track: radius-pill
    // renders an ELLIPSE on the non-square track (femtovg per-axis clamp, see
    // docs/patterns.md). The knob below is square, so its radius-pill is fine.
    border-radius: self.height / 2;
    background: root.checked ? Theme.accent : Theme.track-prog;
    border-width: 1px;
    border-color: fs.has-focus ? Theme.accent : Theme.hairline-float;
    drop-shadow-color: fs.has-focus ? Theme.accent-glow : transparent;
    drop-shadow-blur: fs.has-focus ? Theme.space-sm : 0px;
    animate background, border-color { duration: Theme.motion-fast; }

    function flip() {
        root.checked = !root.checked;
        root.toggled(root.checked);
    }

    // ── Knob: white circle that slides via an animated x (no opacity) ────────────
    Rectangle {
        height: root.height - 2 * Theme.toggle-knob-inset;
        width: self.height;
        y: (root.height - self.height) / 2;
        x: root.checked
            ? root.width - self.width - Theme.toggle-knob-inset
            : Theme.toggle-knob-inset;
        background: Theme.text;
        border-radius: Theme.radius-pill;
        // HIG knob depth: one subtle drop shadow lifts the knob off the track
        // (the Scrubber knob's single-shadow idiom; the focus halo lives on the
        // root, so each element still carries at most one shadow).
        drop-shadow-color: Theme.shadow-popover;
        drop-shadow-blur: 4px;
        drop-shadow-offset-y: 1px;
        // Spring slide — the Carousel's curve; Slint has no <easing> property
        // type, so the cubic-bezier is repeated inline (Theme.slint motion note).
        animate x { duration: Theme.motion-fast; easing: cubic-bezier(0.16, 1, 0.3, 1); }
    }

    // ── a11y ──────────────────────────────────────────────────────────────────
    accessible-role: switch;
    accessible-label: root.a11y-label;
    accessible-checkable: true;
    accessible-checked: root.checked;
    accessible-action-default => { root.flip(); }

    // ── Keyboard (Tab-focusable; click handled by the non-focusable TouchArea) ───
    fs := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Space || event.text == Key.Return) {
                root.flip();
                return accept;
            }
            return reject;
        }
    }

    TouchArea {
        clicked => {
            fs.focus();
            root.flip();
        }
    }
}
