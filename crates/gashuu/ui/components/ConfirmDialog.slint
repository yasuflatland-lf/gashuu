// ConfirmDialog — reusable confirm/cancel modal (issue 127). GENERIC two-choice
// modal carrying NO domain vocabulary: every visible word arrives via a property.
// Built on GlassModal's glass idiom; sheen is a FILL gradient, not opacity (opacity
// blurs text/SVG on HiDPI); show/hide is `if`/`visible:`, never opacity.
//
// KEY MODEL (docs/patterns.md FocusScope-ancestor + modal-key-trap): backdrop click,
// Esc, and Enter/Return ALL map to cancel(). The affirmative (possibly destructive)
// action is NEVER bound to Enter — reachable ONLY by pointer click or Tab→Space, even
// while its button holds focus. Every OTHER key is swallowed so nothing leaks to the
// live content behind. `fs` WRAPS the panel so it is a genuine ANCESTOR of the button
// scopes: Slint walks a rejected key strictly UP the parent chain (i-slint-core 1.16
// window.rs), never a SIBLING — a sibling `fs` leaves Esc/Enter dead. Gate-invisible
// (cargo gates don't exercise .slint keys — verify by hand).
//
// DEFAULT FOCUS: Cancel, set on BOTH `fs.init` AND `changed focus-epoch` (`changed`
// does NOT fire on the initial binding). USAGE CONTRACT: mount behind an `if` gate,
// not `visible:`, so `init` re-runs and re-focuses Cancel on every open; the epoch
// handler re-claims focus after a stacked overlay closes.
//
// BUTTONS: DangerButton/PrimaryButton are TouchArea-based/non-focusable, so each is
// wrapped in the shared FocusButton (a FocusScope) that draws the ring and fires
// `pressed` on Space. Tab/Backtab/Enter/Esc are rejected by the button scopes and
// bubble to `fs`, which maps Enter/Esc to cancel() and ROTATES focus between the two
// stops itself — never deferring to Slint's window Tab nav, which could carry focus
// OUT of the modal.

import { Theme } from "../Theme.slint";
import { DangerButton } from "DangerButton.slint";
import { PrimaryButton } from "PrimaryButton.slint";
import { GlassModal } from "GlassModal.slint";
import { FocusButton } from "FocusButton.slint";

export component ConfirmDialog inherits GlassModal {
    // ── Public API (pinned — issue 127 signature) ─────────────────────────────
    // Heading line.
    in property <string> title;
    // Optional itemized lines under the title (rendered one Text per entry).
    in property <[string]> body-lines;
    // Neutral explainer, drawn on a calm surface band. Empty ⇒ band hidden.
    in property <string> info-text;
    // Danger-colored caution line. Empty ⇒ hidden.
    in property <string> warning-text;
    // Affirmative button label.
    in property <string> confirm-label;
    // Dismiss button label.
    in property <string> cancel-label;
    // When true the confirm button is the destructive DangerButton; otherwise the
    // neutral PrimaryButton.
    in property <bool> danger: false;
    // Bumped by the parent to (re)claim keyboard focus onto Cancel.
    in property <int> focus-epoch: 0;
    // Fired on the confirm button (pointer click or Tab→Space).
    callback confirm();
    // Fired on Esc, Return/Enter, backdrop click, or the Cancel button.
    callback cancel();

    changed focus-epoch => {
        // Re-claim focus onto Cancel when the parent bumps the epoch (the
        // `changed`-doesn't-fire-on-init half; `init` below owns the open path).
        cancel-scope.focus();
    }

    // Panel geometry + backdrop (glass chrome in GlassModal). Fluid width: caps on
    // wide windows, gutters on narrow ones (settings-w clamp); height hugs content.
    panel-width: min(Theme.settings-w, root.width - 2 * Theme.space-xl);
    // Reading body-col.preferred-height here is safe (computed bottom-up, no cycle).
    // TRAP: if body-col gains an explicit `height:`, panel.height → preferred-height
    // combined with fs.height = panel.height becomes circular — drop the explicit
    // height instead (SettingsDialog assembles height from named sub-parts).
    panel-height: body-col.preferred-height;
    backdrop-clicked => { root.cancel(); }

    // FocusScope: Esc/Enter → cancel, swallow everything else. WRAPS the panel so
    // it's a genuine ANCESTOR of the button scopes (rejected-key upward walk); it
    // doesn't keep focus (init/epoch hand it to Cancel). FocusScope doesn't intercept
    // pointer events, so empty-panel clicks fall through to GlassModal's absorber
    // regardless of declaration order.
    fs := FocusScope {
        x: 0;
        y: 0;
        // Size to the glass PANEL, not `parent`: @children only relocates where the
        // element DRAWS — `parent` still resolves to the lexical root (fills the
        // window), so `parent.*` would overflow the panel. `root.panel-*` is its size.
        width: root.panel-width;
        height: root.panel-height;
        init => {
            cancel-scope.focus();
        }
        key-pressed(event) => {
            // Esc and Return/Enter BOTH cancel — Return is deliberately the safe
            // choice so a reflexive press never fires confirm, even when it holds
            // focus (its scope rejects all but Space, so Return bubbles up here).
            if (event.text == Key.Escape
                || event.text == Key.Return) {
                root.cancel();
                return accept;
            }
            // Tab/Backtab: rotate focus between the two stops OURSELVES. The button
            // scopes reject Tab so it bubbles here; accepting without moving focus
            // (old catch-all) means Slint's window Tab nav never fires (the upward
            // walk returns EventAccepted first) → Confirm unreachable. But
            // reject-and-defer risks window nav carrying focus OUT of the modal (a
            // live focusable backdrop sits behind it), so we rotate in-trap. Two
            // stops → forward and backward are the same toggle; Backtab may arrive
            // as Key.Backtab or Key.Tab+shift, both fall into it.
            if (event.text == Key.Tab || event.text == Key.Backtab) {
                if (cancel-scope.has-focus) {
                    confirm-scope.focus();
                } else {
                    // confirm-scope focused, or `fs` still holds the initial
                    // focus before `init` handed it off — go to Cancel.
                    cancel-scope.focus();
                }
                return accept;
            }
            // Catch-all: swallow every other key so nothing leaks to content
            // mounted behind this modal.
            return accept;
        }

        // ── Panel content: title, optional body lines, info band, warning,
        //    and the action row ─────────────────────────────────────────────
        body-col := VerticalLayout {
            x: 0;
            y: 0;
            width: parent.width;
            padding: Theme.space-xl;
            spacing: Theme.space-lg;

            // ── Title ──────────────────────────────────────────────────────
            Text {
                text: root.title;
                font-size: Theme.font-title;
                font-weight: Theme.weight-semibold;
                color: Theme.text-high;
                horizontal-alignment: left;
                wrap: word-wrap;
                accessible-role: text;
                accessible-label: root.title;
            }

            // Optional itemized body lines — one Text per entry. The parent truncates
            // the model before binding; this component renders what it is given.
            if root.body-lines.length > 0 : VerticalLayout {
                spacing: Theme.space-xxs;
                for line in root.body-lines : Text {
                    text: line;
                    font-size: Theme.font-body;
                    color: Theme.text-mid;
                    horizontal-alignment: left;
                    wrap: word-wrap;
                }
            }

            // Info band — neutral explainer on a calm raised surface, hidden when
            // empty. Uses surface-raised, not error-surface (its red ground signals
            // a failed-decode STATE — wrong for a reassuring note).
            if root.info-text != "" : Rectangle {
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                HorizontalLayout {
                    padding: Theme.space-md;
                    Text {
                        text: root.info-text;
                        font-size: Theme.font-body;
                        color: Theme.text-muted;
                        horizontal-alignment: left;
                        wrap: word-wrap;
                    }
                }
            }

            // ── Warning line ───────────────────────────────────────────────
            // Danger-colored caution. Hidden when empty (`if` gate).
            if root.warning-text != "" : Text {
                text: root.warning-text;
                font-size: Theme.font-body;
                font-weight: Theme.weight-medium;
                color: Theme.danger;
                horizontal-alignment: left;
                wrap: word-wrap;
            }

            // Action row [Cancel] [Confirm], pinned right by a leading stretch spacer
            // (a literal `alignment:` would DISABLE the stretch — docs/patterns.md).
            // Cancel is leftmost so the safe choice is the first Tab stop.
            HorizontalLayout {
                spacing: Theme.space-md;

                // Stretch spacer: pushes the buttons hard right.
                Rectangle { horizontal-stretch: 1; }

                // Cancel — holds default focus. Space cancels; Enter/Esc are rejected
                // so `fs` handles them (keeps the key model in ONE place).
                cancel-scope := FocusButton {
                    pressed => { root.cancel(); }
                    PrimaryButton {
                        text: root.cancel-label;
                        clicked => {
                            root.cancel();
                        }
                    }
                }

                // Confirm — same wrapper, swapping DangerButton/PrimaryButton on
                // `danger` (mutually-exclusive `if` gates). Space fires confirm;
                // Enter/Esc bubble to `fs` → cancel, so confirm is never reached by Enter.
                confirm-scope := FocusButton {
                    pressed => { root.confirm(); }
                    if root.danger : DangerButton {
                        text: root.confirm-label;
                        clicked => {
                            root.confirm();
                        }
                    }
                    if !root.danger : PrimaryButton {
                        text: root.confirm-label;
                        clicked => {
                            root.confirm();
                        }
                    }
                }
            }
        }
    }
}
