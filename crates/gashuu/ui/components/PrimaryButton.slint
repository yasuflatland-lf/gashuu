// PrimaryButton — DESIGN.md `components.button-primary`: the accent-ground push
// button. Colors route through Theme (no inline hex); accent is the sole interactive hue.

import { Theme } from "../Theme.slint";

export component PrimaryButton inherits Rectangle {
    // ── Public API ────────────────────────────────────────────────────────────
    in property <string> text;
    callback clicked;

    // Sizing: root sizes to content (layout min-size drives width; padding drives
    // height). min-height 32px satisfies the DESIGN hit-area floor.
    min-height: Theme.button-min-h;
    horizontal-stretch: 0;
    vertical-stretch: 0;

    // ── Default appearance ────────────────────────────────────────────────────
    background: Theme.accent;
    border-radius: Theme.radius-md;

    animate background { duration: Theme.motion-fast; }

    // States: pressed > hover — Slint's first matching state wins, so list pressed
    // before hover (same ordering as the Slint fluent Button).
    states [
        pressed when touch.pressed : {
            root.background: Theme.accent.darker(0.20);
        }
        hover when touch.has-hover : {
            root.background: Theme.accent.darker(0.08);
        }
    ]

    // ── Label ─────────────────────────────────────────────────────────────────
    HorizontalLayout {
        padding-left: Theme.button-pad-x;
        padding-right: Theme.button-pad-x;
        // Optical centering: Slint metric-centers the full line box, so descender-less
        // labels sit ~1px high; the 9/7 pad split (button-pad-*) nudges down, not a `y:`.
        padding-top: Theme.button-pad-top;
        padding-bottom: Theme.button-pad-bottom;
        alignment: center;

        Text {
            text: root.text;
            color: Theme.text;
            font-size: Theme.font-label;
            font-weight: Theme.weight-medium;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // ── Accessibility ─────────────────────────────────────────────────────────
    accessible-role: button;
    accessible-label: root.text;
    // Let a screen-reader activation gesture fire the same callback as a click.
    accessible-action-default => { root.clicked(); }

    // TouchArea is non-focusable — it never steals keyboard focus from a parent
    // FocusScope (docs/patterns.md "TouchArea click focus recovery").
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
