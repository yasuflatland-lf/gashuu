// SelectionBadge — two-state bulk-selection check badge. ACCENT, never red (reserved for
// delete). Two states via DIRECT ternary bindings (states[] can't touch child props).
import { Theme } from "../Theme.slint";

export component SelectionBadge inherits Rectangle {
    // True -> filled accent disc + check; false -> hollow text-mid ring. Defaults
    // to true so existing call sites keep the original filled rendering.
    in property <bool> checked: true;

    // The disc footprint is identical in both states (zero jump on toggle); only
    // the fill/border/glyph differ by `checked`.
    width: Theme.space-huge;
    height: Theme.space-huge;
    border-radius: Theme.radius-pill;
    // Filled accent disc when checked; a faint dark glass backing (for legibility
    // over cover art) with a 1px text-mid ring when unchecked.
    background: root.checked ? Theme.accent : Theme.glass-fill;
    border-width: root.checked ? 0px : 1px;
    border-color: Theme.text-mid;

    // Centered white check mark, recolored from the single-path SVG. Gated on
    // `checked` so the unchecked ring carries no glyph.
    if root.checked : Image {
        source: @image-url("../assets/check.svg");
        width: Theme.space-lg;
        height: Theme.space-lg;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        image-fit: contain;
        colorize: Theme.text;
    }
}
