// NavBar — top centered "glass pill": search field, divider, icon-only capsules
// (Add files/folder, or a combined Add-books on macOS, plus Select/Bookmark/Settings).
// Slint 1.x has no backdrop-blur, so the glass is faked with 4 cheap layers; the
// width is computed from tokens (not layout preferred-width) to avoid a binding
// loop. Colors/lengths from Theme.* only (scripts/check-tokens.sh).
import { Theme } from "../Theme.slint";
import { Strings } from "../Strings.slint";
import { NavItem } from "NavItem.slint";

// File-private live search field (issue 88). TextInput (not LineEdit) so every
// color comes from Theme.* — LineEdit's native palette would bypass the token rule.
component SearchField inherits Rectangle {
    // ── Public API ────────────────────────────────────────────────────────────
    in-out property <string> query;
    in property <image> search-icon;
    callback debounced-query(string);
    callback exit-search();

    // Restore focus to the input (and select existing text) when the carousel
    // hands focus over via `/` or a click. Exposed so NavBar can forward it.
    public function focus-self() {
        input.focus();
        input.select-all();
    }

    // Shape: transparent background so the field reads as the same glass color (a
    // sunken fill stood out as a darker box); border delineates it, accent on focus.
    width: Theme.nav-search-width;
    height: Theme.nav-capsule;
    border-radius: Theme.nav-search-radius;
    background: transparent;
    border-width: Theme.nav-divider-width;
    border-color: input.has-focus ? Theme.accent : Theme.search-border-rest;
    animate border-color { duration: Theme.motion-fast; }

    // Leading magnifier icon: colorized text-mid to match NavItem's icon family.
    icon := Image {
        source: root.search-icon;
        width: Theme.nav-search-icon;
        height: Theme.nav-search-icon;
        x: Theme.nav-search-pad-x;
        y: Theme.snap((parent.height - self.height) / 2);
        image-fit: contain;
        colorize: Theme.text-mid;
    }

    // Text starts after the icon + a small gap so it never overlaps the glyph;
    // placeholder and input share the same column geometry (text-x / text-width).
    property <length> text-x: Theme.nav-search-pad-x + Theme.nav-search-icon + Theme.space-xs;
    property <length> text-width: root.width - root.text-x - Theme.nav-search-pad-x;

    // ── Placeholder (shown only while empty) ──────────────────────────────────
    Text {
        visible: root.query == "";
        x: root.text-x;
        width: root.text-width;
        height: 100%;
        text: Strings.navbar-search-placeholder;
        color: Theme.text-dim;
        font-size: Theme.font-label;
        vertical-alignment: center;
        overflow: elide;
        accessible-role: none;
    }

    // ── The actual text input ─────────────────────────────────────────────────
    input := TextInput {
        x: root.text-x;
        y: 0;
        width: root.text-width;
        height: 100%;
        text <=> root.query;
        single-line: true;
        color: Theme.text;
        font-size: Theme.font-label;
        vertical-alignment: center;
        selection-background-color: Theme.accent-glow;
        selection-foreground-color: Theme.text;
        text-cursor-width: Theme.nav-search-cursor;
        accessible-role: text-input;
        accessible-label: Strings.navbar-search-a11y;
        accessible-placeholder-text: Strings.navbar-search-placeholder;

        // Each keystroke re-arms the trailing debounce, so the query callback
        // fires ~120ms after the LAST edit.
        edited => {
            debounce.stop();
            debounce.start();
        }

        // Enter commits the current query immediately and returns focus to the
        // carousel. It must NOT open the first result — that is intentional.
        accepted => {
            debounce.stop();
            root.debounced-query(root.query);
            root.exit-search();
        }

        key-pressed(event) => {
            // Escape clears the query, flushes an empty filter, and exits.
            if (event.text == Key.Escape) {
                root.query = "";
                debounce.stop();
                root.debounced-query("");
                root.exit-search();
                return accept;
            }
            // Down commits the current query and hands focus back to the
            // carousel WITHOUT switching to the viewer (carousel's Down does).
            if (event.text == Key.DownArrow) {
                debounce.stop();
                root.debounced-query(root.query);
                root.exit-search();
                return accept;
            }
            return reject;
        }
    }

    // ── 120ms trailing debounce ───────────────────────────────────────────────
    debounce := Timer {
        interval: 120ms;
        running: false;
        triggered => {
            root.debounced-query(root.query);
            debounce.stop();
        }
    }
}

export component NavBar inherits Rectangle {
    // ── Public API ────────────────────────────────────────────────────────────
    in property <image> file-icon;
    in property <image> folder-icon;
    in property <image> plus-icon;
    in property <image> search-icon;
    in property <image> settings-icon;
    // The filter glyph for the bulk-selection capsule.
    in property <image> select-icon;
    // The bookmark glyph for the continue-reading capsule.
    in property <image> bookmark-icon;
    // Mirrors the carousel's selection mode; drives the capsule's persistent
    // active ring (the toggle affordance: re-click exits selection).
    in property <bool> selection-active;
    // False on an empty library — the capsule dims/faints instead of
    // disappearing, so the computed pill width never jumps.
    in property <bool> select-enabled: true;
    // True when the platform's native panel picks files AND folders in one dialog
    // (macOS): collapses the two add capsules into one. Pushed once from Rust at boot.
    in property <bool> combined-add-picker;
    in-out property <string> search-query;
    // When true, a translucent veil recedes the NavBar behind foreground content;
    // wired to `selection-mode && !modal-open` so it never compounds a modal scrim.
    in property <bool> receded: false;
    callback add-books();
    callback add-folder();
    callback settings();
    callback search-changed(string);
    callback search-exit();
    // Enter/exit bulk-selection.
    callback toggle-selection();
    // Jump to the continue-reading book. ALWAYS enabled: with no bookmark the click
    // answers with a status notice, so a faint capsule would hide the affordance.
    callback continue-reading();

    // Move keyboard focus into the search field (carousel `/` and click).
    public function focus-search() { search.focus-self(); }

    // Width from tokens (not layout preferred-width) to avoid a binding loop.
    //   combined (macOS): search + 4*capsule + divider + 5*gap + 2*pad
    //   split (elsewhere): search + 5*capsule + divider + 6*gap + 2*pad
    height: Theme.nav-pill-height;
    width: Theme.nav-search-width
        + (root.combined-add-picker ? 4 : 5) * Theme.nav-capsule
        + Theme.nav-divider-width
        + (root.combined-add-picker ? 5 : 6) * Theme.nav-item-gap
        + 2 * Theme.nav-pill-pad;
    horizontal-stretch: 0;
    vertical-stretch: 0;

    // ── Glass approximation (layers 1, 2 and 4; see header) ───────────────────
    background: Theme.glass-fill;
    border-radius: Theme.nav-pill-radius;
    border-width: 1px;
    border-color: Theme.glass-border;
    drop-shadow-color: Theme.shadow-popover;
    drop-shadow-blur: Theme.shadow-blur-float;
    drop-shadow-offset-y: Theme.shadow-offset-float;

    // Glass layer 3: top highlight rim, inset horizontally by ~half the height so
    // it stays inside the rounded corners (pill radius caps at half height).
    Rectangle {
        x: Theme.nav-pill-height / 2;
        y: 1px;
        width: parent.width - Theme.nav-pill-height;
        height: 1px;
        background: Theme.glass-highlight;
    }

    // ── Items: search field, divider, then the five icon-only capsules ────────
    HorizontalLayout {
        spacing: Theme.nav-item-gap;
        padding: Theme.nav-pill-pad;
        alignment: center;

        search := SearchField {
            query <=> root.search-query;
            search-icon: root.search-icon;
            debounced-query(q) => { root.search-changed(q); }
            exit-search => { root.search-exit(); }
        }

        // Thin vertical divider separating search from the action capsules.
        // ~60% of the capsule height, vertically centered within its layout cell.
        Rectangle {
            width: Theme.nav-divider-width;
            vertical-stretch: 0;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: Theme.nav-divider-width;
                    height: Theme.nav-capsule * 0.6;
                    background: Theme.hairline-float;
                }
            }
        }

        // Both the combined and files capsules fire the SAME add-books() intent;
        // Rust picks the dialog flavor. NavItem is TouchArea-based (no FocusScope
        // id), so `if` is safe.
        if root.combined-add-picker : NavItem {
            icon: root.plus-icon;
            a11y-label: Strings.navbar-add-books-a11y;
            clicked => { root.add-books(); }
        }
        if !root.combined-add-picker : NavItem {
            icon: root.file-icon;
            a11y-label: Strings.navbar-add-files-a11y;
            clicked => { root.add-books(); }
        }
        if !root.combined-add-picker : NavItem {
            icon: root.folder-icon;
            a11y-label: Strings.navbar-add-folder-a11y;
            clicked => { root.add-folder(); }
        }
        // Bulk-selection toggle, gated by select-enabled (faint not removed → stable
        // pill width). NOT modal-gated: the backdrop absorber blocks input, and
        // folding a modal flag into `enabled` would flicker the capsule under the scrim.
        NavItem {
            icon: root.select-icon;
            a11y-label: Strings.selection-enter;
            active: root.selection-active;
            enabled: root.select-enabled;
            clicked => { root.toggle-selection(); }
        }
        // Continue-reading jump. ALWAYS enabled: with no bookmark the click answers
        // with a status notice, so a faint capsule would hide the affordance.
        NavItem {
            icon: root.bookmark-icon;
            a11y-label: Strings.continue-reading;
            clicked => { root.continue-reading(); }
        }
        NavItem {
            icon: root.settings-icon;
            a11y-label: Strings.settings-title;
            clicked => { root.settings(); }
        }
    }

    // Recede veil — MUST be the last child (paints over all controls); shares the
    // root radius to clip to the pill. No TouchArea, so controls stay clickable
    // through it (Rectangles are pointer-transparent by default).
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        border-radius: Theme.nav-pill-radius;
        background: root.receded ? Theme.scrim-soft : transparent;
        animate background { duration: Theme.motion-fast; }
    }
}
