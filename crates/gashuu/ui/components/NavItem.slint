// NavItem — circular icon-only capsule for the glass-pill nav: a centered,
// colorized icon on a transparent ground. Reserves a transparent 1px border so
// the hover/active accent ring can appear without shifting the icon or footprint.
// Disabled: faint icon, inert, but stays mounted so the NavBar width never jumps.
// Colors/lengths from Theme.* only (scripts/check-tokens.sh).
import { Theme } from "../Theme.slint";

export component NavItem inherits Rectangle {
    // ── Public API ────────────────────────────────────────────────────────────
    in property <image> icon;
    in property <string> a11y-label;
    callback clicked;
    // Exposed so a container can keep its auto-hiding chrome visible while the
    // pointer rests on this capsule.
    out property <bool> hovered: touch.has-hover;
    // Opt-in: hold the hover look (accent ring + glow) while a mode is active
    // (e.g. selection). Default false so existing call sites are unaffected.
    in property <bool> active: false;
    // Opt-in: when false the capsule is fully inert (no input, no lit states, faint
    // icon) but stays mounted so the NavBar width never jumps. Default true.
    in property <bool> enabled: true;

    // ── Shape: a circular capsule with a stable, reserved 1px ring ────────────
    width: Theme.nav-capsule;
    height: Theme.nav-capsule;
    border-radius: Theme.radius-pill;

    // Default: transparent fill + transparent 1px border, so the hover ring appears
    // without shifting the icon or the capsule's footprint.
    background: transparent;
    border-width: 1px;
    border-color: transparent;

    // Fade fill/ring on state change. Glow blur is left OUT of the animate block:
    // animating drop-shadow is version-fragile, so the glow is a discrete change.
    animate background, border-color { duration: Theme.motion-fast; }

    // States — pressed listed before lit: Slint applies the first matching state.
    // `lit` fires on hover OR persistent `active` (identical ring+glow, one body).
    // Only ROOT props here: Slint 1.x can't set child props from states[] (no
    // parent/sibling access), so the icon colorize is a binding below. Every `when`
    // folds in `&& root.enabled` so no state lights up while disabled.
    states [
        pressed when touch.pressed && root.enabled : {
            root.background: Theme.accent-glow.darker(0.10);
            root.border-color: Theme.accent;
        }
        lit when (touch.has-hover || root.active) && root.enabled : {
            root.background: Theme.accent-glow;
            root.border-color: Theme.accent;
            root.drop-shadow-color: Theme.accent-glow;
            root.drop-shadow-blur: 12px;
        }
    ]

    // ── Icon ──────────────────────────────────────────────────────────────────
    Image {
        source: root.icon;
        width: Theme.nav-icon;
        height: Theme.nav-icon;
        x: Theme.snap((parent.width - self.width) / 2);
        y: Theme.snap((parent.height - self.height) / 2);
        image-fit: contain;
        // Brighten on hover/press/active, faint when disabled, else mid tone. A
        // binding (not states[]) because the icon is a child element.
        colorize: !root.enabled ? Theme.text-faint
                : (touch.has-hover || touch.pressed || root.active) ? Theme.text-high
                : Theme.text-mid;
    }

    // ── Accessibility ─────────────────────────────────────────────────────────
    // Icon-only: the label is exposed to assistive tech, not drawn on screen.
    accessible-role: button;
    accessible-label: root.a11y-label;
    // Screen-reader activation fires the same callback as a click; guarded on
    // enabled so AT cannot invoke a disabled action.
    accessible-action-default => { if (root.enabled) { root.clicked(); } }

    // TouchArea is non-focusable in Slint — it does NOT steal keyboard focus from
    // the carousel FocusScope (docs/patterns.md "TouchArea click focus recovery").
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}
