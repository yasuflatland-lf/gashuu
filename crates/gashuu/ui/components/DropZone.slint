import { Theme } from "../Theme.slint";
import { Strings } from "../Strings.slint";

// Full-window drop-zone affordance during an OS drag over Library (ViewerWindow's
// `drag-active`). Purely visual: NO TouchArea (OS drag continues), NO opacity (HiDPI blur).
export component DropZone inherits Rectangle {
    // Recede the library to ~30% visible so the frame reads as foreground (the
    // translucency is the drop-scrim alpha, not an opacity layer).
    background: Theme.drop-scrim;

    // Solid frame, inset from every window edge. A Rectangle border is a solid
    // line, so the frame is a single transparent-filled Rectangle (no dash tiling).
    Rectangle {
        x: Theme.drop-frame-inset;
        y: Theme.drop-frame-inset;
        width: root.width - 2 * Theme.drop-frame-inset;
        height: root.height - 2 * Theme.drop-frame-inset;
        background: transparent;
        border-color: Theme.drop-frame-line;
        border-width: Theme.drop-frame-width;
        border-radius: Theme.radius-lg;
    }

    // Centered message: icon + hint on one line. Outer VerticalLayout centers the row
    // vertically; inner HorizontalLayout centers it horizontally; `no-wrap` keeps one line.
    VerticalLayout {
        width: 100%;
        height: 100%;
        alignment: center;

        HorizontalLayout {
            alignment: center;
            spacing: Theme.space-md;

            Image {
                source: @image-url("../assets/plus.svg");
                colorize: Theme.drop-frame-line;
                width: Theme.nav-icon * 2;
                height: Theme.nav-icon * 2;
                vertical-alignment: center;
            }

            Text {
                text: Strings.drag-drop-hint;
                color: Theme.drop-frame-line;
                font-size: Theme.font-title;
                font-weight: Theme.weight-bold;
                vertical-alignment: center;
                wrap: no-wrap;
                accessible-role: text;
                accessible-label: Strings.drag-drop-hint;
            }
        }
    }
}
