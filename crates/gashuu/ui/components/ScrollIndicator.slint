// ScrollIndicator — self-drawn scroll thumb shared by two dialogs (issue 367). PLACEMENT
// is the caller's job (x/y/height); auto-hides via `visible:`, not opacity (HiDPI blur).

import { Theme } from "../Theme.slint";

export component ScrollIndicator inherits Rectangle {
    // ── Public API ────────────────────────────────────────────────────────────
    // Total content height of the scrolled body (= Flickable.viewport-height).
    in property <length> content-height;
    // Current scroll offset of the body (= Flickable.viewport-y; <= 0 when
    // scrolled down, briefly > 0 during elastic overscroll).
    in property <length> viewport-y;

    // ── Rail appearance ───────────────────────────────────────────────────────
    // Width/fill/radius are fixed; the caller owns x/y/height placement.
    width: Theme.settings-scroll-indicator-w;
    background: Theme.track-prog;
    border-radius: Theme.settings-scroll-indicator-w / 2;
    // Only when the body content overflows its visible (rail) height.
    visible: root.content-height > root.height;
    // Clip the thumb so elastic overscroll (viewport-y briefly positive) cannot
    // render the thumb above the rail bounds.
    clip: true;

    // ── Thumb: proportional size and offset from the scroll position ──────────
    Rectangle {
        x: 0;
        width: parent.width;
        height: parent.height * (parent.height / max(root.content-height, 1px));
        y: -root.viewport-y * (parent.height / max(root.content-height, 1px));
        background: Theme.accent;
        border-radius: Theme.settings-scroll-indicator-w / 2;
    }
}
