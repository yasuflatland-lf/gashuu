// One thumbnail treatment shared by three surfaces (page strip, scrubber preview,
// library covers) so they can't drift apart; three mutually-exclusive states below.
import { Theme } from "../Theme.slint";

export component ThumbnailCell inherits Rectangle {
    // ── Public API (kept minimal so the three call sites stay declarative) ──────
    in property <image> source;
    in property <bool> loaded;
    in property <bool> failed;
    // Accent highlight border for the "current page" cell (page strip). Library
    // covers leave this false and lean on their own focus ring instead.
    in property <bool> highlighted;
    // Corner rounding: pages / thumbnail cells use Theme.radius-xs (3px,
    // DESIGN.md "Shapes"); library covers pass Theme.radius-sm (6px).
    in property <length> radius: Theme.radius-xs;
    // A short label drawn UNDER the error icon (State 3 only). Defaults to "" so small
    // surfaces stay icon-only; only the carousel cover passes a value to caption failure.
    in property <string> failed-label;

    // Border widths (verbatim from ThumbnailStrip): the accent highlight ring is
    // wider so the current page reads clearly; a resting cell keeps a 1px hairline.
    private property <length> border-highlight: 3px;
    private property <length> border-neutral: 1px;
    // The active border width, used both for the visible border and to inset the
    // inner content so the image/placeholder never overlaps the ring.
    private property <length> border-w: root.highlighted ? root.border-highlight : root.border-neutral;
    // Inner content box, inset by the border on all sides. Shared by all three
    // state children below so the image/placeholder never overlaps the ring.
    private property <length> inner-w: root.width - 2 * root.border-w;
    private property <length> inner-h: root.height - 2 * root.border-w;

    // ── Cell shell ──────────────────────────────────────────────────────────────
    background: Theme.surface-raised;
    border-radius: root.radius;
    border-width: root.border-w;
    border-color: root.highlighted ? Theme.accent : Theme.hairline;

    // ── State 1: loaded → real thumbnail, inset by the border ──────────────────
    if root.loaded : Image {
        x: root.border-w;
        y: root.border-w;
        width: root.inner-w;
        height: root.inner-h;
        source: root.source;
        image-fit: contain;
    }

    // State 2: !loaded && !failed → neutral "loading" placeholder. The continuous
    // spin reads as "processing", keeping it distinct from the static failed state.
    if !root.loaded && !root.failed : Rectangle {
        x: root.border-w;
        y: root.border-w;
        width: root.inner-w;
        height: root.inner-h;
        background: Theme.placeholder;
        border-radius: root.radius;

        Image {
            source: @image-url("../assets/loading.svg");
            colorize: Theme.text-faint;
            width: Math.min(root.inner-w, root.inner-h) * 40%;
            height: self.width;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            // Continuous slow spin = "processing". Uses the non-deprecated
            // transform-rotation (Slint 1.16.1), which pivots about its own centre.
            transform-rotation: 360deg * (animation-tick() / 2s);
        }
    }

    // State 3: !loaded && failed → red-tinted "decode failed" placeholder. A no-image
    // SVG (not a "✕" text glyph) avoids tofu fallback; `failed-label` captions the cover.
    if !root.loaded && root.failed : Rectangle {
        x: root.border-w;
        y: root.border-w;
        width: root.inner-w;
        height: root.inner-h;
        background: Theme.error-surface;
        border-color: Theme.error;
        border-width: 1px;
        border-radius: root.radius;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            alignment: center;
            spacing: Theme.space-xs;
            padding: Theme.space-sm;

            Image {
                source: @image-url("../assets/no-image.svg");
                colorize: Theme.error;
                // 23.6% ≈ 1/φ³ on the repo's golden-ratio ladder — a quieter
                // "no image" mark, one φ step below the 40% loading spinner.
                width: Math.min(root.inner-w, root.inner-h) * 23.6%;
                height: self.width;
                horizontal-alignment: center;
            }

            if root.failed-label != "" : Text {
                text: root.failed-label;
                color: Theme.error;
                font-size: Theme.font-label;
                horizontal-alignment: center;
                wrap: word-wrap;
                overflow: elide;
            }
        }
    }
}
