// One thumbnail treatment shared by the three thumbnail surfaces — the page
// strip, the scrubber preview popover, and the library covers (DESIGN.md
// "Iteration / Agent Prompt Guide" rule 6: shared rounding / shadow /
// loading / failed treatment across all three). Centralizing the cell here
// keeps every call site declarative and guarantees the surfaces can't drift
// apart visually.
//
// Three mutually-exclusive states are modeled as explicit booleans (Figma
// variant parity), exactly as ThumbnailStrip drives them today:
//   loaded              → the real thumbnail Image (contain-fit, inset by border)
//   !loaded && !failed  → neutral "still loading" placeholder (Theme.placeholder)
//                         with a slowly spinning loading icon (motion = "processing",
//                         distinguishing it from the static error state)
//   !loaded && failed   → "decode failed" placeholder (Theme.error-surface +
//                         Theme.error border) with a centered "no image" icon
//                         (and an optional label under it) — the tint MUST stay
//                         distinct from a loading cell so a permanent failure is
//                         visually separable (the "view must match status" rule).
//
// Colors come from Theme.* only — NO inline brand hex (DESIGN.md rule 2;
// scripts/check-tokens.sh enforces this). Theme lives one directory up.
import { Theme } from "../Theme.slint";

export component ThumbnailCell inherits Rectangle {
    // ── Public API (kept minimal so the three call sites stay declarative) ──────
    in property <image> source;
    in property <bool> loaded;
    in property <bool> failed;
    // Accent highlight border for the "current page" cell (page strip). Library
    // covers leave this false and lean on their own focus ring instead.
    in property <bool> highlighted;
    // Corner rounding: pages / thumbnail cells use Theme.radius-xs (3px,
    // DESIGN.md "Shapes"); library covers pass Theme.radius-sm (6px).
    in property <length> radius: Theme.radius-xs;
    // A short label drawn UNDER the error icon (State 3 only). Defaults to "" so
    // the small surfaces (page strip / scrubber preview) stay icon-only; only the
    // centered carousel cover passes a non-empty value to caption the failure.
    in property <string> failed-label;

    // ── Border widths (adopted verbatim from ThumbnailStrip's two widths) ──────
    // Highlighted cell vs neutral cell — the accent ring is wider so the current
    // page reads clearly while a resting cell keeps a quiet 1px hairline.
    private property <length> border-highlight: 3px;
    private property <length> border-neutral: 1px;
    // The active border width, used both for the visible border and to inset the
    // inner content so the image/placeholder never overlaps the ring.
    private property <length> border-w: root.highlighted ? root.border-highlight : root.border-neutral;
    // Inner content box, inset by the border on all sides. Shared by all three
    // state children below so the image/placeholder never overlaps the ring.
    private property <length> inner-w: root.width - 2 * root.border-w;
    private property <length> inner-h: root.height - 2 * root.border-w;

    // ── Cell shell ──────────────────────────────────────────────────────────────
    background: Theme.surface-raised;
    border-radius: root.radius;
    border-width: root.border-w;
    border-color: root.highlighted ? Theme.accent : Theme.hairline;

    // ── State 1: loaded → real thumbnail, inset by the border ──────────────────
    if root.loaded : Image {
        x: root.border-w;
        y: root.border-w;
        width: root.inner-w;
        height: root.inner-h;
        source: root.source;
        image-fit: contain;
    }

    // ── State 2: !loaded && !failed → neutral "loading" placeholder ────────────
    // Placeholder fill plus a centered, slowly spinning loading icon. The motion
    // (a continuous spin) reads as "processing" and keeps this state visually
    // distinct from the static failed state below.
    if !root.loaded && !root.failed : Rectangle {
        x: root.border-w;
        y: root.border-w;
        width: root.inner-w;
        height: root.inner-h;
        background: Theme.placeholder;
        border-radius: root.radius;

        Image {
            source: @image-url("../assets/loading.svg");
            colorize: Theme.text-faint;
            width: Math.min(root.inner-w, root.inner-h) * 40%;
            height: self.width;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            // Continuous slow spin = "processing" (motion distinguishes the
            // loading state from the static error state). Uses the
            // non-deprecated transform-rotation (Slint 1.16.1), which pivots
            // about the element's own centre by default.
            transform-rotation: 360deg * (animation-tick() / 2s);
        }
    }

    // ── State 3: !loaded && failed → red-tinted "decode failed" placeholder ────
    // Surface + 1px border + a centered "no image" icon, all in the failed hue
    // (matches how ThumbnailStrip tints this state). A no-image SVG replaces
    // the old "✕" Text glyph so the mark renders identically on every font (no
    // tofu fallback). When `failed-label` is non-empty (centered carousel cover
    // only) it is captioned under the icon; the small surfaces stay icon-only.
    if !root.loaded && root.failed : Rectangle {
        x: root.border-w;
        y: root.border-w;
        width: root.inner-w;
        height: root.inner-h;
        background: Theme.error-surface;
        border-color: Theme.error;
        border-width: 1px;
        border-radius: root.radius;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            alignment: center;
            spacing: Theme.space-xs;
            padding: Theme.space-sm;

            Image {
                source: @image-url("../assets/no-image.svg");
                colorize: Theme.error;
                width: Math.min(root.inner-w, root.inner-h) * 40%;
                height: self.width;
                horizontal-alignment: center;
            }

            if root.failed-label != "" : Text {
                text: root.failed-label;
                color: Theme.error;
                font-size: Theme.font-label;
                horizontal-alignment: center;
                wrap: word-wrap;
                overflow: elide;
            }
        }
    }
}
