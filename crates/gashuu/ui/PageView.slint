// Two-page spread display with RTL/LTR placement and single-page mode. Rust drives
// content-x/y/w/h to position the content rect; input callbacks relay gestures to viewer.rs.
import { Theme } from "Theme.slint";

// Loading placeholder that fills its assigned slot while a page is decoded. slot-x/width/height
// express the RTL-aware geometry at the call site, so the component stays policy-free.
component LoadingSlot inherits Rectangle {
    in property <length> slot-x;
    in property <length> slot-width;
    in property <length> slot-height;

    x: slot-x;
    y: 0px;
    width: slot-width;
    height: slot-height;
    background: Theme.placeholder;

    Image {
        source: @image-url("assets/loading.svg");
        colorize: Theme.text-faint;
        width: Math.min(parent.width, parent.height) * 21%;
        height: self.width;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        transform-rotation: 360deg * (animation-tick() / 2s);
    }
}

export component PageView inherits Rectangle {
    in property <image> leading-page;
    in property <image> trailing-page;
    in property <bool> rtl;
    in property <bool> single;
    in property <bool> leading-loading: false;
    in property <bool> trailing-loading: false;
    // Rust-computed displayed-content rectangle (placed inside the clip).
    // Defaults to 0px so the build passes before Rust sets them.
    in property <length> content-x: 0px;
    in property <length> content-y: 0px;
    in property <length> content-w: 0px;
    in property <length> content-h: 0px;
    // When a modal overlay is open, suppress pinch/scroll here: they bypass the FocusScope
    // keyboard guard, so PageView must gate them itself (docs/patterns.md scroll-event modal rule).
    in property <bool> modal-open: false;

    // Input callbacks relayed to ViewerWindow / handlers/viewer.rs.
    callback begin-pan();
    callback pan-to(length, length);             // cumulative delta from the press point
    // Native trackpad pinch (ScaleRotateGestureHandler): begin-pinch snapshots the base zoom;
    // pinch-to applies the cumulative scale at the focal point (anchor in TouchArea mouse-x/y space).
    callback begin-pinch();
    callback pinch-to(length, length, float);    // anchor-x, anchor-y, cumulative scale
    // Incremental two-finger scroll pan while zoomed in (dx, dy).
    callback scroll-pan(length, length);
    callback viewport-resized(length, length);   // width, height
    // Fired on ANY pointer movement (pressed or not) to reveal auto-hiding chrome. `changed
    // mouse-x/y` fires on unpressed hover where `moved` (pressed-only) wouldn't, and steals no press.
    callback reveal();
    // Fired on a clean tap (press-release within `tap-slop`), with the release mouse-x; ViewerWindow
    // maps it to page-turn halves. Slop guard REQUIRED: TouchArea fires `clicked` on ANY release (1.16.1).
    callback tapped(length);
    // Max press-to-release travel still counted as a tap (not a pan).
    property <length> tap-slop: 4px;

    // Two-finger horizontal swipe → page turn (discrete), only while the page fits horizontally
    // (content-w <= width; else pan). A fixed post-turn cooldown double-fires — macOS momentum outlasts it.
    callback page-swipe(string);   // "left" / "right" — physical swipe direction
    property <length> swipe-threshold: 100px;     // higher = heavier / less sensitive; page turns stay deliberate
    property <length> swipe-release-delta: 6px;   // lull travel that unlatches; small so a single flick's whole tail is swallowed (no double-fire)
    property <length> swipe-spike-jump: 25px;     // a re-flick that spikes |dx| back up by at least this above the decaying momentum unlatches; higher = duller consecutive swipes (needs a more deliberate re-flick)
    property <duration> swipe-idle-gap: 90ms;     // fallback: unlatch this long after events stop (finger lifted, no momentum)
    property <duration> swipe-decay-gap: 140ms;   // quiet time before a partial (sub-threshold) swipe's glow fades
    property <float> swipe-accum: 0;              // signed px accumulated toward the next turn (also drives the glow)
    property <float> swipe-prev-dx: 0;            // |delta-x| of the previous event, for spike (re-flick) detection
    property <bool> swipe-latched: false;         // owns input after a turn until a lull or a re-flick spike
    // 0..1 progress toward the next turn; drives the edge-glow opacity.
    property <float> swipe-progress: Math.clamp(Math.abs(root.swipe-accum) / (root.swipe-threshold / 1px), 0, 1);
    // Glow opacity = progress * gain (clamped), so it reaches full at 1/gain of the
    // threshold and becomes visible EARLY in the swipe. Higher = shows sooner.
    property <float> swipe-glow-gain: 2.0;

    background: Theme.canvas;
    clip: true;

    init => { root.viewport-resized(self.width, self.height); }
    changed width => { root.viewport-resized(self.width, self.height); }
    changed height => { root.viewport-resized(self.width, self.height); }

    if root.single : Image {
        x: root.content-x;
        y: root.content-y;
        width: root.content-w;
        height: root.content-h;
        source: root.leading-page;
        image-fit: contain;
    }

    if !root.single : HorizontalLayout {
        x: root.content-x;
        y: root.content-y;
        width: root.content-w;
        height: root.content-h;
        spacing: 0px;
        Image {
            source: root.rtl ? root.trailing-page : root.leading-page;
            image-fit: contain;
            horizontal-stretch: 1;
        }
        Image {
            source: root.rtl ? root.leading-page : root.trailing-page;
            image-fit: contain;
            horizontal-stretch: 1;
        }
    }

    if root.single && root.leading-loading : LoadingSlot {
        slot-x: 0px;
        slot-width: root.width;
        slot-height: root.height;
    }

    if !root.single && root.leading-loading : LoadingSlot {
        slot-x: root.rtl ? root.width / 2 : 0px;
        slot-width: root.width / 2;
        slot-height: root.height;
    }

    if !root.single && root.trailing-loading : LoadingSlot {
        slot-x: root.rtl ? 0px : root.width / 2;
        slot-width: root.width / 2;
        slot-height: root.height;
    }

    // Swipe-to-turn edge affordance: two pointer-transparent bands glowing on the side the
    // fingers push toward. `animate opacity` gives the live ramp AND the ease-out turn-confirm flash.
    Rectangle {
        x: 0;
        width: Theme.viewer-swipe-glow-width;
        height: 100%;
        background: @linear-gradient(90deg, Theme.viewer-swipe-glow 0%, transparent 100%);
        opacity: root.swipe-accum < 0 ? Math.min(root.swipe-progress * root.swipe-glow-gain, 1) : 0;
        animate opacity { duration: Theme.motion-fast; easing: ease-out; }
    }
    Rectangle {
        x: root.width - self.width;
        width: Theme.viewer-swipe-glow-width;
        height: 100%;
        background: @linear-gradient(90deg, transparent 0%, Theme.viewer-swipe-glow 100%);
        opacity: root.swipe-accum > 0 ? Math.min(root.swipe-progress * root.swipe-glow-gain, 1) : 0;
        animate opacity { duration: Theme.motion-fast; easing: ease-out; }
    }

    // TouchArea is non-focusable, so it won't steal focus from ViewerWindow's FocusScope.
    // Latch-release fallback (re-armable): if events stop with no lull, unlatch after swipe-idle-gap.
    release-timer := Timer {
        interval: root.swipe-idle-gap;
        running: root.swipe-latched;
        triggered => { root.swipe-latched = false; }
    }
    // Partial-swipe decay (re-armable): each scroll event restarts this; when the gesture
    // pauses it zeroes `swipe-accum` so the edge glow fades instead of hanging.
    decay-timer := Timer {
        interval: root.swipe-decay-gap;
        running: root.swipe-accum != 0 && !root.swipe-latched;
        triggered => { root.swipe-accum = 0; }
    }

    // Native pinch (trackpad + touchscreens): `scale` is cumulative (1.0 at start), `center` is
    // the focal point in this element's space. Rotation is intentionally ignored (manga page).
    ScaleRotateGestureHandler {
        enabled: !root.modal-open;
        started => { root.begin-pinch(); }
        updated => { root.pinch-to(self.center.x, self.center.y, self.scale); }
    }

    TouchArea {
        scroll-event(e) => {
            // Scroll bypasses the FocusScope keyboard guard, so guard it here
            // FIRST (docs/patterns.md scroll-event modal rule).
            if (root.modal-open) {
                return reject;
            }
            // A horizontal-dominant swipe (1.2x margin) turns ONE page while content fits
            // HORIZONTALLY (content-w <= width) — NOT "neither axis overflows", so Width fit still turns.
            if (Math.abs(e.delta-x / 1px) > Math.abs(e.delta-y / 1px) * 1.2
                && root.content-w <= root.width + 2px) {
                // After a turn the gesture is LATCHED; unlatch only on a NEW swipe — a lull
                // (|dx| < release-delta) or a velocity SPIKE (re-flick). Swallows a flick's tail (no double-fire).
                if (root.swipe-latched) {
                    if (Math.abs(e.delta-x / 1px) < root.swipe-release-delta / 1px
                        || Math.abs(e.delta-x / 1px) > root.swipe-prev-dx + root.swipe-spike-jump / 1px) {
                        root.swipe-latched = false;
                    } else {
                        root.swipe-prev-dx = Math.abs(e.delta-x / 1px);
                        release-timer.restart();
                        return accept;
                    }
                }
                root.swipe-prev-dx = Math.abs(e.delta-x / 1px);
                if (e.delta-x / 1px * root.swipe-accum < 0) {
                    root.swipe-accum = 0;
                }
                root.swipe-accum += e.delta-x / 1px;
                if (Math.abs(root.swipe-accum) >= root.swipe-threshold / 1px) {
                    root.page-swipe(root.swipe-accum > 0 ? "right" : "left");
                    root.swipe-accum = 0;
                    root.swipe-latched = true;
                } else {
                    // Sub-threshold: keep the glow alive but arm its idle fade.
                    decay-timer.restart();
                }
                return accept;
            }
            // Otherwise two-finger scroll pans whatever overflows. core clamp_offset ignores deltas
            // on an axis that already fits, so passing both deltas never nudges a fitting axis.
            if (root.content-w > root.width + 2px || root.content-h > root.height + 2px) {
                root.scroll-pan(e.delta-x, e.delta-y);
                return accept;
            }
            return accept;
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                root.begin-pan();
            }
        }
        moved => {
            if (self.pressed) {
                root.pan-to(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
            }
        }
        // Tap-vs-pan split: `pressed-x/y` hold the press point through release (vendored input_items.rs
        // sets them on Pressed, never clears), so comparing to release mouse-x/y separates a tap from a pan.
        clicked => {
            if (Math.abs(self.mouse-x / 1px - self.pressed-x / 1px) <= root.tap-slop / 1px
                && Math.abs(self.mouse-y / 1px - self.pressed-y / 1px) <= root.tap-slop / 1px) {
                root.tapped(self.mouse-x);
            }
        }
        changed mouse-x => { root.reveal(); }
        changed mouse-y => { root.reveal(); }
    }
}
