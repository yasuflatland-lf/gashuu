// Single page display: the image is scaled to fit (contain), with black bars
// filling the unused space (letterbox for wide pages, pillarbox for tall ones).
export component PageView inherits Rectangle {
    in property <image> source;
    background: #000000;
    Image {
        source: root.source;
        image-fit: contain;
        width: 100%;
        height: 100%;
    }
}
