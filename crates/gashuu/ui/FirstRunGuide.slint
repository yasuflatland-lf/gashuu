// First-run guide overlay shown once when the user launches gashuu for the
// first time.  A semi-transparent backdrop dims the viewer behind a centered
// panel that explains the key bindings and toolbar actions.
//
// The panel is dismissed by clicking "Got it", which fires `dismiss-guide` so
// Rust can persist the "guide shown" flag and hide the component.
import { Button, VerticalBox } from "std-widgets.slint";
import { Theme } from "Theme.slint";
import { Strings } from "Strings.slint";

// One line of the controls reference. Factors out the styling shared by every
// reference row so each call site only supplies its text.
component GuideLine inherits Text {
    color: Theme.text-muted;
    font-size: Theme.font-body;
    horizontal-alignment: left;
    wrap: word-wrap;
}

export component FirstRunGuide inherits Rectangle {
    // ── Callback ───────────────────────────────────────────────────────────────
    // Fired when the user clicks "Got it".  Rust should hide this component and
    // persist the "first-run guide shown" flag so it is not shown again.
    callback dismiss-guide();

    // ── Backdrop ───────────────────────────────────────────────────────────────
    // Fills the entire parent area with a semi-transparent black overlay so the
    // viewer behind is visible but clearly dimmed.
    background: Theme.scrim-strong;

    // ── Centered panel ─────────────────────────────────────────────────────────
    Rectangle {
        // Center the panel inside the backdrop.
        x: Theme.snap((root.width  - self.width)  / 2);
        y: Theme.snap((root.height - self.height) / 2);
        // Fluid width: caps at 520 px on wide windows; shrinks to leave a
        // Theme.space-xl gutter on each side on narrow windows.
        width: min(520px, root.width - 2 * Theme.space-xl);
        // Height grows with content; VerticalBox drives it.

        background: Theme.surface-float;
        border-radius: Theme.radius-md;

        VerticalBox {
            padding: 28px;
            spacing: 14px;

            // ── Title ──────────────────────────────────────────────────────────
            Text {
                text: Strings.guide-welcome;
                font-size: Theme.font-title;
                color: Theme.text;
                horizontal-alignment: center;
            }

            // ── Intro ──────────────────────────────────────────────────────────
            Text {
                text: Strings.guide-intro;
                color: Theme.text-mid;
                font-size: Theme.font-body;
                horizontal-alignment: left;
                wrap: word-wrap;
            }

            // ── Controls reference ─────────────────────────────────────────────
            GuideLine {
                text: Strings.guide-open;
            }

            GuideLine {
                text: Strings.guide-turn-pages;
            }

            GuideLine {
                text: Strings.guide-modes;
            }

            GuideLine {
                text: Strings.guide-zoom-fit;
            }

            GuideLine {
                text: Strings.guide-thumbnails;
            }

            GuideLine {
                text: Strings.guide-settings;
            }

            // ── Dismiss button ─────────────────────────────────────────────────
            Button {
                text: Strings.guide-got-it;
                clicked => { root.dismiss-guide(); }
            }
        }
    }
}
