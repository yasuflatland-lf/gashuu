import { VerticalBox } from "std-widgets.slint";
import { PageView } from "PageView.slint";
import { ThumbnailStrip, ThumbnailItem } from "ThumbnailStrip.slint";
import { SettingsDialog } from "SettingsDialog.slint";
import { ShortcutsOverlay } from "ShortcutsOverlay.slint";
import { Carousel, CarouselItem } from "Carousel.slint";
import { Theme } from "Theme.slint";
import { Scrubber } from "Scrubber.slint";
import { ViewerPill } from "components/ViewerPill.slint";
import { Strings } from "Strings.slint";
import { ConfirmDialog } from "components/ConfirmDialog.slint";
import { UpdateAvailableDialog } from "components/UpdateAvailableDialog.slint";
import { DropZone } from "components/DropZone.slint";

// Re-export so Rust gets the `ui.global::<Strings>()` accessor — Slint only
// generates global accessors for globals exported from the build entry point.
export { Strings }

export component ViewerWindow inherits Window {
    // Intentionally empty: the OS title bar shows no app name (the floating title label above the ViewerPill carries the current book name instead). See issue #85.
    title: "";
    icon: @image-url("assets/app-icon.png");
    preferred-width: 900px;
    preferred-height: 1200px;
    // Floor keeps a two-page spread legible: below ~480px each half collapses to a
    // sliver. Tune the FLOOR only; the preferred-* boot size above is unchanged.
    min-width: 480px;
    min-height: 600px;

    // Top-level screen: 0 = Library (Carousel), 1 = Viewer. Pushed by main.rs
    // from NavState; app boots to Library (0).
    in property <int> screen: 0;
    // True while an OS file/folder drag hovers the window (set by handlers/drag_drop.rs).
    // Gates the drop-zone overlay below; only meaningful on the Library screen.
    in property <bool> drag-active: false;
    // Carousel model + focus index (filled by PR-C; empty shell for now).
    in property <[CarouselItem]> carousel-items;
    in-out property <int> carousel-focused-index;

    // ── Library search seams (issue 88), re-exposed for Rust ──────────────────
    // `library-book-count` is filter-INDEPENDENT so the carousel tells the
    // empty-library CTA from the no-results state.
    in-out property <string> library-search-query;
    in property <int> library-book-count;
    callback library-search-changed(string);
    public function focus-library-search() { carousel.focus-search(); }

    in property <[ThumbnailItem]> thumbnails;
    in property <int> current-index;
    in property <bool> show-thumbnails: false;

    // ── Scrubber + auto-hide chrome (PR-S) ────────────────────────────────────
    // Auto-hide state shared by the scrubber, ViewerPill, and title label; revealed
    // on mouse-move / arrow / drag, cleared by the idle Timer.
    in-out property <bool> chrome-shown: false;
    // Guards the phantom-reveal flip-flop after an idle-hide: when the chrome hides
    // under a STATIONARY cursor, the vacated pill lets PageView re-acquire it and emit
    // a phantom `changed mouse-x` that would re-reveal every idle interval.
    property <bool> suppress-pointer-reveal: false;
    // True while the pointer rests on the pill/title: pauses the idle timer so the
    // chrome doesn't auto-hide under the cursor (like `field-focused` while typing).
    property <bool> chrome-hovered: viewer-pill.hovered || title-touch.has-hover;
    // Scrubber data (1-based current page + total; direction + layout; preview thumbs).
    in property <int> scrubber-current-page;
    in property <int> scrubber-total-pages;
    in property <bool> scrubber-double;
    in property <image> scrubber-preview-a;
    in property <image> scrubber-preview-b;
    in property <bool> scrubber-preview-a-loaded: false;
    in property <bool> scrubber-preview-a-failed: false;
    in property <bool> scrubber-preview-b-loaded: false;
    in property <bool> scrubber-preview-b-failed: false;

    // Viewer pill: page-jump text (1-based string, kept in sync by Rust)
    in-out property <string> page-jump-text: "1";
    // Viewer pill callbacks — handled by Rust
    callback page-jump-request(string);
    callback page-jump-cancel();

    // Fired with the 0-based page under the knob during a drag (preview only —
    // the page body must NOT change) and with the page to commit on release.
    callback scrub-preview(float);
    callback scrub-commit(float);
    // Fired when the user shows intent (mouse-move / scrubber drag); Rust delegates
    // back to reveal-chrome-now(). Arrow/page-turn keys call it directly instead.
    callback reveal-chrome();
    callback spread-anchored(float, float, bool, int, int, int);
    callback page-decode-error(int);

    in property <image> leading-page;
    in property <image> trailing-page;
    in property <bool> rtl;
    in property <bool> single;
    in property <bool> leading-loading: false;
    in property <bool> trailing-loading: false;
    in property <string> status-text: "No folder opened";
    // Idle value of the bottom strip — total library size, composed/pushed from Rust.
    in property <string> library-count-text;
    // Add notice — skips/failures only. Rust sets this (and clears `status-text`);
    // the toast auto-dismisses. In-out so the auto-dismiss Timer can clear it to "".
    in-out property <string> add-toast-text;
    // Bulk-add loading affordance (the on_add_progress / on_add_finalize handlers
    // drive these): `add-active` is true while a batch is probing (shows the bottom
    // bar); `add-progress-ratio` is the completed fraction 0.0..1.0 driving the fill
    // width. Named `add-progress-ratio` (not `add-progress`) because a
    // `callback add-progress(int, int)` already exists on this component.
    in property <bool> add-active: false;
    in property <float> add-progress-ratio: 0.0;
    // Book display name (set by handlers/library.rs on open, "" otherwise). Declared on
    // the root because Rust binds only to the root surface; consumed by the title label.
    in property <string> current-book-name;
    // Rust-computed content rectangle forwarded to PageView.
    in property <length> content-x: 0px;
    in property <length> content-y: 0px;
    in property <length> content-w: 0px;
    in property <length> content-h: 0px;

    // Settings dialog / overlay visibility and state.
    in property <bool> show-settings: false;
    in property <bool> show-shortcuts: false;
    // Private epoch: Rust bumps this (via focus-settings()) so SettingsDialog re-focuses.
    // The if-gated dialog has no id here, so it observes the epoch via a `changed` handler.
    property <int> settings-focus-epoch: 0;
    in-out property <int> reading-direction-index;
    in-out property <int> spread-mode-index;
    in-out property <int> cover-mode-index;
    in-out property <int> fit-mode-index;
    in-out property <int> cache-size;
    in-out property <int> preload-pages;
    in-out property <bool> track-recent;
    in-out property <bool> allow-rar-archives;
    // Pre-composed feedback string for the clear-history / clear-cache actions.
    // Empty = not shown. Rust pushes a transient string; the caller clears it.
    in property <string> data-action-status;
    // Index into the language dropdown model (En=0, Ja=1).
    in-out property <int> language-index;
    in property <string> key-bindings-text;
    // True when the settings dialog edits the current book's per-book override
    // (opened from the Viewer) rather than the global defaults (Library screen).
    in property <bool> settings-per-book: false;

    changed width  => { root.resized(self.width, self.height); }
    changed height => { root.resized(self.width, self.height); }

    callback thumbnail-clicked(int);
    // Forwarded from the thumbnail strip so Rust lazily decodes only near-viewport
    // pages. Args: first on-screen content pixel, viewport width, per-cell stride.
    callback thumbnail-strip-visible-range-changed(length, length, length);
    callback toggle-thumbnails();

    public function focus-pages() { fs.focus(); }
    // Rust calls this after closing the shortcuts overlay to refocus SettingsDialog.
    // The if-gated dialog has no id, so it bumps an epoch the dialog observes.
    public function focus-settings() { root.settings-focus-epoch += 1; }

    // Re-arm the idle-fade: show the chrome, then stop+restart the timer so a full
    // interval elapses from THIS reveal. Called from Rust on every reveal.
    public function reveal-chrome-now() {
        root.chrome-shown = true;
        idle-timer.running = true;
        idle-timer.stop();
        idle-timer.start();
    }

    // Pointer-driven reveals honor a brief suppression window after an idle-hide so
    // the chrome doesn't flip-flop under a stationary cursor (see suppress-pointer-reveal).
    // Arrow keys / scrubber drags bypass this guard via reveal-chrome-now directly.
    function reveal-chrome-from-pointer() {
        if (root.suppress-pointer-reveal) {
            return;
        }
        root.reveal-chrome-now();
    }

    // Arms the same pointer-reveal suppression window the idle-hide uses. Called from
    // Rust when the LoadingSlot mounts/unmounts under a stationary cursor: either
    // toggle perturbs PageView hit-testing and emits a phantom `changed mouse-x`.
    public function arm-pointer-reveal-suppression() {
        root.suppress-pointer-reveal = true;
        reveal-guard.start();
    }

    // Carousel navigation seams (Library screen). Forwarded to handlers/library.rs.
    callback carousel-open(int);
    callback carousel-move(int);
    callback carousel-back();
    // NavBar bookmark capsule: jump to the continue-reading book, or a no-bookmark
    // notice. Root twin because Slint exposes only the root surface to Rust.
    callback carousel-continue-reading();
    // Bulk-selection seams (PR-2). Root twins of the Carousel's seams; toggle/cover-
    // clicked forward the VISIBLE index. (Slint exposes only the root surface to Rust.)
    in-out property <bool> carousel-selection-mode;
    callback carousel-toggle-selection(int);
    callback carousel-cover-clicked(int);
    callback carousel-exit-selection();
    // SelectionToolbar root twins (PR-4). Pre-composed count + select-all label;
    // `carousel-select-all()` fires from the toolbar button AND the Cmd/Ctrl+A arm.
    in property <string> carousel-selection-count-text;
    in property <string> carousel-select-all-label;
    callback carousel-select-all();
    // Delete root twins (PR-5). Pre-composed label + has-selection gate; request-delete()
    // fires from the toolbar AND Delete/Backspace; Rust flips `show-confirm-delete`.
    in property <string> carousel-delete-label;
    in property <bool> carousel-has-selection;
    callback carousel-request-delete();
    // ── Confirm-delete modal (PR-5) ───────────────────────────────────────────
    // `show-confirm-delete` is `in-out` so `cancel` closes it WITHOUT a Rust round-trip
    // (D4: selection preserved); the four text props are pre-composed in Rust.
    in-out property <bool> show-confirm-delete: false;
    in property <string> confirm-delete-title;
    in property <[string]> confirm-delete-body-lines;
    in property <string> confirm-delete-info;
    in property <string> confirm-delete-warning;
    callback confirm-delete-accepted();
    // ── Update-available modal (Task 9) ───────────────────────────────────────
    // `show-update-available` is `in-out` so `later`/`skip` close it WITHOUT a Rust round-trip.
    // `update-notes-available`/`update-in-progress` gate optional dialog content.
    in-out property <bool> show-update-available: false;
    in property <string> update-current-version;
    in property <string> update-latest-version;
    in property <bool> update-notes-available: true;
    in property <bool> update-in-progress: false;
    in property <string> update-status-text;
    callback update-accept();
    callback update-later();
    callback update-skip();
    callback update-notes();
    // Add-picker triggers forwarded from the Carousel toolbar/CTA. Rust decides the
    // add-books dialog flavor (files+folders on macOS, files-only elsewhere).
    callback add-books();
    callback add-folder();
    // True when one native dialog picks files AND folders (macOS): the Library
    // NavBar collapses its two add capsules into one. Pushed once at boot.
    in property <bool> combined-add-picker;
    // Fired by the cover loader when a worker opens a book CLEANLY but finds ZERO pages
    // (remove + purge + rebuild + notice). Distinct from an open ERROR, which fires nothing.
    callback empty-book-detected(/* canonical path */ string);
    // Bulk-add async probe bridge (issue 206): AddController probes each source on rayon
    // workers (UI never freezes). add-finalize fires ONCE with the epoch to drop a stale add.
    callback add-progress(/* done */ int, /* total */ int);
    callback add-finalize(/* epoch */ int);
    public function focus-carousel() { carousel.focus-self(); }
    // Forwarded navigation token: "left" | "right" | "space" | "backspace" |
    // "d" | "r" | "c" | "+" | "=" | "-" | "0" | "1" | "f".
    callback nav(string);
    // Zoom/pan callbacks forwarded from PageView so handlers/viewer.rs can connect them.
    callback begin-pan();
    callback pan-to(length, length);
    callback begin-pinch();
    callback pinch-to(length, length, float);
    callback scroll-pan(length, length);
    callback viewport-resized(length, length);
    // Forwarded window size (logical pixels, Slint `length` units) so Rust can
    // resolve SpreadMode::Auto live.
    callback resized(length, length);

    // Settings dialog callbacks.
    callback open-settings();
    callback close-settings();
    callback open-shortcuts();
    callback close-shortcuts();
    // Viewer settings: reset the current book to the global defaults.
    callback reset-overrides();
    callback set-reading-direction(int);
    callback set-spread-mode(int);
    callback set-cover-mode(int);
    callback set-fit-mode(int);
    callback set-cache-size(int);
    callback set-preload-pages(int);
    callback set-track-recent(bool);
    callback set-allow-rar-archives(bool);
    callback clear-reading-history();
    callback clear-cover-cache();
    callback set-language(int);
    // ── SettingsDialog About / auto-update (Task 10) ──────────────────────────
    // Root twins forwarded to the dialog's app-version / auto-update-check /
    // check-for-updates / set-auto-update-check.
    in property <string> settings-app-version;
    in-out property <bool> settings-auto-update-check: true;
    // Transient feedback for the manual "Check for updates now" button; forwarded to
    // SettingsDialog's `update-status` (one-way in-prop, like data-action-status).
    in property <string> settings-update-status;
    callback settings-check-for-updates();
    callback settings-set-auto-update-check(bool);

    // ── Library screen ────────────────────────────────────────────────────────
    // Both screens are always instantiated and toggled with `visible` (not `if`) so
    // their FocusScope ids stay reachable from the focus functions: Slint's `if`
    // puts ids in a child scope the parent cannot name.
    carousel := Carousel {
        visible: root.screen == 0;
        width: root.width;
        height: root.height;
        items: root.carousel-items;
        focused-index <=> root.carousel-focused-index;
        search-query <=> root.library-search-query;
        library-book-count: root.library-book-count;
        combined-add-picker: root.combined-add-picker;
        // Suppress the carousel's keyboard seams while a modal overlays the
        // Library — same condition the Viewer FocusScope uses (see `fs` below).
        modal-open: root.show-settings || root.show-shortcuts || root.show-confirm-delete || root.show-update-available;
        search-changed(q) => { root.library-search-changed(q); }
        // The nav's Settings button routes straight to the shared `open-settings` flow
        // (same handler the Viewer title bar uses), not a separate placeholder callback.
        settings() => { root.open-settings(); }
        open(i) => { root.carousel-open(i); }
        move(delta) => { root.carousel-move(delta); }
        back() => { root.carousel-back(); }
        continue-reading() => { root.carousel-continue-reading(); }
        add-books() => { root.add-books(); }
        add-folder() => { root.add-folder(); }
        // Bulk-selection (PR-2): mirror the mode locally and forward the seams.
        selection-mode <=> root.carousel-selection-mode;
        toggle-selection(i) => { root.carousel-toggle-selection(i); }
        cover-clicked(i) => { root.carousel-cover-clicked(i); }
        exit-selection() => { root.carousel-exit-selection(); }
        // SelectionToolbar (PR-4): pre-composed count + select-all label down,
        // select-all action up.
        selection-count-text: root.carousel-selection-count-text;
        select-all-label: root.carousel-select-all-label;
        select-all() => { root.carousel-select-all(); }
        // Delete (PR-5): pre-composed label + has-selection gate down, the
        // request-delete action up (Rust opens the ConfirmDialog).
        delete-label: root.carousel-delete-label;
        has-selection: root.carousel-has-selection;
        request-delete() => { root.carousel-request-delete(); }
    }

    // ── Library-screen status notice ─────────────────────────────────────────
    // Add/save feedback. Shares `status-text` with the Viewer; mutually exclusive
    // with the error toast below (one message at a time).
    Text {
        visible: root.screen == 0 && root.add-toast-text == "";
        x: 0;
        y: root.height - self.preferred-height - Theme.space-md;
        width: root.width;
        text: root.status-text == "" ? root.library-count-text : root.status-text;
        color: Theme.text-muted;
        font-size: Theme.font-micro;
        horizontal-alignment: center;
    }

    // ── Bulk-add progress hairline ────────────────────────────────────────────
    // Full-width 3px bar pinned to the very bottom edge while an add probes. The
    // accent fill grows to `add-progress` (determinate), and a shimmer band sweeps
    // continuously via animation-tick() so a stalled count still reads as alive.
    // Gated by `add-active` so animation-tick() is unreferenced (zero repaint cost)
    // when idle — same principle as the page-decode LoadingSlot.
    if root.screen == 0 && root.add-active: Rectangle {
        x: 0;
        y: root.height - self.height;
        width: root.width;
        height: 3px;
        background: Theme.placeholder;
        clip: true;

        // Determinate fill: eases to the new width on each probe completion.
        Rectangle {
            x: 0;
            width: parent.width * root.add-progress-ratio;
            height: parent.height;
            background: Theme.accent;
            animate width { duration: Theme.motion-fast; }
        }

        // Perpetual shimmer band: a fixed-width highlight sweeping left→right once
        // every ~1.15s, so motion never stops even while the fill sits at 0.
        Rectangle {
            property <float> phase: Math.mod(animation-tick() / 1150ms, 1.0);
            width: parent.width * 40%;
            height: parent.height;
            x: -self.width + (parent.width + self.width) * phase;
            background: @linear-gradient(90deg,
                transparent 0%, Theme.progress-shimmer 50%, transparent 100%);
        }
    }

    // ── Library add-error toast ───────────────────────────────────────────────
    // Raised ONLY for add skips/failures (success + idle count stay on the strip
    // above). The bound Timer auto-dismisses it a few seconds later.
    Timer {
        interval: 6s;
        running: root.screen == 0 && root.add-toast-text != "";
        triggered => { root.add-toast-text = ""; }
    }
    if root.screen == 0 && root.add-toast-text != "": Rectangle {
        x: (root.width - self.width) / 2;
        y: root.height - self.height - Theme.space-xl;
        width: min(toast-row.preferred-width, root.width - 2 * Theme.space-xxl);
        height: toast-row.preferred-height;
        background: Theme.glass-fill;
        border-color: Theme.error;
        border-width: 1px;
        border-radius: Theme.radius-lg;
        clip: true;
        drop-shadow-color: Theme.shadow-popover;
        drop-shadow-blur: Theme.space-md;
        drop-shadow-offset-y: Theme.space-xxs;

        // Left severity accent bar (clipped to the rounded corners by `clip`).
        Rectangle {
            x: 0;
            width: 3px;
            height: parent.height;
            background: Theme.error;
        }

        toast-row := HorizontalLayout {
            padding-left: Theme.space-md;
            padding-right: Theme.space-md;
            padding-top: Theme.space-sm;
            padding-bottom: Theme.space-sm;
            spacing: Theme.space-sm;

            Image {
                source: @image-url("assets/warning.svg");
                colorize: Theme.error;
                width: Theme.font-body;
                height: Theme.font-body;
                vertical-alignment: center;
            }
            Text {
                text: root.add-toast-text;
                color: Theme.text-high;
                font-size: Theme.font-micro;
                vertical-alignment: center;
                horizontal-alignment: center;
                wrap: no-wrap;
                overflow: elide;
            }
        }
    }

    // ── Drag-and-drop drop zone ───────────────────────────────────────────────
    // Drop-zone affordance shown while an OS drag hovers the Library screen (gated to
    // it). Purely visual (no TouchArea) — the actual add happens in Rust on drop.
    if root.drag-active && root.screen == 0: DropZone {
        width: root.width;
        height: root.height;
    }

    // ── Viewer screen (existing content) ───────────────────────────────────────
    // `visible`-gated (not `if`) so the inner `fs` FocusScope id stays reachable
    // from `focus-pages()` and `init` (see the carousel note above).
    VerticalBox {
        visible: root.screen == 1;
        // Viewer stage: the page + auto-hiding chrome (ViewerPill + scrubber) on top.
        // PageView reveals the chrome via `reveal()`; chrome uses absolute x/y here.
        Rectangle {
            // The FocusScope + PageView are unchanged; only wrapped so the chrome
            // can be absolutely positioned over them.
            fs := FocusScope {
                key-pressed(event) => {
                    // Suppress background navigation while a modal overlay is open.
                    if (root.show-settings || root.show-shortcuts || root.show-confirm-delete || root.show-update-available) { return reject; }
                    if (event.text == Key.LeftArrow) {
                        root.nav("left");
                        return accept;
                    }
                    if (event.text == Key.RightArrow) {
                        root.nav("right");
                        return accept;
                    }
                    if (event.text == Key.UpArrow) {
                        root.nav("up");
                        return accept;
                    }
                    // Escape returns to the Library, mirroring Up. The modal guard above
                    // rejects it while an overlay is open, so Esc closes the topmost modal first.
                    if (event.text == Key.Escape) {
                        root.nav("escape");
                        return accept;
                    }
                    if (event.text == Key.Space) {
                        root.nav("space");
                        return accept;
                    }
                    if (event.text == Key.Backspace) {
                        root.nav("backspace");
                        return accept;
                    }
                    if (event.text == "d" || event.text == "D") { root.nav("d"); return accept; }
                    if (event.text == "r" || event.text == "R") { root.nav("r"); return accept; }
                    if (event.text == "c" || event.text == "C") { root.nav("c"); return accept; }
                    if (event.text == "+") { root.nav("+"); return accept; }
                    if (event.text == "=") { root.nav("="); return accept; }
                    if (event.text == "-") { root.nav("-"); return accept; }
                    if (event.text == "0") { root.nav("0"); return accept; }
                    if (event.text == "1") { root.nav("1"); return accept; }
                    if (event.text == "f" || event.text == "F") { root.nav("f"); return accept; }
                    if (event.text == "t" || event.text == "T") { root.nav("t"); return accept; }
                    return reject;
                }
                PageView {
                    leading-page: root.leading-page;
                    trailing-page: root.trailing-page;
                    rtl: root.rtl;
                    single: root.single;
                    leading-loading: root.leading-loading;
                    trailing-loading: root.trailing-loading;
                    content-x: root.content-x;
                    content-y: root.content-y;
                    content-w: root.content-w;
                    content-h: root.content-h;
                    modal-open: root.show-settings || root.show-shortcuts || root.show-confirm-delete || root.show-update-available;
                    begin-pan() => { root.begin-pan(); }
                    pan-to(dx, dy) => { root.pan-to(dx, dy); }
                    begin-pinch() => { root.begin-pinch(); }
                    pinch-to(ax, ay, scale) => { root.pinch-to(ax, ay, scale); }
                    scroll-pan(dx, dy) => { root.scroll-pan(dx, dy); }
                    viewport-resized(w, h) => { root.viewport-resized(w, h); }
                    reveal() => { root.reveal-chrome-from-pointer(); }
                    // Tap-to-turn: a tap on the left/right half routes into the SAME nav
                    // tokens as the arrow keys, so keymap.rs resolves reading direction once.
                    // Same modal guard as the FocusScope (belt-and-braces under an overlay).
                    tapped(tx) => {
                        if (!root.show-settings && !root.show-shortcuts && !root.show-confirm-delete && !root.show-update-available) {
                            root.nav(tx < self.width / 2 ? "left" : "right");
                        }
                    }
                    // Two-finger horizontal swipe: routes its direction token into the SAME
                    // nav() seam as tap/arrows. Same modal guard as tapped (belt-and-braces).
                    page-swipe(dir) => {
                        if (!root.show-settings && !root.show-shortcuts && !root.show-confirm-delete && !root.show-update-available) {
                            root.nav(dir);
                        }
                    }
                }
            }

            // Title label above the pill (auto-hides). Faux text-glow because Slint 1.x
            // Text has no text-shadow: drawn several times in Theme.title-glow offset
            // ~1.5–2px around a crisp copy. Wrapper hugs the name (no binding loop).
            title-label := Rectangle {
                width: min(front-text.preferred-width + Theme.space-lg * 2, parent.width - Theme.space-xl * 2);
                height: front-text.preferred-height + Theme.space-xs * 2;
                x: (parent.width - self.width) / 2;
                y: Theme.space-sm;
                background: transparent;
                visible: root.chrome-shown && root.current-book-name != "";
                // Hover sensor: keeps the chrome from auto-hiding while the pointer rests
                // on the title. Declared before the text so it sits behind it.
                title-touch := TouchArea { }
                // Glow copies behind the crisp title (faux text-shadow): 8 directions,
                // diagonals at ~1.5px vs ~2px orthogonal so the halo stays roughly circular.
                for o in [
                    { dx: -2px, dy: 0px },
                    { dx: 2px, dy: 0px },
                    { dx: 0px, dy: -2px },
                    { dx: 0px, dy: 2px },
                    { dx: -1.5px, dy: -1.5px },
                    { dx: 1.5px, dy: -1.5px },
                    { dx: -1.5px, dy: 1.5px },
                    { dx: 1.5px, dy: 1.5px },
                ] : Text {
                    x: Theme.space-lg + o.dx;
                    y: o.dy;
                    width: parent.width - Theme.space-lg * 2;
                    height: 100%;
                    text: root.current-book-name;
                    color: Theme.title-glow;
                    font-size: Theme.font-label;
                    font-weight: Theme.weight-medium;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
                front-text := Text {
                    x: Theme.space-lg;
                    y: 0;
                    width: parent.width - Theme.space-lg * 2;
                    height: 100%;
                    text: root.current-book-name;
                    color: Theme.text;
                    font-size: Theme.font-label;
                    font-weight: Theme.weight-medium;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            // ViewerPill: centered floating glass pill (auto-hides with chrome),
            // placed just below the title label so neither clips the other.
            viewer-pill := ViewerPill {
                x: (parent.width - self.width) / 2;
                y: title-label.y + title-label.height + Theme.space-xs;
                page-text <=> root.page-jump-text;
                total-pages: root.scrubber-total-pages;
                visible: root.chrome-shown;
                page-jump-request(t) => { root.page-jump-request(t); }
                page-jump-cancel => { root.page-jump-cancel(); }
                toggle-thumbnails => {
                    root.toggle-thumbnails();
                    fs.focus();
                }
                open-settings => { root.open-settings(); }
            }

            // Scrubber pinned to the bottom edge.
            Scrubber {
                x: 0;
                width: parent.width;
                y: parent.height - self.height - Theme.space-lg;
                current-page: root.scrubber-current-page;
                total-pages: root.scrubber-total-pages;
                rtl: root.rtl;
                double: root.scrubber-double;
                preview-a: root.scrubber-preview-a;
                preview-b: root.scrubber-preview-b;
                preview-a-loaded: root.scrubber-preview-a-loaded;
                preview-a-failed: root.scrubber-preview-a-failed;
                preview-b-loaded: root.scrubber-preview-b-loaded;
                preview-b-failed: root.scrubber-preview-b-failed;
                chrome-shown: root.chrome-shown;
                preview(p) => { root.reveal-chrome(); root.scrub-preview(p); }
                commit(p) => { root.scrub-commit(p); }
            }

            // Idle fade timer. `running` starts it on any reveal (reveal-chrome-now does
            // a stop+restart). On fire the chrome hides, unless the page-jump field has focus.
            idle-timer := Timer {
                interval: 2500ms;
                running: root.chrome-shown && !viewer-pill.field-focused && !root.chrome-hovered;
                triggered => {
                    if (!viewer-pill.field-focused && !root.chrome-hovered) {
                        root.chrome-shown = false;
                        // Suppress the phantom pointer-reveal this hide triggers
                        // when a stationary cursor sat over the vacated chrome.
                        root.arm-pointer-reveal-suppression();
                    }
                    idle-timer.stop();
                }
            }
            // Clears the post-hide pointer-reveal suppression after a short window: long
            // enough to absorb the phantom `changed mouse-x`, short enough to feel instant.
            reveal-guard := Timer {
                interval: 250ms;
                running: false;
                triggered => {
                    root.suppress-pointer-reveal = false;
                    reveal-guard.stop();
                }
            }
        }
        if root.show-thumbnails : ThumbnailStrip {
            height: 150px;
            thumbnails: root.thumbnails;
            current-index: root.current-index;
            thumbnail-clicked(page) => { root.thumbnail-clicked(page); }
            visible-range-changed(first-px, viewport-w, cell-stride) => {
                root.thumbnail-strip-visible-range-changed(first-px, viewport-w, cell-stride);
            }
        }
    }

    // Modal overlays: siblings of the VerticalBox, painting back-to-front in declaration
    // order. Order is LOAD-BEARING: SettingsDialog → ShortcutsOverlay → ConfirmDialog →
    // UpdateAvailableDialog (both show-settings & show-shortcuts true = modal-over-modal).
    if root.show-settings : SettingsDialog {
        width: root.width;
        height: root.height;
        reading-direction-index <=> root.reading-direction-index;
        spread-mode-index <=> root.spread-mode-index;
        cover-mode-index <=> root.cover-mode-index;
        fit-mode-index <=> root.fit-mode-index;
        cache-size <=> root.cache-size;
        preload-pages <=> root.preload-pages;
        track-recent <=> root.track-recent;
        allow-rar-archives <=> root.allow-rar-archives;
        data-action-status: root.data-action-status;
        language-index <=> root.language-index;
        focus-epoch: root.settings-focus-epoch;
        show-reset-button: root.settings-per-book;
        open-shortcuts() => { root.open-shortcuts(); }
        set-reading-direction(i) => { root.set-reading-direction(i); }
        set-spread-mode(i) => { root.set-spread-mode(i); }
        set-cover-mode(i) => { root.set-cover-mode(i); }
        set-fit-mode(i) => { root.set-fit-mode(i); }
        set-cache-size(v) => { root.set-cache-size(v); }
        set-preload-pages(v) => { root.set-preload-pages(v); }
        set-track-recent(b) => { root.set-track-recent(b); }
        set-allow-rar-archives(b) => { root.set-allow-rar-archives(b); }
        clear-reading-history() => { root.clear-reading-history(); }
        clear-cover-cache() => { root.clear-cover-cache(); }
        set-language(i) => { root.set-language(i); }
        // About / auto-update (Task 10): app-version is one-way in-prop; auto-update-check
        // is two-way bound AND fires its callback so Rust persists (like track-recent).
        app-version: root.settings-app-version;
        auto-update-check <=> root.settings-auto-update-check;
        update-status: root.settings-update-status;
        check-for-updates() => { root.settings-check-for-updates(); }
        set-auto-update-check(b) => { root.settings-set-auto-update-check(b); }
        close-settings() => { root.close-settings(); }
        reset-to-global() => { root.reset-overrides(); }
    }
    // ShortcutsOverlay: declared AFTER SettingsDialog so it paints above it (see the
    // modal-stack note). ConfirmDialog/UpdateAvailableDialog stack above it in turn.
    if root.show-shortcuts : ShortcutsOverlay {
        width: root.width;
        height: root.height;
        key-bindings-text: root.key-bindings-text;
        close-shortcuts() => { root.close-shortcuts(); }
    }
    // ── Confirm-delete modal (PR-5) ───────────────────────────────────────────
    // Mounted LAST so it paints on top. The `if` gate re-instantiates on every open,
    // so `init` re-focuses Cancel — NO focus-epoch needed. `cancel` is pure Slint
    // (D4): closes + restores focus WITHOUT a Rust round-trip (selection preserved);
    // only `confirm` crosses to Rust.
    if root.show-confirm-delete : ConfirmDialog {
        width: root.width;
        height: root.height;
        title: root.confirm-delete-title;
        body-lines: root.confirm-delete-body-lines;
        info-text: root.confirm-delete-info;
        warning-text: root.confirm-delete-warning;
        confirm-label: Strings.selection-delete;
        cancel-label: Strings.confirm-delete-cancel;
        danger: true;
        confirm => { root.confirm-delete-accepted(); }
        cancel => { root.show-confirm-delete = false; carousel.focus-self(); }
    }
    // ── Update-available modal (Task 9) ───────────────────────────────────────
    // Mounted LAST (topmost) — a background release check can fire over anything.
    // The `if` gate re-focuses "Later" via `init` (no epoch). `later`/`skip` are
    // pure Slint; `accept`/`notes` cross to Rust.
    if root.show-update-available : UpdateAvailableDialog {
        width: root.width;
        height: root.height;
        current-version: root.update-current-version;
        latest-version: root.update-latest-version;
        notes-available: root.update-notes-available;
        in-progress: root.update-in-progress;
        status-text: root.update-status-text;
        accept => { root.update-accept(); }
        later => { root.show-update-available = false; root.update-later(); }
        skip => { root.show-update-available = false; root.update-skip(); }
        notes => { root.update-notes(); }
    }

    // Grab keyboard focus on startup so arrow keys work without a click.
    init => {
        // App boots to Library; focus the carousel so its key seams work without a
        // click. Rust calls focus-pages() when it switches to the Viewer.
        if (root.screen == 0) { carousel.focus-self(); } else { fs.focus(); }
    }
}
