import { VerticalBox } from "std-widgets.slint";
import { PageView } from "PageView.slint";
import { ThumbnailStrip, ThumbnailItem } from "ThumbnailStrip.slint";
import { SettingsDialog } from "SettingsDialog.slint";
import { FirstRunGuide } from "FirstRunGuide.slint";
import { ShortcutsOverlay } from "ShortcutsOverlay.slint";
import { Carousel, CarouselItem } from "Carousel.slint";
import { Theme } from "Theme.slint";
import { Scrubber } from "Scrubber.slint";
import { ViewerPill } from "components/ViewerPill.slint";

export component ViewerWindow inherits Window {
    // Intentionally empty: the OS title bar shows no app name (the floating title label above the ViewerPill carries the current book name instead). See issue #85.
    title: "";
    icon: @image-url("assets/app-icon.png");
    preferred-width: 900px;
    preferred-height: 1200px;
    // Floor that keeps a two-page spread legible with the chrome: the floating
    // ViewerPill and the bottom scrubber both need horizontal room, and a double
    // spread is two half-width pages — below ~480px each half collapses to an
    // unreadable sliver. The height floor keeps a portrait-ish page tall enough
    // to read once the scrubber's bottom inset is subtracted. Tune the FLOOR
    // only; the preferred-* boot size above is unchanged.
    min-width: 480px;
    min-height: 600px;

    // Top-level screen: 0 = Library (Carousel), 1 = Viewer. Pushed by main.rs
    // from NavState; app boots to Library (0).
    in property <int> screen: 0;
    // Carousel model + focus index (filled by PR-C; empty shell for now).
    in property <[CarouselItem]> carousel-items;
    in-out property <int> carousel-focused-index;

    // ── Library search seams (issue #88) — re-exposed for Rust ────────────────
    // `library-search-query` mirrors the NavBar field text; `library-book-count`
    // is the TOTAL book count (filter-independent) so the carousel can tell the
    // empty-library CTA apart from the search no-results state.
    // `library-search-changed` carries the debounced query to main.rs;
    // `focus-library-search` lets Rust move focus into the field. The nav's
    // `settings` click is routed straight to the existing `open-settings` flow
    // below (no dedicated root callback), so the glass-pill Settings button opens
    // the same SettingsDialog as the Viewer's ViewerPill Settings button.
    in-out property <string> library-search-query;
    in property <int> library-book-count;
    callback library-search-changed(string);
    public function focus-library-search() { carousel.focus-search(); }

    in property <[ThumbnailItem]> thumbnails;
    in property <int> current-index;
    in property <bool> show-thumbnails: false;

    // ── Scrubber + auto-hide chrome (PR-S) ────────────────────────────────────
    // Auto-hide state shared by the scrubber, ViewerPill, and floating title label. Revealed
    // on mouse-move / arrow / drag; cleared by the idle Timer.
    in-out property <bool> chrome-shown: false;
    // Guards the phantom-reveal flip-flop after an idle-hide. When the chrome
    // hides out from under a STATIONARY cursor, the vacated pill/title lets
    // PageView's TouchArea re-acquire the cursor and emit a `changed mouse-x` —
    // a phantom "move" that would re-reveal the chrome and flip-flop it every
    // idle interval. See `reveal-chrome-from-pointer`.
    property <bool> suppress-pointer-reveal: false;
    // True while the pointer rests on the pill or the title capsule. The chrome
    // must NOT auto-hide under the cursor there, so this pauses the idle timer
    // (same role `field-focused` plays while typing a page number).
    property <bool> chrome-hovered: viewer-pill.hovered || title-touch.has-hover;
    // Scrubber data (1-based current page + total; direction + layout; preview thumbs).
    in property <int> scrubber-current-page;
    in property <int> scrubber-total-pages;
    in property <bool> scrubber-double;
    in property <image> scrubber-preview-a;
    in property <image> scrubber-preview-b;
    in property <bool> scrubber-preview-a-loaded: false;
    in property <bool> scrubber-preview-a-failed: false;
    in property <bool> scrubber-preview-b-loaded: false;
    in property <bool> scrubber-preview-b-failed: false;

    // Viewer pill: page-jump text (1-based string, kept in sync by Rust)
    in-out property <string> page-jump-text: "1";
    // Viewer pill callbacks — handled by Rust
    callback page-jump-request(string);
    callback page-jump-cancel();

    // Fired with the 0-based page under the knob during a drag (preview only —
    // the page body must NOT change) and with the page to commit on release.
    callback scrub-preview(float);
    callback scrub-commit(float);
    // Fired whenever the user shows intent (mouse-move over the page / scrubber
    // drag). Rust's `on_reveal_chrome` handler delegates straight back to the
    // Slint `reveal-chrome-now()` function, which sets chrome-shown and restarts
    // the idle timer. (Arrow / page-turn keys call `invoke_reveal_chrome_now()`
    // directly in the `nav` handler, bypassing this callback.)
    callback reveal-chrome();

    in property <image> leading-page;
    in property <image> trailing-page;
    in property <bool> rtl;
    in property <bool> single;
    in property <string> status-text: "No folder opened";
    // Book display name (set by main.rs on a successful open, cleared to "" when
    // nothing is open). Declared on the root because Rust binds only to the root
    // surface; consumed by the floating title label Rectangle in the viewer stage.
    in property <string> current-book-name;
    // Rust-computed content rectangle forwarded to PageView.
    in property <length> content-x: 0px;
    in property <length> content-y: 0px;
    in property <length> content-w: 0px;
    in property <length> content-h: 0px;

    // Settings dialog / overlay visibility and state.
    in property <bool> show-settings: false;
    in property <bool> show-guide: false;
    in property <bool> show-shortcuts: false;
    // Private epoch: Rust bumps this (via focus-settings()) after closing the
    // shortcuts overlay so SettingsDialog can re-focus its FocusScope. The
    // if-gated dialog cannot be referenced by id from here, so the epoch is
    // observed via a `changed` handler inside the dialog.
    property <int> settings-focus-epoch: 0;
    in-out property <int> reading-direction-index;
    in-out property <int> spread-mode-index;
    in-out property <int> cover-mode-index;
    in-out property <int> fit-mode-index;
    in-out property <int> cache-size;
    in-out property <int> preload-pages;
    in-out property <bool> track-recent;
    // Index into the language dropdown model (En=0, Ja=1).
    in-out property <int> language-index;
    in property <string> key-bindings-text;
    // True when the settings dialog edits the current book's per-book override
    // (opened from the Viewer) rather than the global defaults (Library screen).
    in property <bool> settings-per-book: false;

    changed width  => { root.resized(self.width, self.height); }
    changed height => { root.resized(self.width, self.height); }

    callback thumbnail-clicked(int);
    callback toggle-thumbnails();

    public function focus-pages() { fs.focus(); }
    // Rust calls this after closing the shortcuts overlay to return focus to
    // SettingsDialog. The if-gated dialog cannot be referenced by id, so this
    // bumps an epoch that the dialog's `changed` handler observes to re-focus
    // its inner FocusScope.
    public function focus-settings() { root.settings-focus-epoch += 1; }

    // Re-arm the idle-fade countdown: show the chrome, then stop+restart the timer
    // so a full interval elapses from THIS reveal (not from whenever it last
    // started). Called via invoke_reveal_chrome_now() from Rust on every reveal
    // (mouse-move, arrow / page-turn key, or scrubber drag).
    public function reveal-chrome-now() {
        root.chrome-shown = true;
        idle-timer.running = true;
        idle-timer.stop();
        idle-timer.start();
    }

    // Pointer-driven reveals (PageView hover) honor a brief suppression window
    // after an idle-hide so the chrome does not flip-flop when it hides out from
    // under a stationary cursor (see `suppress-pointer-reveal`). A genuine
    // pointer move after the window reveals the chrome normally; arrow keys and
    // scrubber drags bypass this guard via `reveal-chrome-now` directly.
    function reveal-chrome-from-pointer() {
        if (root.suppress-pointer-reveal) {
            return;
        }
        root.reveal-chrome-now();
    }

    callback open-folder();
    callback open-archive();
    // Carousel navigation seams (Library screen). Forwarded to main.rs.
    callback carousel-open(int);
    callback carousel-move(int);
    callback carousel-back();
    // File/folder picker triggers forwarded from the Carousel toolbar and CTA.
    callback add-files();
    callback add-folder();
    public function focus-carousel() { carousel.focus-self(); }
    // Forwarded navigation token: "left" | "right" | "space" | "backspace" |
    // "d" | "r" | "c" | "+" | "=" | "-" | "0" | "1" | "f".
    callback nav(string);
    // Zoom/pan callbacks forwarded from PageView so main.rs can connect them.
    callback zoom-at(length, length, float);
    callback begin-pan();
    callback pan-to(length, length);
    callback viewport-resized(length, length);
    // Forwarded window size (logical pixels, Slint `length` units) so Rust can
    // resolve SpreadMode::Auto live.
    callback resized(length, length);

    // Settings dialog callbacks.
    callback open-settings();
    callback close-settings();
    callback open-shortcuts();
    callback close-shortcuts();
    // Viewer settings: reset the current book to the global defaults.
    callback reset-overrides();
    callback dismiss-guide();
    callback set-reading-direction(int);
    callback set-spread-mode(int);
    callback set-cover-mode(int);
    callback set-fit-mode(int);
    callback set-cache-size(int);
    callback set-preload-pages(int);
    callback set-track-recent(bool);
    callback set-language(int);

    // ── Library screen ────────────────────────────────────────────────────────
    // Both screens are always instantiated and toggled with `visible` (rather
    // than `if`) so their FocusScope ids (`carousel`'s internal scope and `fs`)
    // stay at root scope and remain reachable from the public focus functions
    // and `init`. Slint's `if` puts ids in a child scope the parent cannot name.
    carousel := Carousel {
        visible: root.screen == 0;
        width: root.width;
        height: root.height;
        items: root.carousel-items;
        focused-index <=> root.carousel-focused-index;
        search-query <=> root.library-search-query;
        library-book-count: root.library-book-count;
        // Suppress the carousel's keyboard seams while a modal overlays the
        // Library — same condition the Viewer FocusScope uses (see `fs` below).
        modal-open: root.show-settings || root.show-guide || root.show-shortcuts;
        search-changed(q) => { root.library-search-changed(q); }
        // The nav's Settings button opens the EXISTING SettingsDialog: route the
        // click straight to the shared `open-settings` flow (same handler the
        // Viewer title bar uses) rather than a separate placeholder callback.
        settings() => { root.open-settings(); }
        open(i) => { root.carousel-open(i); }
        move(delta) => { root.carousel-move(delta); }
        back() => { root.carousel-back(); }
        add-files() => { root.add-files(); }
        add-folder() => { root.add-folder(); }
    }

    // ── Library-screen status notice ─────────────────────────────────────────
    // Shows add/save feedback (e.g. "Added 3 book(s)", "Already in library…")
    // from the Carousel toolbar and CTA. Shares the same `status-text` property
    // as the Viewer toolbar; visible only on the Library screen (screen == 0).
    // Positioned as a bottom strip so it does not overlap the carousel toolbar.
    Text {
        visible: root.screen == 0;
        x: 0;
        y: root.height - self.preferred-height - Theme.space-md;
        width: root.width;
        text: root.status-text;
        color: Theme.text-muted;
        font-size: Theme.font-micro;
        horizontal-alignment: center;
    }

    // ── Viewer screen (existing content) ───────────────────────────────────────
    // `visible`-gated (not `if`) so the inner `fs` FocusScope id stays reachable
    // from `focus-pages()` and `init` (see the note on the carousel above).
    VerticalBox {
        visible: root.screen == 1;
        // Viewer stage: the page and the auto-hiding chrome (ViewerPill +
        // scrubber) stacked on top. PageView's TouchArea reveals the chrome on
        // pointer movement via its `reveal()` callback. The chrome positions
        // itself with absolute x/y relative to this Rectangle.
        Rectangle {
            // The FocusScope + PageView are unchanged; only wrapped so the chrome
            // can be absolutely positioned over them.
            fs := FocusScope {
                key-pressed(event) => {
                    // Suppress background navigation while a modal overlay is open.
                    if (root.show-settings || root.show-guide || root.show-shortcuts) { return reject; }
                    if (event.text == Key.LeftArrow) {
                        root.nav("left");
                        return accept;
                    }
                    if (event.text == Key.RightArrow) {
                        root.nav("right");
                        return accept;
                    }
                    if (event.text == Key.UpArrow) {
                        root.nav("up");
                        return accept;
                    }
                    if (event.text == Key.Space) {
                        root.nav("space");
                        return accept;
                    }
                    if (event.text == Key.Backspace) {
                        root.nav("backspace");
                        return accept;
                    }
                    if (event.text == "d" || event.text == "D") { root.nav("d"); return accept; }
                    if (event.text == "r" || event.text == "R") { root.nav("r"); return accept; }
                    if (event.text == "c" || event.text == "C") { root.nav("c"); return accept; }
                    if (event.text == "+") { root.nav("+"); return accept; }
                    if (event.text == "=") { root.nav("="); return accept; }
                    if (event.text == "-") { root.nav("-"); return accept; }
                    if (event.text == "0") { root.nav("0"); return accept; }
                    if (event.text == "1") { root.nav("1"); return accept; }
                    if (event.text == "f" || event.text == "F") { root.nav("f"); return accept; }
                    if (event.text == "t" || event.text == "T") { root.nav("t"); return accept; }
                    return reject;
                }
                PageView {
                    leading-page: root.leading-page;
                    trailing-page: root.trailing-page;
                    rtl: root.rtl;
                    single: root.single;
                    content-x: root.content-x;
                    content-y: root.content-y;
                    content-w: root.content-w;
                    content-h: root.content-h;
                    zoom-at(mx, my, dy) => { root.zoom-at(mx, my, dy); }
                    begin-pan() => { root.begin-pan(); }
                    pan-to(dx, dy) => { root.pan-to(dx, dy); }
                    viewport-resized(w, h) => { root.viewport-resized(w, h); }
                    reveal() => { root.reveal-chrome-from-pointer(); }
                }
            }

            // Title label above the pill (auto-hides with chrome). No backing
            // capsule — the title sits directly over the page; legibility comes
            // from a faux text-glow: Slint 1.x Text has no text-shadow (and a
            // Rectangle drop-shadow paints a full-width bar, not a text glow), so
            // the name is drawn several times in Theme.title-glow, offset ~1.5–2px
            // around a crisp white copy. The wrapper hugs the name — its width
            // tracks the text's preferred width (capped to the stage), and because
            // preferred-width does not depend on this Rectangle's width there is no
            // binding loop. Pinned to the top edge with a small inset; the pill is
            // positioned BELOW it (see viewer-pill.y) so neither clips the other.
            title-label := Rectangle {
                width: min(front-text.preferred-width + Theme.space-lg * 2, parent.width - Theme.space-xl * 2);
                height: front-text.preferred-height + Theme.space-xs * 2;
                x: (parent.width - self.width) / 2;
                y: Theme.space-sm;
                background: transparent;
                visible: root.chrome-shown && root.current-book-name != "";
                // Hover sensor: keeps the chrome from auto-hiding while the pointer
                // rests on the title (see idle-timer). Declared before the text so
                // it sits behind it; the text is non-interactive anyway.
                title-touch := TouchArea { }
                // Glow copies behind the crisp white title (faux text-shadow).
                // 8 directions (orthogonal + diagonal) at ~2px spread the glow
                // wider than a 1px outline; the diagonals use ~1.5px so the halo
                // stays roughly circular.
                for o in [
                    { dx: -2px, dy: 0px },
                    { dx: 2px, dy: 0px },
                    { dx: 0px, dy: -2px },
                    { dx: 0px, dy: 2px },
                    { dx: -1.5px, dy: -1.5px },
                    { dx: 1.5px, dy: -1.5px },
                    { dx: -1.5px, dy: 1.5px },
                    { dx: 1.5px, dy: 1.5px },
                ] : Text {
                    x: Theme.space-lg + o.dx;
                    y: o.dy;
                    width: parent.width - Theme.space-lg * 2;
                    height: 100%;
                    text: root.current-book-name;
                    color: Theme.title-glow;
                    font-size: Theme.font-label;
                    font-weight: Theme.weight-medium;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
                front-text := Text {
                    x: Theme.space-lg;
                    y: 0;
                    width: parent.width - Theme.space-lg * 2;
                    height: 100%;
                    text: root.current-book-name;
                    color: Theme.text;
                    font-size: Theme.font-label;
                    font-weight: Theme.weight-medium;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            // ViewerPill: centered floating glass pill (auto-hides with chrome),
            // placed just below the title label so neither clips the other.
            viewer-pill := ViewerPill {
                x: (parent.width - self.width) / 2;
                y: title-label.y + title-label.height + Theme.space-xs;
                page-text <=> root.page-jump-text;
                total-pages: root.scrubber-total-pages;
                visible: root.chrome-shown;
                page-jump-request(t) => { root.page-jump-request(t); }
                page-jump-cancel => { root.page-jump-cancel(); }
                toggle-thumbnails => {
                    root.toggle-thumbnails();
                    fs.focus();
                }
                open-settings => { root.open-settings(); }
            }

            // Scrubber pinned to the bottom edge.
            Scrubber {
                x: 0;
                width: parent.width;
                y: parent.height - self.height - Theme.space-lg;
                current-page: root.scrubber-current-page;
                total-pages: root.scrubber-total-pages;
                rtl: root.rtl;
                double: root.scrubber-double;
                preview-a: root.scrubber-preview-a;
                preview-b: root.scrubber-preview-b;
                preview-a-loaded: root.scrubber-preview-a-loaded;
                preview-a-failed: root.scrubber-preview-a-failed;
                preview-b-loaded: root.scrubber-preview-b-loaded;
                preview-b-failed: root.scrubber-preview-b-failed;
                chrome-shown: root.chrome-shown;
                preview(p) => { root.reveal-chrome(); root.scrub-preview(p); }
                commit(p) => { root.scrub-commit(p); }
            }

            // Idle fade timer. The `running` binding starts it for any reveal that
            // flips chrome-shown true (via reveal-chrome-now()), which also does an
            // explicit stop+restart so a full interval elapses from the latest reveal.
            // When it fires, the chrome hides — but only if the page-jump field does
            // not have focus (suppressed while the user types a page number).
            idle-timer := Timer {
                interval: 2500ms;
                running: root.chrome-shown && !viewer-pill.field-focused && !root.chrome-hovered;
                triggered => {
                    if (!viewer-pill.field-focused && !root.chrome-hovered) {
                        root.chrome-shown = false;
                        // Suppress the phantom pointer-reveal this hide triggers
                        // when a stationary cursor sat over the vacated chrome.
                        root.suppress-pointer-reveal = true;
                        reveal-guard.start();
                    }
                    idle-timer.stop();
                }
            }
            // Clears the post-hide pointer-reveal suppression after a short window
            // (long enough to absorb the phantom `changed mouse-x`, short enough
            // that a real pointer move reveals the chrome without a felt delay).
            reveal-guard := Timer {
                interval: 250ms;
                running: false;
                triggered => {
                    root.suppress-pointer-reveal = false;
                    reveal-guard.stop();
                }
            }
        }
        if root.show-thumbnails : ThumbnailStrip {
            height: 150px;
            thumbnails: root.thumbnails;
            current-index: root.current-index;
            thumbnail-clicked(page) => { root.thumbnail-clicked(page); }
        }
    }

    // Modal overlays rendered as siblings of the VerticalBox so they stack on
    // top of all page content. Slint children paint back-to-front in
    // declaration order: first-declared = behind, last-declared = topmost.
    // Explicit width/height fill the window surface.
    // show-settings and show-shortcuts are BOTH true while the shortcuts
    // overlay is open (modal-over-modal), so declaration order is load-bearing:
    // ShortcutsOverlay MUST remain the last child so it paints above
    // SettingsDialog.
    if root.show-settings : SettingsDialog {
        width: root.width;
        height: root.height;
        reading-direction-index <=> root.reading-direction-index;
        spread-mode-index <=> root.spread-mode-index;
        cover-mode-index <=> root.cover-mode-index;
        fit-mode-index <=> root.fit-mode-index;
        cache-size <=> root.cache-size;
        preload-pages <=> root.preload-pages;
        track-recent <=> root.track-recent;
        language-index <=> root.language-index;
        focus-epoch: root.settings-focus-epoch;
        show-reset-button: root.settings-per-book;
        open-shortcuts() => { root.open-shortcuts(); }
        set-reading-direction(i) => { root.set-reading-direction(i); }
        set-spread-mode(i) => { root.set-spread-mode(i); }
        set-cover-mode(i) => { root.set-cover-mode(i); }
        set-fit-mode(i) => { root.set-fit-mode(i); }
        set-cache-size(v) => { root.set-cache-size(v); }
        set-preload-pages(v) => { root.set-preload-pages(v); }
        set-track-recent(b) => { root.set-track-recent(b); }
        set-language(i) => { root.set-language(i); }
        close-settings() => { root.close-settings(); }
        reset-to-global() => { root.reset-overrides(); }
    }
    if root.show-guide : FirstRunGuide {
        width: root.width;
        height: root.height;
        dismiss-guide() => { root.dismiss-guide(); }
    }
    // ShortcutsOverlay: must stay LAST (topmost) — see stacking-order note above.
    if root.show-shortcuts : ShortcutsOverlay {
        width: root.width;
        height: root.height;
        key-bindings-text: root.key-bindings-text;
        close-shortcuts() => { root.close-shortcuts(); }
    }

    // Grab keyboard focus on startup so arrow keys work without a click.
    init => {
        // App boots to Library; focus the carousel so its key seams work
        // without a click. When Rust switches to the Viewer it calls
        // focus-pages() to move focus there.
        if (root.screen == 0) { carousel.focus-self(); } else { fs.focus(); }
    }
}
