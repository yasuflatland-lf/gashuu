// Bottom page scrubber (spec §5). Fires preview(fraction) while dragging (preview ONLY) and
// commit(fraction) once on release; RTL drag-left advances. Fraction→page rounding is Rust's (issue 71 Part D).
import { Theme } from "Theme.slint";
import { ThumbnailCell } from "components/ThumbnailCell.slint";

export component Scrubber inherits Rectangle {
    in property <int> current-page;     // 1-based current spread leading
    in property <int> total-pages;
    in property <bool> rtl;             // RTL: dragging left advances
    in property <bool> double;          // 2 preview thumbs vs 1
    in property <image> preview-a;      // leading preview thumb
    in property <image> preview-b;      // trailing preview thumb (double only)
    in property <bool> preview-a-loaded: false;
    in property <bool> preview-a-failed: false;
    in property <bool> preview-b-loaded: false;
    in property <bool> preview-b-failed: false;
    in property <bool> chrome-shown;    // auto-hide state (parent-driven)
    // Raw clamped knob fraction in [0,1] (screen-left 0 → right 1). Rust maps it to a 0-based
    // page via `scrub_fraction_to_page` (single source of rounding); RTL inversion lives there.
    callback preview(float);   // fraction under the knob DURING drag
    callback commit(float);    // fraction to resolve + jump_to ON RELEASE

    // Whole component fades with the chrome; no hit area when hidden so a hidden
    // scrubber can't intercept clicks meant for the page.
    opacity: root.chrome-shown ? 1.0 : 0.0;
    visible: root.chrome-shown;
    animate opacity { duration: Theme.motion-fast; }

    // ── Geometry ────────────────────────────────────────────────────────────
    // The rail spans the component width minus symmetric edge insets.
    private property <length> inset: Theme.space-huge;
    private property <length> rail-x: root.inset;
    private property <length> rail-w: root.width - 2 * root.inset;
    // Last 0-based index; -1 guard keeps the span non-negative when empty.
    private property <int> last-index: max(root.total-pages - 1, 0);

    // Drag bookkeeping.
    private property <bool> dragging: ta.pressed;
    // Pointer fraction along the rail (screen-left 0 → right 1), clamped to [0,1] — the ONLY value
    // handed to Rust; NO `drag-page` rounding here, `scrub_fraction_to_page` owns it (issue 71 Part D).
    private property <float> drag-frac:
        root.rail-w > 0px
            ? clamp(ta.mouse-x / root.rail-w, 0.0, 1.0)
            : 0.0;
    // Idle fraction derived from current-page (1-based) so the knob sits at the
    // current spread when not dragging. RTL mirrors the position.
    private property <float> idle-frac:
        root.last-index > 0
            ? (root.rtl
                ? 1.0 - (root.current-page - 1) / root.last-index
                : (root.current-page - 1) / root.last-index)
            : 0.0;
    // The fraction actually drawn: pointer while dragging, else the idle anchor.
    private property <float> knob-frac: root.dragging ? root.drag-frac : root.idle-frac;
    private property <length> knob-cx: root.rail-x + root.knob-frac * root.rail-w;

    height: 40px;

    // ── Rail ──────────────────────────────────────────────────────────────────
    Rectangle {
        x: root.rail-x;
        width: root.rail-w;
        height: Theme.scrubber-track-height;
        y: (root.height - self.height) / 2;
        background: Theme.track;
        border-radius: Theme.radius-xs;
    }

    // Filled track (HIG): traversed portion fills with accent as reading progress, derived from
    // `knob-cx`. RTL fills knob→right edge (page 1 sits screen-right); LTR fills left edge→knob.
    Rectangle {
        x: root.rtl ? root.knob-cx : root.rail-x;
        width: root.total-pages > 1
            ? (root.rtl
                ? (root.rail-x + root.rail-w) - root.knob-cx
                : root.knob-cx - root.rail-x)
            : 0px;
        height: Theme.scrubber-track-height;
        y: (root.height - self.height) / 2;
        background: Theme.accent;
        border-radius: Theme.radius-xs;
    }

    // Knob: white core (grabber) + accent halo (progress). Grows on press via a sibling
    // `ta.pressed` binding, not a states[] child mutation (sidesteps the Slint states[] limitation).
    Rectangle {
        width: ta.pressed ? Theme.scrubber-knob-size-active : Theme.scrubber-knob-size;
        height: ta.pressed ? Theme.scrubber-knob-size-active : Theme.scrubber-knob-size;
        x: root.knob-cx - self.width / 2;
        y: (root.height - self.height) / 2;
        background: Theme.text;
        border-radius: Theme.radius-pill;
        // 4px accent-glow halo (the only glow in the system).
        drop-shadow-color: Theme.accent-glow;
        drop-shadow-blur: 4px;
        animate width, height { duration: Theme.motion-fast; }
    }

    // ── Hit area spanning the full rail width ─────────────────────────────────
    ta := TouchArea {
        x: root.rail-x;
        width: root.rail-w;
        height: root.height;
        y: 0;
        // Live preview while dragging — body must NOT change (Rust updates only the popover +
        // counter). Pass the RAW clamped fraction; Rust resolves the page via `scrub_fraction_to_page`.
        moved => {
            if (self.pressed) { root.preview(clamp(root.drag-frac, 0.0, 1.0)); }
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                // Fire an initial preview on press so the popover appears
                // immediately at the press point.
                root.preview(clamp(root.drag-frac, 0.0, 1.0));
            }
            if (e.kind == PointerEventKind.up) {
                // Commit exactly once on release.
                root.commit(clamp(root.drag-frac, 0.0, 1.0));
            }
        }
    }

    // ── Drag preview popover (only while dragging) ────────────────────────────
    if root.dragging : Rectangle {
        // Clamp horizontally so the popover never clips at the window edges.
        private property <length> pop-w: root.double ? 168px : 92px;
        private property <length> pop-h: 132px;
        x: clamp(root.knob-cx - self.pop-w / 2, root.inset, root.width - root.inset - self.pop-w);
        y: -(self.pop-h) - Theme.space-sm;
        width: self.pop-w;
        height: self.pop-h;
        background: Theme.surface-float;
        border-color: Theme.hairline-float;
        border-width: 1px;
        border-radius: Theme.radius-md;
        drop-shadow-color: Theme.shadow-popover;
        drop-shadow-blur: 30px;

        // Preview thumbnail(s). The page number is shown by the ViewerPill, so the popover has
        // no in-Slint page readout — keeping ALL fraction→page rounding in Rust (issue 71 Part D).
        HorizontalLayout {
            padding: Theme.space-sm;
            spacing: Theme.space-xs;

            // ThumbnailCell (inherits Rectangle) has NO intrinsic size in a layout, so cells need
            // explicit stretch + min-height. Preview thumbs mirror load/decode via loaded/failed.
            ThumbnailCell {
                source: root.preview-a;
                loaded: root.preview-a-loaded;
                failed: root.preview-a-failed;
                highlighted: false;
                horizontal-stretch: 1;
                min-height: 100px;
            }
            if root.double : ThumbnailCell {
                source: root.preview-b;
                loaded: root.preview-b-loaded;
                failed: root.preview-b-failed;
                highlighted: false;
                horizontal-stretch: 1;
                min-height: 100px;
            }
        }
    }
}
