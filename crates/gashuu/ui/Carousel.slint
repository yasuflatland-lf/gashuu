// Library cover-flow carousel. Public contract (CarouselItem, Carousel, its
// properties/callbacks) is FROZEN. Styling uses Theme.* only — NO inline hex.
import { Theme } from "Theme.slint";
import { Strings } from "Strings.slint";
// Shared design-system components (issue 71 componentization). The local private
// ProgressBar was deleted in favor of components/ProgressBar.slint (move-only).
import { ProgressBar } from "components/ProgressBar.slint";
import { PrimaryButton } from "components/PrimaryButton.slint";
import { ThumbnailCell } from "components/ThumbnailCell.slint";
import { NavBar } from "components/NavBar.slint";
import { SelectionBadge } from "components/SelectionBadge.slint";
import { BookmarkRibbon } from "components/BookmarkRibbon.slint";
import { SelectionToolbar } from "components/SelectionToolbar.slint";

// One book in the shelf. `selected` (from LibrarySelectionState) draws the check badge;
// `cover-failed` (issue 144) is set by CoverController::marshal_failed, reset on rebuild.
export struct CarouselItem {
    cover: image,
    title: string,
    current: int,     // 1-based current page for display (= 0-based index + 1)
    total: int,
    progress: float,  // 0.0 .. 1.0
    available: bool,
    selected: bool,
    bookmarked: bool, // true = last-opened book; shows the BookmarkRibbon overlay
    cover-failed: bool, // true = cover load failed; shows the failed treatment
    cover-loaded: bool, // true = cover image arrived from CoverController (not yet = loading placeholder)
}

// File-private cover-flow card (NOT exported), shared by both z-order passes.
// Slint 1.16.1 has no per-Repeater-item z, so draw order layers it: pass 1 =
// always-on backing (every book), pass 2 = centered card redrawn on top. Stops a
// fast sweep blanking a passed-through book for one frame (the "gap-toothed" bug);
// both passes bind identical geometry (pure fns of `flow-position`) so no pop.
component CoverCard inherits Rectangle {
    // Layer gate + per-card state (all driven by the enclosing `for`).
    in property <bool> show;       // this pass should draw this card
    in property <bool> centered;   // idx == round(flow-position): the card at the VISUAL center; ring + shadow
    // Only the pass-2 top copy paints the drop-shadow; the pass-1 backing copy sets
    // `elevated: false` so the semi-transparent shadow isn't composited twice (darkened).
    in property <bool> elevated: true;
    in property <float> flow-delta; // idx - flow-position: signed FLOAT distance from the visual center
    // Geometry tunables, forwarded from the Carousel root.
    in property <length> cover-w;
    in property <length> cover-h;
    in property <length> cover-step;
    in property <float> neighbor-scale;
    in property <float> neighbor-opacity;
    in property <length> ring-width;
    // Enclosing row geometry, passed in per-`for`: a component ROOT cannot read
    // `parent` (the call site can), so width and vertical anchor come from outside.
    in property <length> row-width;
    in property <length> row-cy;
    // Item data.
    in property <image> cover-source;
    in property <bool> available;
    in property <float> progress;
    // Cover load failed permanently (issue 144): drives the shared failed treatment.
    // Only meaningful while `available` — an unavailable book has its own broken-cover look.
    in property <bool> cover-failed;
    // true once CoverController streams in a real image. Starts false so the
    // neutral loading placeholder is shown instead of a black default image.
    in property <bool> cover-loaded;
    // Bulk-selection (PR-2). `selected` draws the check badge. `interactive` gates
    // the cover TouchArea so only the pass-1 backing copy fires (pass-2 sets it false).
    in property <bool> selected;
    in property <bool> selection-mode;
    in property <bool> interactive;
    // Continue-reading (BookmarkRibbon). True when this is the last-opened book;
    // renders a ribbon at the top-left of the cover, independent of `available`.
    in property <bool> bookmarked;
    callback clicked;
    // Double-click on the cover (pass-1 only, same gating as `clicked`). The
    // Carousel decides what it means — CoverCard stays presentational.
    callback double-clicked;

    // Every value below is a PURE function of `flow-delta` (no per-card `animate`):
    // the row animates ONE scalar, so a fast sweep never leaves the center slot
    // empty (patterns.md "animation altitude").
    x: root.row-width / 2 + root.flow-delta * root.cover-step - self.width / 2;
    y: root.row-cy - self.height / 2;
    // Size/opacity interpolate continuously with distance from center (full at d==0,
    // neighbor floor from d>=1). `scale-factor` single-sources the size; `width`
    // slaved to the same scalar as `x` avoids the old mid-animation second-order lag.
    private property <float> scale-factor: Math.clamp(
        1.0 - Math.abs(root.flow-delta) * (1.0 - root.neighbor-scale),
        root.neighbor-scale, 1.0);
    width: root.cover-w * root.scale-factor;
    height: root.cover-h * root.scale-factor;
    // Opacity holds FULL across the center half (|flow-delta| <= 0.5) then fades to
    // `neighbor-opacity` at the neighbor slot (==1). The flat plateau fixes the
    // mid-move "cover behind bleeds through" artifact (centered card is round(),
    // so |flow-delta| <= 0.5). Plateau edge pinned to 0.5 — the hand-off point where
    // both cards sit at exactly 1.0 — so the center hand-off carries no opacity pop.
    opacity: Math.clamp(
        1.0 - (Math.abs(root.flow-delta) - 0.5) * 2 * (1.0 - root.neighbor-opacity),
        root.neighbor-opacity, 1.0);
    // Layer gate only. Every loaded cover stays visible at EVERY width (user
    // decision: the former narrow-window neighbor-drop read as covers vanishing).
    visible: root.show;

    // The cover card: rounded, card shadow on the centered cover only, accent ring.
    cover := Rectangle {
        width: 100%;
        height: 100%;
        border-radius: Theme.radius-sm;               // DESIGN.md covers 6px
        background: Theme.surface-raised;             // placeholder backing
        // Card shadow on the CENTERED cover only (DESIGN.md elevation.card); gated on
        // `elevated` so only the pass-2 top copy paints it (else it composites twice).
        drop-shadow-blur: (root.centered && root.elevated) ? Theme.shadow-blur-float : 0px;
        drop-shadow-color: Theme.shadow-card;
        // Focus ring: 3px accent on the centered cover; in selection mode only, a
        // hovered non-centered cover gets a 1px ring (single-source via pass-1 `cover-touch`).
        border-width: root.centered ? root.ring-width : (root.selection-mode && cover-touch.has-hover ? 1px : 0px);
        border-color: Theme.accent;

        // Cover image via the shared ThumbnailCell. `highlighted: false` avoids a
        // double ring (this Rectangle draws the accent ring); `cover-failed` (issue 144)
        // flips the cell into the shared failed treatment vs the loading placeholder.
        if root.available : ThumbnailCell {
            x: 0; y: 0; width: 100%; height: 100%;
            radius: Theme.radius-sm;
            source: root.cover-source;
            loaded: root.cover-loaded;
            failed: root.cover-failed;
            failed-label: root.centered && root.cover-failed ? Strings.cover-failed-label : "";
            highlighted: false;
        }

        // Unavailable: grayed card + "no image" SVG glyph (replaced the old "⛌" Text
        // glyph, which rendered as a tofu box on fonts lacking U+26CC).
        if !root.available : Rectangle {
            x: 0; y: 0; width: 100%; height: 100%;
            border-radius: Theme.radius-sm;
            background: Theme.surface-sunken;
            Image {
                source: @image-url("assets/no-image.svg");
                colorize: Theme.text-faint;
                // 23.6% ≈ 1/φ³ on the repo's golden-ratio ladder (a quieter mark).
                width: Math.min(parent.width, parent.height) * 23.6%;
                height: self.width;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        // Bulk-selection check badge, pinned top-right. Gated on `selection-mode` (not
        // `selected`) so EVERY cover shows a badge while selecting; `checked` fills it.
        // Lives in the shared body so both z-order passes draw it (else it vanishes centered).
        if root.selection-mode : SelectionBadge {
            checked: root.selected;
            x: parent.width - self.width - Theme.space-xs;
            y: Theme.space-xs;
        }

        // Continue-reading ribbon: card-external protrusion, floats fully clear of the
        // cover's top edge (negative y — no ancestor clips this region, so it's safe).
        // Top-left, so it never conflicts with SelectionBadge (top-right); rendered
        // regardless of `available` (a file-gone book still shows "continue reading").
        if root.bookmarked : BookmarkRibbon {
            x: Theme.space-xs;
            y: -self.height - Theme.space-md;
        }
    }

    // Per-cover progress bar (under the cover). `parent` is this CoverCard.
    ProgressBar {
        x: 0;
        y: parent.height + Theme.space-xs;
        width: parent.width;
        progress: root.progress;
    }

    // Invisible click rectangle, centered on the card. Width = max(cover-step, card
    // width): neighbors get a comfortable cover-step target, while the centered card
    // uses its full width so the top-right selection badge isn't in a dead zone.
    // `enabled: root.interactive` fires only the pass-1 backing copy (handled once).
    // Non-focusable (repo convention), so keyboard focus stays on the carousel.
    cover-touch := TouchArea {
        enabled: root.interactive;
        width: Math.max(root.cover-step, parent.width);
        height: parent.height;
        x: (parent.width - self.width) / 2;
        y: 0;
        clicked => { root.clicked(); }
        // Slint fires `clicked` on EVERY click and `double-clicked` IN ADDITION on the
        // second (vendored input_items.rs) — so a double-click is focus, focus, open.
        double-clicked => { root.double-clicked(); }
    }
}

// File-private sunken card shared by the empty-library CTA and the no-results state.
// Container-relative geometry (width clamp, x/y centering) is set by each call site,
// NOT here: a component ROOT cannot reference `parent`, so it lives where parent resolves.
component EmptyStatePanel inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <length> panel-height;   // 200px (CTA) / 160px (no-results)
    height: root.panel-height;
    background: Theme.surface-sunken;
    border-radius: Theme.radius-lg;
    border-width: 1px;
    border-color: Theme.hairline;
    VerticalLayout {
        alignment: center;
        spacing: Theme.space-md;
        padding: Theme.space-xl;
        Text {
            text: root.title;
            color: Theme.text;
            font-size: Theme.font-title;
            font-weight: Theme.weight-bold;
            horizontal-alignment: center;
        }
        Text {
            text: root.subtitle;
            color: Theme.text-muted;
            font-size: Theme.font-micro;
            horizontal-alignment: center;
        }
        // Optional CTA slot — LAST child so it stacks under the subtitle. The
        // empty-state call site passes a CTA here; the no-results site passes none.
        @children
    }
}

export component Carousel inherits Rectangle {
    // ── Frozen public contract ────────────────────────────────────────────────
    in property <[CarouselItem]> items;
    in-out property <int> focused-index;
    callback open(int);       // index — Return on the focused book, or a cover double-click
    callback move(int);       // delta (-1 / +1) — Left / Right
    callback back();          // Down — return to the currently-open book
    callback add-books();     // opens the add picker (rfd); wired to on_add_books in handlers/library.rs
    callback add-folder();    // opens a folder picker (rfd); wired to on_add_folder in handlers/library.rs
    // True when one native dialog picks files AND folders (macOS): the NavBar
    // shows a single combined add capsule. Pushed once from Rust at boot.
    in property <bool> combined-add-picker;

    // ── Library search seams (issue 88) ───────────────────────────────────────
    // `library-book-count` is filter-INDEPENDENT so the empty-library CTA and no-results
    // are told apart; `settings` routes to the shared open-settings flow (Viewer's dialog).
    in-out property <string> search-query;
    in property <int> library-book-count;
    callback search-changed(string);
    callback settings();
    // NavBar bookmark capsule: jump to the continue-reading book (resume at its saved
    // page), else a no-bookmark notice. Bubbles up to ViewerWindow like `settings`.
    callback continue-reading();
    // True while a modal overlays the Library. The carousel still holds focus, so its
    // FocusScope must suppress all key arms (else they act under the modal).
    in property <bool> modal-open;

    // ── Bulk-selection seams (PR-2) ───────────────────────────────────────────
    // `selection-mode` is `in-out` so the key arms flip it locally AND Rust can
    // observe/reset. toggle/cover-clicked/exit forward to handlers/library.rs.
    in-out property <bool> selection-mode;
    callback toggle-selection(int);   // visible carousel index to toggle
    callback cover-clicked(int);      // visible carousel index whose cover was clicked
    callback exit-selection();        // Esc: clear selection + leave selection mode
    // ── SelectionToolbar seams (PR-4) ─────────────────────────────────────────
    // `selection-count-text`/`select-all-label` are pre-composed in Rust; `select-all()`
    // fires from BOTH the toolbar button and the Cmd/Ctrl+A key arm.
    in property <string> selection-count-text;
    in property <string> select-all-label;
    callback select-all();
    // ── Delete seams (PR-5) ───────────────────────────────────────────────────
    // `delete-label` pre-composed in Rust; `has-selection` gates the DangerButton.
    // `request-delete()` fires from the toolbar AND Delete/Backspace (opens ConfirmDialog).
    in property <string> delete-label;
    in property <bool> has-selection;
    callback request-delete();

    // Move keyboard focus into the NavBar search field (carousel `/` and click).
    public function focus-search() { nav.focus-search(); }

    // FocusScope focus recovery (mirrors ViewerWindow's focus-pages() rule).
    public function focus-self() { fs.focus(); }

    // ── Cover-flow geometry (local tunables; colors/spacing from Theme) ───────
    // Covers center on `flow-position`; each cover's float distance drives position/scale/
    // opacity. RESPONSIVE: cover-w tracks live window width (clamped); cover-h/step derive.
    private property <length> cover-w: Math.clamp(root.width * 0.26, 140px, 240px); // centered cover width (responsive)
    private property <length> cover-h: root.cover-w * 1.4;  // 7:10 manga cover aspect (280/200 = 1.4)
    private property <length> cover-margin: 4px;       // visible gap between two side (neighbor) covers
    private property <float> neighbor-scale: 0.618;    // side covers shrink to 1/φ (centered : neighbor = φ : 1)
    private property <float> neighbor-opacity: 0.45;   // DESIGN.md components.cover.sideOpacity
    // Step between adjacent cover centers = one neighbor's full width + cover-margin,
    // so side covers just clear each other; the full-size centered cover still overlaps.
    private property <length> cover-step: root.cover-w * root.neighbor-scale + root.cover-margin;
    private property <length> ring-width: 3px;         // DESIGN.md cover.focusOutline 3px
    // Narrow breakpoint. Drives ONLY the SelectionToolbar's icon-only select-all
    // collapse; the cover-flow renders every item at every width (neighbor-drop removed).
    private property <length> narrow-threshold: 560px;
    private property <bool> narrow: root.width <= root.narrow-threshold;

    // ── Stage background: stage-top -> canvas vertical gradient (DESIGN.md
    //    "Layout / Two screens"; Slint uses @linear-gradient, not radial). ─────
    background: transparent;
    Rectangle {
        width: 100%;
        height: 100%;
        background: @linear-gradient(180deg, Theme.stage-top 0%, Theme.canvas 100%);
    }

    // ── Keyboard seams ──────────────────────────────────────────────────────
    // The carousel owns key input on the Library route. Up is a no-op here
    // (FocusScope rejects it); the Viewer's own FocusScope catches Up → GoToLibrary.
    fs := FocusScope {
        key-pressed(event) => {
            // Suppress background navigation while a modal overlay is open.
            if (root.modal-open) { return reject; }
            // Bulk-selection arms (PR-2), after the modal reject so modals keep priority.
            // `x` enters selection mode + toggles; `Space` toggles only in selection mode.
            if (event.text == "x") {
                root.selection-mode = true;
                root.toggle-selection(root.focused-index);
                return accept;
            }
            if (root.selection-mode && event.text == " ") {
                root.toggle-selection(root.focused-index);
                return accept;
            }
            // Cmd/Ctrl+A — select/deselect all (selection mode only). Slint's event.text
            // is the logical letter "a" (not "\u{1}"); on macOS Cmd->control, Ctrl->meta,
            // so testing BOTH control || meta covers Cmd+A and Ctrl+A on every platform.
            if (root.selection-mode && (event.modifiers.control || event.modifiers.meta) && event.text == "a") {
                root.select-all();
                return accept;
            }
            // Delete / Backspace — destructive arm (selection mode only); fires
            // request-delete() (Rust opens the ConfirmDialog). `accept` even when N=0 so
            // the key stays swallowed in selection mode. Both keys bound (keyboards vary).
            if (root.selection-mode && (event.text == Key.Delete || event.text == Key.Backspace)) {
                root.request-delete();
                return accept;
            }
            // Esc clears the selection and leaves selection mode (no-op / reject
            // when not in selection mode, so an ancestor could still handle Esc).
            if (event.text == Key.Escape) {
                if (root.selection-mode) {
                    root.selection-mode = false;
                    root.exit-selection();
                    return accept;
                }
                return reject;
            }
            // `/` focuses the search field, but ONLY while the carousel owns focus
            // (once the field has focus, `/` is ordinary text input).
            if (event.text == "/") { root.focus-search(); return accept; }
            if (event.text == Key.LeftArrow) { root.move(-1); return accept; }
            if (event.text == Key.RightArrow) { root.move(1); return accept; }
            if (event.text == Key.Return) { root.open(root.focused-index); return accept; }
            if (event.text == Key.DownArrow) { root.back(); return accept; }
            return reject;
        }

          // Empty state (0 books in the LIBRARY): the picker CTA. Gated on the TOTAL
          // book count, NOT filtered `items`, so a no-match search shows no-results below.
          if root.library-book-count == 0 : EmptyStatePanel {
              // Fluid panel width: clamp to the carousel width (never clips/stretches).
              // Centered via absolute x/y (this slot is not a layout).
              width: Math.clamp(parent.width - 2 * Theme.space-xl, 280px, 360px);
              x: Theme.snap((parent.width - self.width) / 2);
              y: Theme.snap((parent.height - self.height) / 2);
              title: Strings.carousel-empty-title;
              subtitle: Strings.carousel-empty-subtitle;
              panel-height: 200px;
              // CTA button (shared PrimaryButton): fires add-books() and restores
              // keyboard focus to the carousel.
              HorizontalLayout {
                  alignment: center;
                  PrimaryButton {
                      // Wording tracks the dialog flavor behind add-books():
                      // combined files+folders on macOS, files-only elsewhere.
                      text: root.combined-add-picker
                          ? Strings.carousel-empty-cta
                          : Strings.carousel-empty-cta-files;
                      clicked => { root.add-books(); root.focus-self(); }
                  }
              }
          }

          // No-results state (library has books, filter matches none). Distinct from
          // the empty-library CTA: NO add CTA here, only guidance to adjust the query.
          if root.library-book-count > 0 && root.items.length == 0 : EmptyStatePanel {
              width: Math.clamp(parent.width - 2 * Theme.space-xl, 280px, 360px);
              x: Theme.snap((parent.width - self.width) / 2);
              y: Theme.snap((parent.height - self.height) / 2);
              title: Strings.carousel-no-results-title;
              subtitle: Strings.carousel-no-results-hint;
              panel-height: 160px;
          }

          // Two-finger horizontal swipe → one-step move, reusing the Left/Right move(±1).
          // Accumulate delta-x; on crossing `swipe-threshold` fire ONE move, then a
          // cooldown Timer swallows the macOS momentum tail so one flick == one book.
          // Ancestor of the cover/step-zone TouchAreas (scroll falls through; taps don't).
          // GATED on `items.length > 0`: it paints ABOVE the empty-state panels, so
          // ungated it would block the empty-state "add books" CTA behind it.
          if root.items.length > 0 : TouchArea {
              width: 100%;
              height: 100%;
              property <length> swipe-threshold: 25px;   // lower = more sensitive
              property <float> swipe-accum: 0;
              property <bool> swipe-cooling: false;
              Timer {
                  interval: 100ms;   // shorter = higher top speed on a sustained swipe
                  running: parent.swipe-cooling;
                  triggered => { parent.swipe-cooling = false; }
              }
              scroll-event(e) => {
                  // Modals and selection mode own all input while active.
                  if (root.modal-open) { return reject; }
                  if (root.selection-mode) { return reject; }
                  // Dominant-axis gate (1.2x margin): near-horizontal only; a
                  // diagonal/vertical scroll is ignored (no ancestor handles it).
                  if (Math.abs(e.delta-x / 1px) <= Math.abs(e.delta-y / 1px) * 1.2) {
                      return reject;
                  }
                  if (self.swipe-cooling) { return accept; }
                  // Drop a reversed gesture's prior travel so two flicks never cancel.
                  if (e.delta-x / 1px * self.swipe-accum < 0) {
                      self.swipe-accum = 0;
                  }
                  self.swipe-accum += e.delta-x / 1px;
                  if (Math.abs(self.swipe-accum) >= self.swipe-threshold / 1px) {
                      root.move(self.swipe-accum > 0 ? 1 : -1);
                      self.swipe-accum = 0;
                      self.swipe-cooling = true;
                  }
                  return accept;
              }

          // Cover-flow row (>= 1 book): the parent swipe TouchArea is already gated
          // on `items.length > 0`, so this row exists only with a visible book.
          Rectangle {
              width: 100%;
              height: 100%;

              // Vertical anchor for the cover row (leaves room for the meta block
              // below). Covers are centered horizontally on flow-position.
              property <length> row-cy: parent.height / 2 - 28px;

              // Animation altitude: ONE animated scalar (`flow-position`) drives the row;
              // all card geometry derives from it as pure bindings (no per-card animation),
              // so a mid-flight retarget keeps the row coherent. `Math.round(flow-position)`
              // is the VISUAL center (ring/shadow/pass-2); `focused-index` stays the LOGICAL
              // truth. Easing never overshoots ([0,1] control points), so round stays in range.
              property <float> flow-position: root.focused-index;
              animate flow-position {
                  duration: Theme.motion-cinematic;
                  easing: cubic-bezier(0.16, 1, 0.3, 1);
              }
              // The card index at the visual center — single-sources the
              // Math.round so the three pass bindings below cannot drift apart.
              property <int> visual-center: Math.round(self.flow-position);

              // Cover-flow z-order: two passes (Slint 1.16.1 has no per-item z). Pass 1 =
              // backing layer (every book); pass 2 = centered card on top. See CoverCard header.
              for item[idx] in root.items : CoverCard {
                  show: true;
                  elevated: false;
                  centered: idx == parent.visual-center;
                  flow-delta: idx - parent.flow-position;
                  cover-w: root.cover-w;
                  cover-h: root.cover-h;
                  cover-step: root.cover-step;
                  neighbor-scale: root.neighbor-scale;
                  neighbor-opacity: root.neighbor-opacity;
                  ring-width: root.ring-width;
                  row-width: parent.width;
                  row-cy: parent.row-cy;
                  cover-source: item.cover;
                  available: item.available;
                  progress: item.progress;
                  selected: item.selected;
                  selection-mode: root.selection-mode;
                  bookmarked: item.bookmarked;
                  cover-failed: item.cover-failed;
                  cover-loaded: item.cover-loaded;
                  // PR-2: ONLY the pass-1 backing copy is click-interactive, so each cover
                  // (incl. the centered one, pass-2 = interactive:false) fires exactly once.
                  interactive: true;
                  clicked => { root.cover-clicked(idx); }
                  // Double-click opens via the SAME `open(int)` as Return; only reachable on
                  // the CENTER strip. Gated off in selection mode (else it yanks you out mid-select).
                  double-clicked => { if (!root.selection-mode) { root.open(idx); } }
              }
              // Pass 2: centered card only, on top (elevated: true default → shadow painted once).
              // Any future additional render pass MUST also set interactive: false (single-fire invariant).
              for item[idx] in root.items : CoverCard {
                  show: idx == parent.visual-center;
                  centered: idx == parent.visual-center;
                  flow-delta: idx - parent.flow-position;
                  cover-w: root.cover-w;
                  cover-h: root.cover-h;
                  cover-step: root.cover-step;
                  neighbor-scale: root.neighbor-scale;
                  neighbor-opacity: root.neighbor-opacity;
                  ring-width: root.ring-width;
                  row-width: parent.width;
                  row-cy: parent.row-cy;
                  cover-source: item.cover;
                  available: item.available;
                  progress: item.progress;
                  selected: item.selected;
                  selection-mode: root.selection-mode;
                  bookmarked: item.bookmarked;
                  cover-failed: item.cover-failed;
                  cover-loaded: item.cover-loaded;
                  // PR-2: the pass-2 top copy is NON-interactive so the centered cover
                  // doesn't double-fire — its click is handled by the pass-1 backing copy.
                  interactive: false;
              }

              // Left/Right one-step zones (normal mode only): everything outside the
              // centered cover's strip steps focus one book via the frozen move(int).
              // Declared AFTER both passes so they hit-test ABOVE the per-card TouchAreas.
              // NO double-clicked arm (else rapid side-clicks compose an accidental open);
              // `enabled: !selection-mode` makes them pointer-transparent while selecting.
              TouchArea {
                  enabled: !root.selection-mode;
                  x: 0;
                  y: 0;
                  width: Math.max(parent.width / 2 - root.cover-step / 2, 0px);
                  height: 100%;
                  clicked => { root.move(-1); }
              }
              TouchArea {
                  enabled: !root.selection-mode;
                  x: parent.width / 2 + root.cover-step / 2;
                  y: 0;
                  width: Math.max(parent.width / 2 - root.cover-step / 2, 0px);
                  height: 100%;
                  clicked => { root.move(1); }
              }

              // ── Focused-book meta block (centered, below the cover row) ───────
              if root.focused-index >= 0 && root.focused-index < root.items.length : VerticalLayout {
                  x: (parent.width - self.width) / 2;
                  y: parent.height / 2 + root.cover-h / 2 - 8px;
                  width: 320px;
                  spacing: Theme.space-xs;
                  alignment: start;

                  Text {
                      text: root.items[root.focused-index].title;
                      color: Theme.text;
                      font-size: Theme.font-title;
                      font-weight: Theme.weight-bold;
                      horizontal-alignment: center;
                      overflow: elide;
                  }
                  Text {
                      // 1-based "current / total". `total` is 0 only until the cover controller
                      // resolves the page count (then persisted), so a fresh book won't read "1 / 0".
                      text: root.items[root.focused-index].current + " / " + root.items[root.focused-index].total;
                      color: Theme.text-muted;
                      font-size: Theme.font-label;
                      horizontal-alignment: center;
                  }
              }
          }
          }

    }

    // ── Top glass-pill nav (issue 83) ─────────────────────────────────────────
    // Drawn LAST so it paints on top (paint order == declaration order). Kept
    // OUTSIDE the FocusScope; clicks fire the rfd picker then restore carousel focus.
    nav := NavBar {
        x: (parent.width - self.width) / 2;
        y: Theme.space-md;
        search-query <=> root.search-query;
        file-icon: @image-url("assets/file.svg");
        folder-icon: @image-url("assets/folder.svg");
        plus-icon: @image-url("assets/plus.svg");
        search-icon: @image-url("assets/search.svg");
        settings-icon: @image-url("assets/settings.svg");
        combined-add-picker: root.combined-add-picker;
        // §3.2-4: the Select ENTRY now lives IN the NavBar as a toggle capsule
        // (replacing the former entry pill in the slide-strip below).
        select-icon: @image-url("assets/filter.svg");
        // §10 Item D: the continue-reading capsule REUSES the ribbon's bookmark
        // glyph (same affordance, same asset) by user decision.
        bookmark-icon: @image-url("assets/bookmark.svg");
        selection-active: root.selection-mode;
        // `items` is the VISIBLE projection, so the capsule faints under a no-results search.
        // Deliberately does NOT fold `!modal-open` in (would flicker the capsule under the scrim).
        select-enabled: root.items.length > 0;
        // Toggle bulk-selection mode. Exit clears the flag then fires exit-selection()
        // (Rust clears the set). Enter enters the mode ONLY — it does NOT toggle (that's `x`).
        toggle-selection => {
            if (root.selection-mode) {
                root.selection-mode = false;
                root.exit-selection();
            } else {
                root.selection-mode = true;
            }
        }
        // Recede the NavBar behind the SelectionToolbar, bound to the same condition that
        // slides the toolbar in. Purely a translucent veil (NO TouchArea), so capsules stay usable.
        receded: root.selection-mode && !root.modal-open;
        search-changed(q) => { root.search-changed(q); }
        search-exit => { root.focus-self(); }
        add-books => { root.add-books(); root.focus-self(); }
        add-folder => { root.add-folder(); root.focus-self(); }
        settings => { root.settings(); }
        // NO root.focus-self() here: the bookmark path navigates to the Viewer (focus
        // moot), the no-bookmark path keeps carousel focus — a refocus would yank it.
        continue-reading => { root.continue-reading(); }
    }

    // ── Bulk-selection chrome: a clipped slide-strip below the NavBar ─────────
    // Hosts ONLY the SelectionToolbar (slides on `y` inside `clip: true`). Kept OUT
    // of the focus chain. NO `opacity` anywhere (HiDPI child-blur gotcha, patterns.md
    // — hard repo rule); reveal is pure geometry. FIXED height so the cover-flow below
    // never jumps on toggle. INPUT GUARD: the slid-out toolbar is also disabled via
    // `active` (clipping can leak); `active` folds in `!modal-open` so a modal suppresses
    // its pointer targets mid-slide.
    slide-strip := Rectangle {
        x: 0;
        y: nav.y + nav.height + Theme.nav-item-gap;
        width: 100%;
        height: Theme.nav-pill-height;
        clip: true;

        // Whether the toolbar is visible. `toolbar-shown` also drives the NavBar
        // recede binding above, so the recede and the slide animate in the same beat.
        property <bool> toolbar-shown: root.selection-mode && !root.modal-open;

        // SelectionToolbar slides DOWN in selection mode, UP otherwise. `exit`
        // reproduces the Esc arm. Wrapped in a full-width CENTERING layout (not an x
        // formula): content-hug width only resolves as a LAYOUT CHILD — absolutely
        // positioned it defaults to the parent's width and spans the whole window
        // (patterns.md "An element placed OUTSIDE a layout…").
        toolbar-wrap := HorizontalLayout {
            x: 0;
            width: 100%;
            height: Theme.nav-pill-height;
            // 0 = docked just below the NavBar; -height = tucked up under it
            // (clipped). Slides each time `toolbar-shown` flips.
            y: slide-strip.toolbar-shown ? 0 : -self.height;
            animate y { duration: Theme.motion-fast; }
            alignment: center;

            SelectionToolbar {
                count-text: root.selection-count-text;
                select-all-label: root.select-all-label;
                exit-a11y: Strings.selection-exit-a11y;
                narrow: root.narrow;
                // Delete (PR-5): pre-composed label + has-selection gate down, the
                // request-delete action up (Rust opens the ConfirmDialog).
                delete-label: root.delete-label;
                has-selection: root.has-selection;
                // Input/a11y guard: only the slid-in toolbar takes input.
                active: slide-strip.toolbar-shown;
                select-all => { root.select-all(); }
                request-delete => { root.request-delete(); }
                exit => { root.selection-mode = false; root.exit-selection(); }
            }
        }
    }
}
