// Library cover-flow carousel — EMPTY SHELL (PR-0b).
//
// This PR freezes the public contract (struct + component + callbacks + the
// focus-self() recovery function) and renders only a placeholder / empty
// state on the DESIGN.md stage. PR-C fills the real cover-flow rendering from
// the Library model; PR-L fills the "add books" action. Styling references
// Theme tokens only — NO inline hex (see DESIGN.md rule 2).
//
// Focus: the component owns its own FocusScope. `focus-self()` restores
// keyboard focus to it (the carousel counterpart of ViewerWindow's
// `focus-pages()` recovery rule). The key handler forwards the navigation
// seams so downstream PRs only fill the Rust side:
//   Left/Right -> move(-1 / +1)   Return -> open(focused-index)   Down -> back()
import { Theme } from "Theme.slint";

// Frozen by PR-0b; populated by PR-C (covers via PR-V). One book in the shelf.
export struct CarouselItem {
    cover: image,
    title: string,
    current: int,     // 1-based current page for display (= 0-based index + 1)
    total: int,
    progress: float,  // 0.0 .. 1.0
    available: bool,
}

export component Carousel inherits Rectangle {
    // ── Frozen public contract ────────────────────────────────────────────────
    in property <[CarouselItem]> items;
    in-out property <int> focused-index;
    callback open(int);   // index — Return on the focused book
    callback move(int);   // delta (-1 / +1) — Left / Right
    callback back();      // Down — return to the currently-open book

    // FocusScope focus recovery (mirrors ViewerWindow's focus-pages() rule).
    public function focus-self() { fs.focus(); }

    // ── Cover-flow geometry (local tunables; colors/spacing come from Theme) ──
    // Covers are laid out centered on `focused-index`; each cover's horizontal
    // offset from the focused one drives its position, scale, and opacity.
    private property <length> cover-w: 200px;          // focused cover width
    private property <length> cover-h: 280px;          // focused cover height (≈7:10 manga cover)
    private property <length> cover-gap: Theme.space-lg; // 14px inter-cover gap (DESIGN.md)
    private property <float> neighbor-scale: 0.78;     // side covers shrink
    private property <float> neighbor-opacity: 0.45;   // DESIGN.md components.cover.sideOpacity
    // Step between adjacent cover centers (focused width * a tightening factor
    // so neighbors tuck partly behind — the cover-flow overlap).
    private property <length> cover-step: root.cover-w * 0.62 + root.cover-gap;
    private property <length> ring-width: 3px;         // DESIGN.md cover.focusOutline 3px

    // ── Stage background: stage-top -> canvas vertical gradient (DESIGN.md
    //    "Layout / Two screens"; Slint uses @linear-gradient, not radial). ─────
    background: transparent;
    Rectangle {
        width: 100%;
        height: 100%;
        background: @linear-gradient(180deg, Theme.stage-top 0%, Theme.canvas 100%);
    }

    // ── Keyboard seams ──────────────────────────────────────────────────────
    // The carousel is the focused screen on the Library route, so it owns key
    // input here. Left/Right move focus, Return opens the focused book, Down
    // returns to the currently-open book. Up is a no-op in the Library: the
    // carousel's FocusScope rejects it and no ancestor handles it. In the
    // Viewer screen, ViewerWindow's own FocusScope catches Up and fires
    // GoToLibrary.
    fs := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.LeftArrow) { root.move(-1); return accept; }
            if (event.text == Key.RightArrow) { root.move(1); return accept; }
            if (event.text == Key.Return) { root.open(root.focused-index); return accept; }
            if (event.text == Key.DownArrow) { root.back(); return accept; }
            return reject;
        }

          // ── Empty state (0 books): the picker call-to-action (DESIGN.md
          //    "Empty Library"). PR-L wires the CTA to the rfd picker; here it is
          //    the same non-interactive placeholder PR-0b shipped. ───────────────
          if root.items.length == 0 : Rectangle {
              width: 360px;
              height: 200px;
              x: (parent.width - self.width) / 2;
              y: (parent.height - self.height) / 2;
              background: Theme.surface-sunken;
              border-radius: Theme.radius-lg;
              border-width: 1px;
              border-color: Theme.hairline;
              VerticalLayout {
                  alignment: center;
                  spacing: Theme.space-md;
                  padding: Theme.space-xl;
                  Text {
                      text: "Your library is empty";
                      color: Theme.text;
                      font-size: Theme.font-title;
                      font-weight: 700;
                      horizontal-alignment: center;
                  }
                  Text {
                      text: "Add books to start your shelf.";
                      color: Theme.text-muted;
                      font-size: Theme.font-micro;
                      horizontal-alignment: center;
                  }
                  Rectangle {
                      height: 34px;
                      background: Theme.accent;
                      border-radius: Theme.radius-md;
                      Text {
                          text: "Select folders / files to add";
                          color: Theme.text;
                          font-size: Theme.font-label;
                          font-weight: 500;
                          horizontal-alignment: center;
                          vertical-alignment: center;
                      }
                  }
              }
          }

          // ── Cover-flow row (>= 1 book) ───────────────────────────────────────
          if root.items.length > 0 : Rectangle {
              width: 100%;
              height: 100%;

              // Vertical anchor for the cover row (leaves room for the meta block
              // below). Covers are centered horizontally on focused-index.
              property <length> row-cy: parent.height / 2 - 28px;

              for item[idx] in root.items : Rectangle {
                  // Signed distance from the focused cover (… -2 -1 0 +1 +2 …).
                  property <int> delta: idx - root.focused-index;
                  property <bool> focused: self.delta == 0;
                  // Horizontal center: focused at parent center, neighbors stepped.
                  x: parent.width / 2 + self.delta * root.cover-step - self.width / 2;
                  y: parent.row-cy - self.height / 2;
                  width: self.focused ? root.cover-w : root.cover-w * root.neighbor-scale;
                  height: self.focused ? root.cover-h : root.cover-h * root.neighbor-scale;
                  opacity: self.focused ? 1.0 : root.neighbor-opacity;

                  // The cover card: rounded, card shadow, accent focus ring.
                  cover := Rectangle {
                      width: 100%;
                      height: 100%;
                      border-radius: Theme.radius-sm;               // DESIGN.md covers 6px
                      background: Theme.surface-raised;             // placeholder backing
                      drop-shadow-blur: 22px;                       // DESIGN.md elevation.card
                      drop-shadow-color: Theme.shadow-card;
                      // Focus ring: 3px accent outline on the focused cover only.
                      border-width: parent.focused ? root.ring-width : 0px;
                      border-color: Theme.accent;

                      // Cover image (placeholder until PR-V streams real covers).
                      if item.available : Image {
                          x: 0; y: 0; width: 100%; height: 100%;
                          source: item.cover;
                          image-fit: contain;
                          // Neighbor recede is carried by the item's `opacity: 0.45`
                          // (set on the parent for-row Rectangle); a per-Image
                          // `colorize` is not used here (the cover Rectangle is not
                          // a focus-bearing element).
                      }

                      // ── Unavailable: grayed card + broken-cover glyph ──────────
                      if !item.available : Rectangle {
                          x: 0; y: 0; width: 100%; height: 100%;
                          border-radius: Theme.radius-sm;
                          background: Theme.surface-sunken;
                          Text {
                              width: 100%; height: 100%;
                              text: "⛌";
                              color: Theme.text-faint;
                              font-size: 48px;
                              horizontal-alignment: center;
                              vertical-alignment: center;
                          }
                      }
                  }

                  // ── Per-cover progress bar (under every cover) ────────────────
                  Rectangle {
                      x: 0;
                      y: parent.height + Theme.space-xs;
                      width: parent.width;
                      height: 4px;
                      border-radius: 2px;
                      background: Theme.track-prog;
                      Rectangle {
                          x: 0; y: 0;
                          width: parent.width * Math.clamp(item.progress, 0.0, 1.0);
                          height: 100%;
                          border-radius: 2px;
                          background: item.progress >= 1.0 ? Theme.success : Theme.accent;
                      }
                  }
              }

              // ── Focused-book meta block (centered, below the cover row) ───────
              if root.focused-index >= 0 && root.focused-index < root.items.length : VerticalLayout {
                  x: (parent.width - self.width) / 2;
                  y: parent.height / 2 + root.cover-h / 2 - 8px;
                  width: 320px;
                  spacing: Theme.space-xs;
                  alignment: start;

                  Text {
                      text: root.items[root.focused-index].title;
                      color: Theme.text;
                      font-size: Theme.font-title;
                      font-weight: 700;
                      horizontal-alignment: center;
                      overflow: elide;
                  }
                  Text {
                      // 1-based "current / total" (total is 0 until the book is
                      // opened; PR-V/PR-R supply the real count).
                      text: root.items[root.focused-index].current + " / " + root.items[root.focused-index].total;
                      color: Theme.text-muted;
                      font-size: Theme.font-label;
                      horizontal-alignment: center;
                  }
                  Rectangle {
                      height: 4px;
                      border-radius: 2px;
                      background: Theme.track-prog;
                      Rectangle {
                          x: 0; y: 0;
                          width: parent.width * Math.clamp(root.items[root.focused-index].progress, 0.0, 1.0);
                          height: 100%;
                          border-radius: 2px;
                          background: root.items[root.focused-index].progress >= 1.0 ? Theme.success : Theme.accent;
                      }
                  }
              }
          }
    }
}
