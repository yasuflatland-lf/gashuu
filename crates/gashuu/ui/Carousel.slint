// Library cover-flow carousel.
//
// Renders a full cover-flow row built from the `Library` model: a centered
// focused cover (accent ring), dimmed neighbors, a per-cover progress bar, a
// centered focused-book meta block, and a grayed broken-cover placeholder for
// unavailable books. Falls back to an empty-state CTA when there are 0 books.
// PR-L added the always-visible "Add files… / Add folder…" toolbar and wired
// the empty-state CTA to the folder/file picker (via add-files()).
//
// The public contract — the `CarouselItem` struct, the `Carousel` component,
// its `items`/`focused-index` properties, the `open(int)`/`move(int)`/`back()`
// callbacks (plus PR-L's `add-files()`/`add-folder()`), and `focus-self()` —
// is frozen and MUST NOT change here. PR-V streams real cover images into the
// model (covers are placeholders until then).
//
// Focus: the component owns its own FocusScope. `focus-self()` restores
// keyboard focus to it (the carousel counterpart of ViewerWindow's
// `focus-pages()` recovery rule).
//
// Styling references `Theme.*` tokens only — NO inline brand hex (DESIGN.md).
// Key seams (handled in the FocusScope): Left/Right -> move(-1/+1),
// Return -> open(focused-index), Down -> back().
import { Button } from "std-widgets.slint";
import { Theme } from "Theme.slint";
// Shared design-system components (P2 componentization, issue #71): the
// reading-progress bar, the empty-state primary CTA button, and the shared
// thumbnail cell used by all three thumbnail surfaces (page strip / scrubber
// preview / library covers). The local private ProgressBar was deleted in
// favor of the extracted components/ProgressBar.slint (move-only: same body).
import { ProgressBar } from "components/ProgressBar.slint";
import { PrimaryButton } from "components/PrimaryButton.slint";
import { ThumbnailCell } from "components/ThumbnailCell.slint";

// Frozen by PR-0b; populated by PR-C (covers via PR-V). One book in the shelf.
export struct CarouselItem {
    cover: image,
    title: string,
    current: int,     // 1-based current page for display (= 0-based index + 1)
    total: int,
    progress: float,  // 0.0 .. 1.0
    available: bool,
}

export component Carousel inherits Rectangle {
    // ── Frozen public contract ────────────────────────────────────────────────
    in property <[CarouselItem]> items;
    in-out property <int> focused-index;
    callback open(int);       // index — Return on the focused book
    callback move(int);       // delta (-1 / +1) — Left / Right
    callback back();          // Down — return to the currently-open book
    callback add-files();     // opens a file picker (rfd); wired to on_add_files in main.rs
    callback add-folder();    // opens a folder picker (rfd); wired to on_add_folder in main.rs

    // FocusScope focus recovery (mirrors ViewerWindow's focus-pages() rule).
    public function focus-self() { fs.focus(); }

    // ── Cover-flow geometry (local tunables; colors/spacing come from Theme) ──
    // Covers are laid out centered on `focused-index`; each cover's horizontal
    // offset from the focused one drives its position, scale, and opacity.
    //
    // RESPONSIVE (DESIGN.md "Responsive Behavior / Carousel"): the focused cover
    // width tracks the live window width instead of a fixed 200px. It scales as a
    // fraction of `root.width`, clamped to a usable band so it never collapses on
    // a narrow window nor balloons on an ultra-wide one. The 7:10 manga aspect is
    // preserved by deriving `cover-h` from `cover-w`. `cover-step` is recomputed
    // from the live `cover-w` so neighbor spacing follows the focused size.
    private property <length> cover-w: Math.clamp(root.width * 0.26, 140px, 240px); // focused cover width (responsive)
    private property <length> cover-h: root.cover-w * 1.4;  // 7:10 manga cover aspect (280/200 = 1.4)
    private property <length> cover-gap: Theme.space-lg; // 14px inter-cover gap (DESIGN.md)
    private property <float> neighbor-scale: 0.78;     // side covers shrink
    private property <float> neighbor-opacity: 0.45;   // DESIGN.md components.cover.sideOpacity
    // Step between adjacent cover centers (focused width * a tightening factor
    // so neighbors tuck partly behind — the cover-flow overlap).
    private property <length> cover-step: root.cover-w * 0.62 + root.cover-gap;
    private property <length> ring-width: 3px;         // DESIGN.md cover.focusOutline 3px
    // Neighbor-drop threshold (DESIGN.md: "Below a minimum width, neighbors may
    // drop to one per side."). Above the threshold the cover-flow renders all
    // model items; at/below it, only the focused cover ± one neighbor are shown.
    private property <length> narrow-threshold: 560px;
    private property <bool> narrow: root.width <= root.narrow-threshold;

    // ── Stage background: stage-top -> canvas vertical gradient (DESIGN.md
    //    "Layout / Two screens"; Slint uses @linear-gradient, not radial). ─────
    background: transparent;
    Rectangle {
        width: 100%;
        height: 100%;
        background: @linear-gradient(180deg, Theme.stage-top 0%, Theme.canvas 100%);
    }

    // ── Toolbar: "Add files…" / "Add folder…" ────────────────────────────────
    // Always-visible strip at the top of the carousel. Clicking either button fires
    // the matching callback (wired to the rfd file/folder pickers in main.rs), then
    // restores keyboard focus to the carousel's FocusScope.
    HorizontalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        height: 40px;
        alignment: start;
        spacing: Theme.space-sm;
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        padding-top: Theme.space-xs;
        padding-bottom: Theme.space-xs;

        Button {
            text: "Add files…";
            clicked => { root.add-files(); root.focus-self(); }
        }
        Button {
            text: "Add folder…";
            clicked => { root.add-folder(); root.focus-self(); }
        }
    }

    // ── Keyboard seams ──────────────────────────────────────────────────────
    // The carousel is the focused screen on the Library route, so it owns key
    // input here. Left/Right move focus, Return opens the focused book, Down
    // returns to the currently-open book. Up is a no-op in the Library: the
    // carousel's FocusScope rejects it and no ancestor handles it. In the
    // Viewer screen, ViewerWindow's own FocusScope catches Up and fires
    // GoToLibrary.
    fs := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.LeftArrow) { root.move(-1); return accept; }
            if (event.text == Key.RightArrow) { root.move(1); return accept; }
            if (event.text == Key.Return) { root.open(root.focused-index); return accept; }
            if (event.text == Key.DownArrow) { root.back(); return accept; }
            return reject;
        }

          // ── Empty state (0 books): the picker call-to-action (DESIGN.md
          //    "Empty Library"). The CTA button fires add-files() via a TouchArea
          //    (wired in PR-L) and restores keyboard focus to the carousel. ──────
          if root.items.length == 0 : Rectangle {
              // Fluid panel width (DESIGN.md "Responsive Behavior"): clamp the
              // sunken empty-state panel to the carousel width so it never clips
              // on a narrow window nor stretches too wide on a large one.
              width: Math.clamp(parent.width - 2 * Theme.space-xl, 280px, 360px);
              height: 200px;
              x: (parent.width - self.width) / 2;
              y: (parent.height - self.height) / 2;
              background: Theme.surface-sunken;
              border-radius: Theme.radius-lg;
              border-width: 1px;
              border-color: Theme.hairline;
              VerticalLayout {
                  alignment: center;
                  spacing: Theme.space-md;
                  padding: Theme.space-xl;
                  Text {
                      text: "Your library is empty";
                      color: Theme.text;
                      font-size: Theme.font-title;
                      font-weight: Theme.weight-bold;
                      horizontal-alignment: center;
                  }
                  Text {
                      text: "Add books to start your shelf.";
                      color: Theme.text-muted;
                      font-size: Theme.font-micro;
                      horizontal-alignment: center;
                  }
                  // CTA button: fires add-files() on click and restores keyboard
                  // focus to the carousel. The hand-built accent Rectangle was
                  // replaced by the shared PrimaryButton (DESIGN.md
                  // components.button-primary): same accent background, same label
                  // wording, same Theme.radius-md corners, ≥32px hit area.
                  HorizontalLayout {
                      alignment: center;
                      PrimaryButton {
                          text: "Select folders / files to add";
                          clicked => { root.add-files(); root.focus-self(); }
                      }
                  }
              }
          }

          // ── Cover-flow row (>= 1 book) ───────────────────────────────────────
          if root.items.length > 0 : Rectangle {
              width: 100%;
              height: 100%;

              // Vertical anchor for the cover row (leaves room for the meta block
              // below). Covers are centered horizontally on focused-index.
              property <length> row-cy: parent.height / 2 - 28px;

              for item[idx] in root.items : Rectangle {
                  // Signed distance from the focused cover (… -2 -1 0 +1 +2 …).
                  property <int> delta: idx - root.focused-index;
                  property <bool> focused: self.delta == 0;
                  // Horizontal center: focused at parent center, neighbors stepped.
                  x: parent.width / 2 + self.delta * root.cover-step - self.width / 2;
                  y: parent.row-cy - self.height / 2;
                  width: self.focused ? root.cover-w : root.cover-w * root.neighbor-scale;
                  height: self.focused ? root.cover-h : root.cover-h * root.neighbor-scale;
                  opacity: self.focused ? 1.0 : root.neighbor-opacity;
                  // Neighbor-drop on narrow windows (DESIGN.md "Responsive
                  // Behavior / Carousel"): below the threshold only the focused
                  // cover ± one neighbor stay visible; the rest are hidden (kept
                  // instantiated, just not drawn). Wide windows show all items.
                  visible: !root.narrow || Math.abs(self.delta) <= 1;
                  // Motion (P2): glide position/size/opacity on focus changes so a
                  // Left/Right move animates instead of snapping. ease-out feels
                  // settled at the end of the slide.
                  animate x, width, height, opacity {
                      duration: Theme.motion-standard;
                      easing: ease-out;
                  }

                  // The cover card: rounded, card shadow, accent focus ring.
                  cover := Rectangle {
                      width: 100%;
                      height: 100%;
                      border-radius: Theme.radius-sm;               // DESIGN.md covers 6px
                      background: Theme.surface-raised;             // placeholder backing
                      // Card shadow on the FOCUSED cover only (DESIGN.md
                      // elevation.card). Neighbors sit at 0.45 opacity and don't
                      // need a shadow — dropping it for them keeps the cover-flow
                      // GPU-cheap. `parent` here is the for-item Rectangle, which
                      // owns `focused` (exactly one level up).
                      drop-shadow-blur: parent.focused ? 22px : 0px;
                      drop-shadow-color: Theme.shadow-card;
                      // Focus ring: 3px accent outline on the focused cover only.
                      border-width: parent.focused ? root.ring-width : 0px;
                      border-color: Theme.accent;

                      // Cover image via the shared ThumbnailCell (DESIGN.md rule 6:
                      // one thumbnail treatment across page strip / scrubber / covers).
                      // Library covers round to Theme.radius-sm (6px). The accent
                      // focus ring is drawn by the surrounding `cover` Rectangle
                      // (DESIGN cover.focusOutline), so the cell stays
                      // `highlighted: false` to avoid a double ring (covers signal
                      // focus via scale + opacity + the card's own ring). The
                      // CarouselItem model has no loaded/failed fields; available
                      // covers are `loaded: true`. (Cover images are placeholders
                      // until PR-V streams real covers.)
                      if item.available : ThumbnailCell {
                          x: 0; y: 0; width: 100%; height: 100%;
                          radius: Theme.radius-sm;
                          source: item.cover;
                          loaded: true;
                          failed: false;
                          highlighted: false;
                      }

                      // ── Unavailable: grayed card + broken-cover glyph ──────────
                      if !item.available : Rectangle {
                          x: 0; y: 0; width: 100%; height: 100%;
                          border-radius: Theme.radius-sm;
                          background: Theme.surface-sunken;
                          Text {
                              width: 100%; height: 100%;
                              text: "⛌";
                              color: Theme.text-faint;
                              font-size: 48px;
                              horizontal-alignment: center;
                              vertical-alignment: center;
                          }
                      }
                  }

                  // ── Per-cover progress bar (under every cover) ────────────────
                  ProgressBar {
                      x: 0;
                      y: parent.height + Theme.space-xs;
                      width: parent.width;
                      progress: item.progress;
                  }
              }

              // ── Focused-book meta block (centered, below the cover row) ───────
              if root.focused-index >= 0 && root.focused-index < root.items.length : VerticalLayout {
                  x: (parent.width - self.width) / 2;
                  y: parent.height / 2 + root.cover-h / 2 - 8px;
                  width: 320px;
                  spacing: Theme.space-xs;
                  alignment: start;

                  Text {
                      text: root.items[root.focused-index].title;
                      color: Theme.text;
                      font-size: Theme.font-title;
                      font-weight: Theme.weight-bold;
                      horizontal-alignment: center;
                      overflow: elide;
                  }
                  Text {
                      // 1-based "current / total" (total is 0 until the book is
                      // opened; the real count is filled when a book's page source is resolved).
                      text: root.items[root.focused-index].current + " / " + root.items[root.focused-index].total;
                      color: Theme.text-muted;
                      font-size: Theme.font-label;
                      horizontal-alignment: center;
                  }
                  ProgressBar {
                      progress: root.items[root.focused-index].progress;
                  }
              }
          }
    }
}
