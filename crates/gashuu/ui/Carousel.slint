// Library cover-flow carousel.
//
// Renders a full cover-flow row built from the `Library` model: a centered
// focused cover (accent ring), dimmed neighbors, a per-cover progress bar, a
// centered focused-book meta block, and a grayed broken-cover placeholder for
// unavailable books. Falls back to an empty-state CTA when there are 0 books.
// PR-L added the always-visible "Add files… / Add folder…" toolbar and wired
// the empty-state CTA to the folder/file picker (via add-books(), né
// add-files() — renamed when macOS gained the combined files+folders panel).
//
// The public contract — the `CarouselItem` struct, the `Carousel` component,
// its `items`/`focused-index` properties, the `open(int)`/`move(int)`/`back()`
// callbacks (plus PR-L's `add-books()`/`add-folder()`), and `focus-self()` —
// is frozen and MUST NOT change here. PR-V streams real cover images into the
// model (covers are placeholders until then).
//
// Focus: the component owns its own FocusScope. `focus-self()` restores
// keyboard focus to it (the carousel counterpart of ViewerWindow's
// `focus-pages()` recovery rule).
//
// Styling references `Theme.*` tokens only — NO inline brand hex (DESIGN.md).
// Key seams (handled in the FocusScope): Left/Right -> move(-1/+1),
// Return -> open(focused-index), Down -> back(). Pointer seams: the left/right
// step zones fire the same move(-1/+1) one book per click, and a double-click
// on the CENTER strip (the zones' gap) fires the same open(int) with the
// cover's index (normal mode only — see the cover-flow row).
import { Theme } from "Theme.slint";
import { Strings } from "Strings.slint";
// Shared design-system components (P2 componentization, issue #71): the
// reading-progress bar, the empty-state primary CTA button, and the shared
// thumbnail cell used by all three thumbnail surfaces (page strip / scrubber
// preview / library covers). The local private ProgressBar was deleted in
// favor of the extracted components/ProgressBar.slint (move-only: same body).
import { ProgressBar } from "components/ProgressBar.slint";
import { PrimaryButton } from "components/PrimaryButton.slint";
import { ThumbnailCell } from "components/ThumbnailCell.slint";
import { NavBar } from "components/NavBar.slint";
import { SelectionBadge } from "components/SelectionBadge.slint";
import { BookmarkRibbon } from "components/BookmarkRibbon.slint";
import { SelectionToolbar } from "components/SelectionToolbar.slint";

// Frozen by PR-0b; populated by PR-C (covers via PR-V). One book in the shelf.
// `selected` (bulk-delete PR-2) marks the book as picked in selection mode, so
// the cover renders an accent check badge; populated from `LibrarySelectionState`
// in the carousel rebuild path and on every toggle.
// `bookmarked` (continue-reading) is true when this is the last-opened book;
// drives the BookmarkRibbon overlay on the cover card.
// `cover-failed` (issue 144) is true when the cover load failed permanently
// (unreadable archive / decode failure); the card renders the shared failed
// treatment so the user can tell "failed" from "still loading". Set by
// `CoverController` via `marshal_failed`; a model rebuild resets it to false.
export struct CarouselItem {
    cover: image,
    title: string,
    current: int,     // 1-based current page for display (= 0-based index + 1)
    total: int,
    progress: float,  // 0.0 .. 1.0
    available: bool,
    selected: bool,
    bookmarked: bool, // true = last-opened book; shows the BookmarkRibbon overlay
    cover-failed: bool, // true = cover load failed; shows the failed treatment
    cover-loaded: bool, // true = cover image arrived from CoverController (not yet = loading placeholder)
}

// File-private cover-flow card: de-duplicates the per-cover card so the
// two z-order passes in `Carousel` can share ONE body (DESIGN.md covers; the
// patterns.md "shared PRIVATE sub-component within one file" tool). NOT exported,
// so the frozen public contract is untouched.
//
// Why two passes instead of `z`: Slint 1.16.1 cannot set per-Repeater-item z
// (docs/patterns.md), so the centered cover is layered on top purely by DRAW
// ORDER. Pass 1 is the always-on BACKING layer (`show: true`, every book);
// pass 2, declared AFTER pass 1, redraws ONLY the centered card on top so it
// wins z-order. This prevents a fast Left/Right sweep from toggling a
// passed-through book's only instance off-then-on (which blanked its cover for
// one frame — the "gap-toothed" bug). Both passes bind identical geometry —
// pure functions of the same `flow-position` scalar (see the cover-flow row) —
// so the pass hand-off lands at matching positions with no pop.
component CoverCard inherits Rectangle {
    // Layer gate + per-card state (all driven by the enclosing `for`).
    in property <bool> show;       // this pass should draw this card
    in property <bool> centered;   // idx == round(flow-position): the card at the VISUAL center; ring + shadow
    // Only the pass-2 TOP copy of the centered card paints the drop-shadow; the
    // pass-1 backing copy sets `elevated: false` so the centered book's
    // semi-transparent shadow (Theme.shadow-card) is not composited
    // twice (which would darken it). Neighbors never carry a shadow regardless
    // (gated by `centered`).
    in property <bool> elevated: true;
    in property <float> flow-delta; // idx - flow-position: signed FLOAT distance from the visual center
    // Geometry tunables, forwarded from the Carousel root.
    in property <length> cover-w;
    in property <length> cover-h;
    in property <length> cover-step;
    in property <float> neighbor-scale;
    in property <float> neighbor-opacity;
    in property <length> ring-width;
    // Enclosing cover-flow row geometry. A component ROOT cannot read `parent`
    // (the parent is unknown until instantiation), so the row's width and vertical
    // anchor are passed in by each `for` (which CAN read `parent` at its call site).
    in property <length> row-width;
    in property <length> row-cy;
    // Item data.
    in property <image> cover-source;
    in property <bool> available;
    in property <float> progress;
    // Cover load failed permanently (issue 144): drives the shared failed
    // treatment on the ThumbnailCell below. Only meaningful while `available`
    // is true — an unavailable book renders its own distinct broken-cover
    // treatment regardless (the two states stay visually separate).
    in property <bool> cover-failed;
    // true once CoverController streams in a real image. Starts false so the
    // neutral loading placeholder is shown instead of a black default image.
    in property <bool> cover-loaded;
    // Bulk-selection (PR-2). `selected` draws the accent check badge;
    // `selection-mode` is forwarded for future selection-only chrome. `interactive`
    // gates the cover TouchArea so only the pass-1 backing copy fires the click
    // (the pass-2 top copy of the centered card sets it false — see the two for-loops).
    in property <bool> selected;
    in property <bool> selection-mode;
    in property <bool> interactive;
    // Continue-reading (BookmarkRibbon). True when this is the last-opened book;
    // renders a ribbon at the top-left of the cover, independent of `available`.
    in property <bool> bookmarked;
    callback clicked;
    // Double-click on the cover (pass-1 only, via the same `cover-touch`
    // gating as `clicked`). The Carousel decides what it means (open in
    // normal mode, nothing in selection mode) — CoverCard stays presentational.
    callback double-clicked;

    // Position/size/opacity: every value below is a PURE function of `flow-delta`
    // — the card carries NO `animate` blocks. The cover-flow row animates ONE
    // scalar (`flow-position`) and each card merely tracks it, so rapid
    // Left/Right input retargets a single animation instead of restarting N
    // per-card 480ms timers (the old per-card `animate x` left the center slot
    // empty during a fast sweep — docs/patterns.md "animation altitude").
    x: root.row-width / 2 + root.flow-delta * root.cover-step - self.width / 2;
    y: root.row-cy - self.height / 2;
    // Size/opacity interpolate CONTINUOUSLY with the float distance from the
    // visual center: full size/opacity at d == 0, neighbor scale/opacity from
    // d >= 1 outward (the clamp floor). `scale-factor` single-sources the size
    // interpolation (the Scrubber's named-derived-value style); opacity keeps
    // its own clamp because its floor is `neighbor-opacity`, not the scale.
    // Because `width` is slaved to the same scalar as `x`, the x formula's
    // `self.width / 2` term no longer chases a mid-animation width (the old
    // second-order lag).
    private property <float> scale-factor: Math.clamp(
        1.0 - Math.abs(root.flow-delta) * (1.0 - root.neighbor-scale),
        root.neighbor-scale, 1.0);
    width: root.cover-w * root.scale-factor;
    height: root.cover-h * root.scale-factor;
    // Opacity holds FULL across the center half (|flow-delta| <= 0.5), then fades
    // linearly to `neighbor-opacity` out to the immediate-neighbor slot
    // (|flow-delta| == 1). The flat opaque plateau fixes the mid-move "the cover
    // BEHIND bleeds through the front book" artifact: the visually centered card is
    // `Math.round(flow-position)`, so its |flow-delta| never exceeds 0.5 — with the
    // plateau it now stays FULLY opaque for the whole slide and nothing shows
    // through it (the centered card is full-size and overlaps its neighbors on top,
    // so any sub-1.0 opacity used to reveal the overlapped neighbor). The plateau
    // edge is pinned to 0.5 — the round() center hand-off point — ON PURPOSE: at
    // the instant the visual center hands off from one card to the next, BOTH sit
    // at |flow-delta| == 0.5 where this curve equals exactly 1.0, so the hand-off
    // carries no opacity pop. The slope `2 * (1 - neighbor-opacity)` lands the fade
    // on `neighbor-opacity` at |flow-delta| == 1. At rest the look is unchanged:
    // centered d==0 -> 1.0, immediate neighbors d==±1 -> neighbor-opacity, farther
    // cards clamped to it.
    opacity: Math.clamp(
        1.0 - (Math.abs(root.flow-delta) - 0.5) * 2 * (1.0 - root.neighbor-opacity),
        root.neighbor-opacity, 1.0);
    // Layer gate only. Every loaded cover stays visible at EVERY window width
    // (user decision: the former narrow-window neighbor-drop hid all but the
    // centered cover ± one at/below 560px, which read as thumbnails vanishing on
    // resize and during moves). Cards past the window edge clip naturally.
    visible: root.show;

    // The cover card: rounded, card shadow on the centered cover only, accent ring.
    cover := Rectangle {
        width: 100%;
        height: 100%;
        border-radius: Theme.radius-sm;               // DESIGN.md covers 6px
        background: Theme.surface-raised;             // placeholder backing
        // Card shadow on the CENTERED cover only (DESIGN.md elevation.card).
        // Neighbors sit at 0.45 opacity and don't need one — dropping it keeps the
        // cover-flow GPU-cheap. Also gated on `elevated` so only the pass-2 top
        // copy paints it: the pass-1 backing copy of the centered book sets
        // `elevated: false`, else the semi-transparent shadow composites twice.
        drop-shadow-blur: (root.centered && root.elevated) ? 22px : 0px;
        drop-shadow-color: Theme.shadow-card;
        // Focus ring: 3px accent outline on the centered cover. In selection mode
        // ONLY, a non-centered cover also gets a thin 1px accent ring while hovered
        // (§2.4 selection-mode hover affordance) — a pointer hint that the cover is
        // a selectable target. `cover-touch` is the pass-1-only cover TouchArea
        // (enabled: root.interactive); since it is non-interactive on pass 2 it
        // reports no hover there, so the hover ring is single-source like the
        // click. Normal mode (selection-mode false) shows nothing on hover.
        border-width: root.centered ? root.ring-width : (root.selection-mode && cover-touch.has-hover ? 1px : 0px);
        border-color: Theme.accent;

        // Cover image via the shared ThumbnailCell (DESIGN.md rule 6: one
        // thumbnail treatment across page strip / scrubber / covers). The accent
        // focus ring is drawn by this `cover` Rectangle (DESIGN cover.focusOutline),
        // so the cell stays `highlighted: false` to avoid a double ring (covers
        // signal focus via scale + opacity + the card's own ring).
        // `cover-failed` (issue 144) flips the cell into its shared failed
        // treatment (error tint + glyph), so a permanently failed cover load is
        // visually separable from the loading placeholder; an un-failed row
        // keeps the streamed cover (or the placeholder backing while loading).
        if root.available : ThumbnailCell {
            x: 0; y: 0; width: 100%; height: 100%;
            radius: Theme.radius-sm;
            source: root.cover-source;
            loaded: root.cover-loaded;
            failed: root.cover-failed;
            failed-label: root.centered && root.cover-failed ? Strings.cover-failed-label : "";
            highlighted: false;
        }

        // Unavailable: grayed card + broken-cover glyph.
        if !root.available : Rectangle {
            x: 0; y: 0; width: 100%; height: 100%;
            border-radius: Theme.radius-sm;
            background: Theme.surface-sunken;
            Text {
                width: 100%; height: 100%;
                text: "⛌";
                color: Theme.text-faint;
                font-size: 48px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Bulk-selection check badge (PR-2; two-state §2.3). Rendered inside
        // `cover` so it sits on the artwork, pinned to the top-right with a small
        // inset. Drawn in BOTH z-order passes (pass-2's centered copy paints over
        // pass-1, so the badge must live on both or it would vanish on the centered
        // card) — this block is the shared CoverCard body, so both passes get it.
        // Gated on `selection-mode` (not `selected`) so EVERY cover shows a badge
        // while selecting; `checked` then renders the filled (selected) disc or the
        // hollow (unselected) ring. Accent disc + white check — RED stays reserved
        // for the PR-5 delete button.
        if root.selection-mode : SelectionBadge {
            checked: root.selected;
            x: parent.width - self.width - Theme.space-xs;
            y: Theme.space-xs;
        }

        // Continue-reading ribbon (BookmarkRibbon). CARD-EXTERNAL PROTRUSION: the
        // ribbon floats FULLY CLEAR of the cover's top edge (negative y, zero
        // overlap — user decision after a visual check superseded the earlier
        // tucked-in placement). Same protrusion family as the ProgressBar that
        // renders below the cover at `y: parent.height + …`; no ancestor clips
        // this region, so a negative y is safe.
        // Clearance = Theme.space-md (10 px) ≈ ribbon height / φ²
        // (26 / 2.618 ≈ 9.9) — the same φ² derivation the nav-search-radius
        // token documents, on the repo's Fibonacci/φ sizing ladder.
        // The area above the cover is covered by the dark stage gradient, so the
        // white glyph keeps contrast regardless of cover art — the reason the
        // ribbon sits outside the card.
        // TOP-LEFT placement does NOT conflict with SelectionBadge's top-right
        // corner: both render simultaneously when a bookmarked book is also
        // selected (edge case 5).
        // Rendered regardless of `available` — a file-gone book still shows its
        // "continue reading" status (edge case 4).
        if root.bookmarked : BookmarkRibbon {
            x: Theme.space-xs;
            y: -self.height - Theme.space-md;
        }
    }

    // Per-cover progress bar (under the cover). `parent` is this CoverCard.
    ProgressBar {
        x: 0;
        y: parent.height + Theme.space-xs;
        width: parent.width;
        progress: root.progress;
    }

    // ── Cover click target (PR-2 — the repo's FIRST cover pointer interaction) ──
    // An INVISIBLE click rectangle (NOT the shrunken artwork), pinned centered on
    // the card. Width = max(cover-step, card width):
    //   - NEIGHBOR cards (width == cover-w * neighbor-scale at rest): cover-step wins,
    //     so a shrunken side cover is still a comfortable `cover-step`-wide click target.
    //   - CENTERED card (width == cover-w at rest): the card width wins, so the WHOLE
    //     centered cover is clickable — including the selection badge pinned to its
    //     top-right corner. A bare `cover-step`-wide target (cover-step < cover-w)
    //     left the badge in a dead zone, so clicking it in selection mode toggled
    //     nothing; the always-visible selection-mode rings then advertised a target
    //     the centered cover's hit-area never reached (badge inset + space-xs all sit
    //     right of a cover-step-wide centered target). Math.max fixes that without
    //     shrinking the deliberate neighbor target.
    // `enabled: root.interactive` ensures ONLY the pass-1 backing copy fires
    // (pass-2's centered copy passes `interactive: false`, so a click on the centered
    // card is handled exactly once — see the two for-loops in Carousel). The
    // TouchArea is non-focusable (repo convention, see NavItem / docs/patterns.md
    // "TouchArea click focus recovery"), so keyboard focus stays on the carousel
    // FocusScope; handlers/library.rs restores carousel focus after handling.
    cover-touch := TouchArea {
        enabled: root.interactive;
        width: Math.max(root.cover-step, parent.width);
        height: parent.height;
        x: (parent.width - self.width) / 2;
        y: 0;
        clicked => { root.clicked(); }
        // Slint fires `clicked` on EVERY click and `double-clicked` IN ADDITION
        // on the second (vendored i-slint-core 1.16.1 input_items.rs: clicked
        // always, then double_clicked when click_count % 2 == 1) — so a
        // double-click is focus, focus, open in normal mode.
        double-clicked => { root.double-clicked(); }
    }
}

export component Carousel inherits Rectangle {
    // ── Frozen public contract ────────────────────────────────────────────────
    in property <[CarouselItem]> items;
    in-out property <int> focused-index;
    callback open(int);       // index — Return on the focused book, or a cover double-click
    callback move(int);       // delta (-1 / +1) — Left / Right
    callback back();          // Down — return to the currently-open book
    callback add-books();     // opens the add picker (rfd); wired to on_add_books in handlers/library.rs
    callback add-folder();    // opens a folder picker (rfd); wired to on_add_folder in handlers/library.rs
    // True when one native dialog picks files AND folders (macOS): the NavBar
    // shows a single combined add capsule. Pushed once from Rust at boot.
    in property <bool> combined-add-picker;

    // ── Library search seams (issue #88) ──────────────────────────────────────
    // `search-query` mirrors the NavBar field; `library-book-count` is the TOTAL
    // book count (independent of the active filter) so the empty-library CTA and
    // the no-results state can be told apart. `search-changed` carries the
    // debounced query to Rust. `settings` bubbles the glass-pill Settings click
    // up to ViewerWindow, which routes it into the existing `open-settings` flow
    // (`on_open_settings` in handlers/settings.rs) — the SAME SettingsDialog reached from the
    // Viewer's TitleBar "Settings…" button. The dialog overlays the Library
    // carousel; closing it returns keyboard focus to the carousel.
    in-out property <string> search-query;
    in property <int> library-book-count;
    callback search-changed(string);
    callback settings();
    // The NavBar bookmark capsule: jump to the continue-reading book (resume at
    // its saved page) when one exists, else surface a no-bookmark status notice.
    // Bubbles up to ViewerWindow (and handlers/library.rs) the same way `settings` does.
    callback continue-reading();
    // True while a modal overlay (settings / shortcuts) is open over the
    // Library. The carousel still holds keyboard focus, so its FocusScope must
    // suppress all key arms — otherwise Left/Right, `/`, Down, and Return would
    // act on the carousel underneath the modal (mirrors the Viewer FocusScope
    // guard in ViewerWindow.slint). Bound by ViewerWindow to the same condition.
    in property <bool> modal-open;

    // ── Bulk-selection seams (bulk-delete epic, PR-2) ─────────────────────────
    // `selection-mode` tracks whether the carousel is in selection mode (entered
    // by `x`, exited by Esc). It is `in-out` so the key arms below flip it locally
    // AND ViewerWindow/Rust can observe/reset it. `toggle-selection(int)` toggles
    // the focused book's membership (keyboard `x`/Space); `cover-clicked(int)` is
    // the pointer entry (a cover TouchArea click). `exit-selection()` clears the
    // selection and leaves the mode (Esc). All three are forwarded through
    // ViewerWindow to handlers/library.rs (mirrors the open/move/back forwarding).
    in-out property <bool> selection-mode;
    callback toggle-selection(int);   // visible carousel index to toggle
    callback cover-clicked(int);      // visible carousel index whose cover was clicked
    callback exit-selection();        // Esc: clear selection + leave selection mode
    // ── SelectionToolbar seams (bulk-delete epic, PR-4) ───────────────────────
    // `selection-count-text` is the pre-composed count label from Rust (e.g.
    // "3 selected" or "5 selected (2 outside search)"); `select-all-label` flips between the "Select all"/"Deselect
    // all" wording. `select-all()` fires from BOTH the toolbar button and the
    // Cmd/Ctrl+A key arm (Rust decides select-vs-deselect). All three are forwarded
    // through ViewerWindow to handlers/library.rs (mirrors the PR-2 seams above).
    in property <string> selection-count-text;
    in property <string> select-all-label;
    callback select-all();
    // ── Delete seams (bulk-delete epic, PR-5) ─────────────────────────────────
    // `delete-label` is the pre-composed destructive label from Rust (e.g.
    // "Delete (3)…"); `has-selection` gates the toolbar DangerButton. Both fire
    // the SAME `request-delete()` action: the toolbar button and the
    // Delete/Backspace key arm below. Forwarded through ViewerWindow to handlers/library.rs
    // (mirrors the PR-4 seams above), which opens the ConfirmDialog.
    in property <string> delete-label;
    in property <bool> has-selection;
    callback request-delete();

    // Move keyboard focus into the NavBar search field (carousel `/` and click).
    public function focus-search() { nav.focus-search(); }

    // FocusScope focus recovery (mirrors ViewerWindow's focus-pages() rule).
    public function focus-self() { fs.focus(); }

    // ── Cover-flow geometry (local tunables; colors/spacing come from Theme) ──
    // Covers are laid out centered on `flow-position` (the animated float that
    // chases `focused-index`; see the cover-flow row); each cover's float
    // distance from the visual center drives its position, scale, and opacity.
    //
    // RESPONSIVE (DESIGN.md "Responsive Behavior / Carousel"): the centered cover
    // width tracks the live window width instead of a fixed 200px. It scales as a
    // fraction of `root.width`, clamped to a usable band so it never collapses on
    // a narrow window nor balloons on an ultra-wide one. The 7:10 manga aspect is
    // preserved by deriving `cover-h` from `cover-w`. `cover-step` is recomputed
    // from the live `cover-w` so neighbor spacing follows the centered size.
    private property <length> cover-w: Math.clamp(root.width * 0.26, 140px, 240px); // centered cover width (responsive)
    private property <length> cover-h: root.cover-w * 1.4;  // 7:10 manga cover aspect (280/200 = 1.4)
    private property <length> cover-margin: 4px;       // visible gap between two side (neighbor) covers
    private property <float> neighbor-scale: 0.618;    // side covers shrink to 1/φ (centered : neighbor = φ : 1)
    private property <float> neighbor-opacity: 0.45;   // DESIGN.md components.cover.sideOpacity
    // Step between adjacent cover centers. Sized so two SIDE covers (each at
    // `neighbor-scale`) clear each other by exactly `cover-margin` — that is the
    // boundary the eye reads as "books overlapping" in the cover row. Step =
    // one neighbor's full width + the gap. The centered cover is full-size, so it
    // still overlaps its immediate neighbors and is drawn on top (z-order pass 2),
    // preserving the cover-flow depth; only the side-to-side overlap is removed.
    private property <length> cover-step: root.cover-w * root.neighbor-scale + root.cover-margin;
    private property <length> ring-width: 3px;         // DESIGN.md cover.focusOutline 3px
    // Narrow-window breakpoint. Drives ONLY the SelectionToolbar's icon-only
    // select-all collapse (DESIGN.md selectAllNarrowBreakpoint). The cover-flow
    // itself renders every model item at every width: the former neighbor-drop
    // (centered cover ± one at/below this threshold) was removed by user
    // decision so loaded covers never vanish on resize or during moves.
    private property <length> narrow-threshold: 560px;
    private property <bool> narrow: root.width <= root.narrow-threshold;

    // ── Stage background: stage-top -> canvas vertical gradient (DESIGN.md
    //    "Layout / Two screens"; Slint uses @linear-gradient, not radial). ─────
    background: transparent;
    Rectangle {
        width: 100%;
        height: 100%;
        background: @linear-gradient(180deg, Theme.stage-top 0%, Theme.canvas 100%);
    }

    // ── Keyboard seams ──────────────────────────────────────────────────────
    // The carousel is the focused screen on the Library route, so it owns key
    // input here. Left/Right move focus, Return opens the focused book, Down
    // returns to the currently-open book. Up is a no-op in the Library: the
    // carousel's FocusScope rejects it and no ancestor handles it. In the
    // Viewer screen, ViewerWindow's own FocusScope catches Up and fires
    // GoToLibrary.
    fs := FocusScope {
        key-pressed(event) => {
            // Suppress background navigation while a modal overlay is open.
            if (root.modal-open) { return reject; }
            // ── Bulk-selection arms (PR-2). Placed AFTER the modal reject so
            //    modals keep priority; the existing arms below are untouched.
            //    Return deliberately stays "open" in BOTH modes (handled below).
            // `x` enters selection mode (from normal) and toggles the focused book;
            // in selection mode it just toggles. `Space` toggles only in selection
            // mode (normal-mode Space falls through / rejects as before).
            if (event.text == "x") {
                root.selection-mode = true;
                root.toggle-selection(root.focused-index);
                return accept;
            }
            if (root.selection-mode && event.text == " ") {
                root.toggle-selection(root.focused-index);
                return accept;
            }
            // Cmd/Ctrl+A — select/deselect all (selection mode only). The repo's
            // FIRST modifier-key arm. One action, two triggers: this and the
            // toolbar's Select-all button both fire root.select-all() (Rust decides
            // select-vs-deselect). Verified against the vendored winit backend
            // (i-slint-backend-winit-1.16.1/event_loop.rs to_slint_key): Slint's
            // `event.text` is built from winit's logical key (Key::Character => the
            // letter), NOT the control-character form, so Cmd/Ctrl+A delivers
            // event.text == "a" (lowercase) here, never "\u{1}". On macOS Slint maps
            // Cmd -> control and physical Ctrl -> meta (KeyboardModifiers doc), so
            // testing BOTH control || meta catches Cmd+A on macOS, Ctrl+A on
            // Windows/Linux, and physical Ctrl+A on macOS alike. Gated on
            // selection-mode so normal-mode Cmd/Ctrl+A falls through (reject); a
            // bare `a` (no modifier) never matches the modifier guard.
            if (root.selection-mode && (event.modifiers.control || event.modifiers.meta) && event.text == "a") {
                root.select-all();
                return accept;
            }
            // Delete / Backspace — the destructive arm (selection mode only). One
            // action, two triggers: this and the toolbar's DangerButton both fire
            // root.request-delete(); Rust opens the ConfirmDialog. We `accept` even
            // when nothing is selected (N=0): Rust no-ops on an empty set, and
            // accepting unconditionally keeps the key swallowed inside selection
            // mode rather than letting it leak to an ancestor handler. Both
            // Key.Delete (forward delete) and Key.Backspace are bound because the
            // two read identically as "remove the selected books" on the keyboards
            // that lack the other; both exist in Slint 1.16.1's Key namespace
            // (verified against the vendored i-slint-common key_codes.rs:
            // U+007F => Delete, U+0008 => Backspace).
            if (root.selection-mode && (event.text == Key.Delete || event.text == Key.Backspace)) {
                root.request-delete();
                return accept;
            }
            // Esc clears the selection and leaves selection mode (no-op / reject
            // when not in selection mode, so an ancestor could still handle Esc).
            if (event.text == Key.Escape) {
                if (root.selection-mode) {
                    root.selection-mode = false;
                    root.exit-selection();
                    return accept;
                }
                return reject;
            }
            // `/` focuses the search field — but ONLY while the carousel owns
            // focus. Once the search field has focus, `/` is ordinary text input
            // (this FocusScope no longer receives the key).
            if (event.text == "/") { root.focus-search(); return accept; }
            if (event.text == Key.LeftArrow) { root.move(-1); return accept; }
            if (event.text == Key.RightArrow) { root.move(1); return accept; }
            if (event.text == Key.Return) { root.open(root.focused-index); return accept; }
            if (event.text == Key.DownArrow) { root.back(); return accept; }
            return reject;
        }

          // ── Empty state (0 books in the LIBRARY): the picker call-to-action
          //    (DESIGN.md "Empty Library"). Gated on the total book count, NOT on
          //    the filtered `items` length, so an active search that hides every
          //    book shows the no-results panel below instead of this add CTA. The
          //    CTA button fires add-books() via a TouchArea (wired in PR-L) and
          //    restores keyboard focus to the carousel. ─────────────────────────
          if root.library-book-count == 0 : Rectangle {
              // Fluid panel width (DESIGN.md "Responsive Behavior"): clamp the
              // sunken empty-state panel to the carousel width so it never clips
              // on a narrow window nor stretches too wide on a large one.
              width: Math.clamp(parent.width - 2 * Theme.space-xl, 280px, 360px);
              height: 200px;
              x: Theme.snap((parent.width - self.width) / 2);
              y: Theme.snap((parent.height - self.height) / 2);
              background: Theme.surface-sunken;
              border-radius: Theme.radius-lg;
              border-width: 1px;
              border-color: Theme.hairline;
              VerticalLayout {
                  alignment: center;
                  spacing: Theme.space-md;
                  padding: Theme.space-xl;
                  Text {
                      text: Strings.carousel-empty-title;
                      color: Theme.text;
                      font-size: Theme.font-title;
                      font-weight: Theme.weight-bold;
                      horizontal-alignment: center;
                  }
                  Text {
                      text: Strings.carousel-empty-subtitle;
                      color: Theme.text-muted;
                      font-size: Theme.font-micro;
                      horizontal-alignment: center;
                  }
                  // CTA button: fires add-books() on click and restores keyboard
                  // focus to the carousel. The hand-built accent Rectangle was
                  // replaced by the shared PrimaryButton (DESIGN.md
                  // components.button-primary): same accent background, same label
                  // wording, same Theme.radius-md corners, ≥32px hit area.
                  HorizontalLayout {
                      alignment: center;
                      PrimaryButton {
                          // Wording tracks the dialog flavor behind add-books():
                          // combined files+folders on macOS, files-only elsewhere.
                          text: root.combined-add-picker
                              ? Strings.carousel-empty-cta
                              : Strings.carousel-empty-cta-files;
                          clicked => { root.add-books(); root.focus-self(); }
                      }
                  }
              }
          }

          // ── No-results state (library has books, filter matches none) ────────
          // Distinct from the empty-library CTA above: there ARE books, the
          // active search just hides them all. NO add CTA here — only guidance to
          // adjust the query. Uses Theme.* color tokens only.
          if root.library-book-count > 0 && root.items.length == 0 : Rectangle {
              width: Math.clamp(parent.width - 2 * Theme.space-xl, 280px, 360px);
              height: 160px;
              x: Theme.snap((parent.width - self.width) / 2);
              y: Theme.snap((parent.height - self.height) / 2);
              background: Theme.surface-sunken;
              border-radius: Theme.radius-lg;
              border-width: 1px;
              border-color: Theme.hairline;
              VerticalLayout {
                  alignment: center;
                  spacing: Theme.space-md;
                  padding: Theme.space-xl;
                  Text {
                      text: Strings.carousel-no-results-title;
                      color: Theme.text;
                      font-size: Theme.font-title;
                      font-weight: Theme.weight-bold;
                      horizontal-alignment: center;
                  }
                  Text {
                      text: Strings.carousel-no-results-hint;
                      color: Theme.text-muted;
                      font-size: Theme.font-micro;
                      horizontal-alignment: center;
                  }
              }
          }

          // ── Two-finger horizontal swipe → one-step book move ──────────────
          // Trackpad horizontal scroll (delta-x) steps the focus by one book,
          // reusing the SAME move(±1) the Left/Right keys fire. Discrete by
          // design (matches the codebase's keyboard-first model): accumulate
          // delta-x, and once |accum| crosses `swipe-threshold` fire ONE move,
          // then a cooldown Timer swallows the macOS momentum-phase tail so one
          // flick never flies through several books. This TouchArea is the
          // ANCESTOR of the cover + step-zone TouchAreas: neither has a
          // scroll-event handler, so scroll events fall through to this ancestor
          // while pointer clicks are still absorbed front-to-back by the
          // cover/zone, so this wrapper never steals a tap.
          //
          // GATED on `items.length > 0`: with zero visible books there is
          // nothing to swipe through, AND this full-size TouchArea is declared
          // AFTER (paints ABOVE) the empty-state / no-results panels — so left
          // ungated it would block clicks on the empty-state "add books" CTA
          // behind it (a TouchArea absorbs pointer events even with no `clicked`
          // arm; the cover/zone children that normally take the tap don't exist
          // when the library is empty). The gate matches the cover-flow row's,
          // which is now this TouchArea's only child.
          if root.items.length > 0 : TouchArea {
              width: 100%;
              height: 100%;
              property <length> swipe-threshold: 25px;   // lower = more sensitive
              property <float> swipe-accum: 0;
              property <bool> swipe-cooling: false;
              Timer {
                  interval: 100ms;   // shorter = higher top speed on a sustained swipe
                  running: parent.swipe-cooling;
                  triggered => { parent.swipe-cooling = false; }
              }
              scroll-event(e) => {
                  // Modals and selection mode own all input while active.
                  if (root.modal-open) { return reject; }
                  if (root.selection-mode) { return reject; }
                  // Dominant-axis gate (1.2x margin): near-horizontal only; a
                  // diagonal/vertical scroll is ignored (no ancestor handles it).
                  if (Math.abs(e.delta-x / 1px) <= Math.abs(e.delta-y / 1px) * 1.2) {
                      return reject;
                  }
                  if (self.swipe-cooling) { return accept; }
                  // Drop a reversed gesture's prior travel so two flicks never cancel.
                  if (e.delta-x / 1px * self.swipe-accum < 0) {
                      self.swipe-accum = 0;
                  }
                  self.swipe-accum += e.delta-x / 1px;
                  if (Math.abs(self.swipe-accum) >= self.swipe-threshold / 1px) {
                      root.move(self.swipe-accum > 0 ? 1 : -1);
                      self.swipe-accum = 0;
                      self.swipe-cooling = true;
                  }
                  return accept;
              }

          // ── Cover-flow row (>= 1 book) ───────────────────────────────────────
          // The parent swipe TouchArea is already gated on `items.length > 0`,
          // so this row exists only when there is at least one visible book.
          Rectangle {
              width: 100%;
              height: 100%;

              // Vertical anchor for the cover row (leaves room for the meta block
              // below). Covers are centered horizontally on flow-position.
              property <length> row-cy: parent.height / 2 - 28px;

              // ── Animation altitude: ONE animated scalar drives the whole row ──
              // `flow-position` chases `focused-index` (int -> float binding) on
              // the cinematic curve, and ALL card geometry derives from it as pure
              // bindings (see CoverCard) — no per-card animations. A retarget
              // mid-flight continues from the CURRENT animated value, so rapid
              // Left/Right input keeps the row moving as one coherent band instead
              // of leaving the center slot empty while N per-card timers restart.
              // The card at Math.round(flow-position) is the VISUAL center: pass-2
              // z-order, the accent ring, and the card shadow hand off card-by-card
              // during a sweep, while `focused-index` stays the LOGICAL truth (the
              // Return target and the meta block below). The easing never
              // overshoots (control-point y's within [0, 1]), so the round can
              // never land outside the Rust-clamped index range.
              property <float> flow-position: root.focused-index;
              animate flow-position {
                  duration: Theme.motion-cinematic;
                  easing: cubic-bezier(0.16, 1, 0.3, 1);
              }
              // The card index at the visual center — single-sources the
              // Math.round so the three pass bindings below cannot drift apart.
              property <int> visual-center: Math.round(self.flow-position);

              // ── Cover-flow z-order: two passes (Slint 1.16.1 has no per-item z) ─
              // Pass 1: backing layer, every book always visible (gap-toothed-bug fix).
              // Pass 2: the CENTERED card (round(flow-position)) redrawn on top;
              // shadow painted there only (elevated default).
              // See CoverCard header for full rationale.
              for item[idx] in root.items : CoverCard {
                  show: true;
                  elevated: false;
                  centered: idx == parent.visual-center;
                  flow-delta: idx - parent.flow-position;
                  cover-w: root.cover-w;
                  cover-h: root.cover-h;
                  cover-step: root.cover-step;
                  neighbor-scale: root.neighbor-scale;
                  neighbor-opacity: root.neighbor-opacity;
                  ring-width: root.ring-width;
                  row-width: parent.width;
                  row-cy: parent.row-cy;
                  cover-source: item.cover;
                  available: item.available;
                  progress: item.progress;
                  selected: item.selected;
                  selection-mode: root.selection-mode;
                  bookmarked: item.bookmarked;
                  cover-failed: item.cover-failed;
                  cover-loaded: item.cover-loaded;
                  // PR-2: ONLY the always-on pass-1 backing copy is click-interactive,
                  // so each cover (including the centered one, whose pass-2 copy below
                  // sets interactive:false) fires its TouchArea exactly once.
                  interactive: true;
                  clicked => { root.cover-clicked(idx); }
                  // Double-click opens the book, via the SAME `open(int)` path as
                  // Return (Rust resolves the visible index and enters the
                  // viewer). In NORMAL mode the step zones above intercept every
                  // side click, so this arm is only reachable on the CENTER strip
                  // — the visually centered cover. Gated off in selection mode:
                  // the two preceding `clicked` events have already toggled the
                  // book twice (net no-op), and opening would yank the user out
                  // of an in-progress selection.
                  double-clicked => { if (!root.selection-mode) { root.open(idx); } }
              }
              // Pass 2: centered card only, on top (elevated: true default → shadow painted once).
              // Any future additional render pass MUST also set interactive: false (single-fire invariant).
              for item[idx] in root.items : CoverCard {
                  show: idx == parent.visual-center;
                  centered: idx == parent.visual-center;
                  flow-delta: idx - parent.flow-position;
                  cover-w: root.cover-w;
                  cover-h: root.cover-h;
                  cover-step: root.cover-step;
                  neighbor-scale: root.neighbor-scale;
                  neighbor-opacity: root.neighbor-opacity;
                  ring-width: root.ring-width;
                  row-width: parent.width;
                  row-cy: parent.row-cy;
                  cover-source: item.cover;
                  available: item.available;
                  progress: item.progress;
                  selected: item.selected;
                  selection-mode: root.selection-mode;
                  bookmarked: item.bookmarked;
                  cover-failed: item.cover-failed;
                  cover-loaded: item.cover-loaded;
                  // PR-2: the pass-2 TOP copy of the centered card is NON-interactive
                  // so the centered cover does not double-fire — its click is handled
                  // by the pass-1 backing copy above (which is always shown).
                  interactive: false;
              }

              // ── Left/Right one-step zones (normal mode only) ──────────────────
              // Everything OUTSIDE the centered cover's non-overlapped strip (the
              // cover-step-wide tile around the row center) steps the focus by
              // exactly ONE book toward the clicked side, via the SAME frozen
              // move(int) the Left/Right keys use (Rust clamps). Declared AFTER
              // both card passes so they hit-test ABOVE the per-card TouchAreas
              // (the meta block below is Text-only and never hit-tests): with
              // every cover always visible, the former jump-to-clicked focus
              // skipped several books per side click. The zones wire NO double-clicked arm,
              // so rapid side-clicking can never compose into an accidental open
              // (patterns.md "double-clicked fires IN ADDITION"). `enabled:
              // !root.selection-mode` makes them pointer-transparent in selection
              // mode (a disabled TouchArea ignores input — vendored input_items.rs),
              // so selection clicks keep toggling the CLICKED book. The center
              // strip stays a GAP between the zones: the centered cover's own
              // TouchArea still handles focus and double-click-to-open there.
              TouchArea {
                  enabled: !root.selection-mode;
                  x: 0;
                  y: 0;
                  width: Math.max(parent.width / 2 - root.cover-step / 2, 0px);
                  height: 100%;
                  clicked => { root.move(-1); }
              }
              TouchArea {
                  enabled: !root.selection-mode;
                  x: parent.width / 2 + root.cover-step / 2;
                  y: 0;
                  width: Math.max(parent.width / 2 - root.cover-step / 2, 0px);
                  height: 100%;
                  clicked => { root.move(1); }
              }

              // ── Focused-book meta block (centered, below the cover row) ───────
              if root.focused-index >= 0 && root.focused-index < root.items.length : VerticalLayout {
                  x: (parent.width - self.width) / 2;
                  y: parent.height / 2 + root.cover-h / 2 - 8px;
                  width: 320px;
                  spacing: Theme.space-xs;
                  alignment: start;

                  Text {
                      text: root.items[root.focused-index].title;
                      color: Theme.text;
                      font-size: Theme.font-title;
                      font-weight: Theme.weight-bold;
                      horizontal-alignment: center;
                      overflow: elide;
                  }
                  Text {
                      // 1-based "current / total". `total` is 0 only until the cover
                      // controller resolves the page count in the background (or the
                      // book is opened); once resolved it is persisted and shows the
                      // real count, so this no longer reads "1 / 0" for a fresh book.
                      text: root.items[root.focused-index].current + " / " + root.items[root.focused-index].total;
                      color: Theme.text-muted;
                      font-size: Theme.font-label;
                      horizontal-alignment: center;
                  }
              }
          }
          }

    }

    // ── Top glass-pill nav (#83): centered, icon-only twin capsules. ──────────
    // Drawn LAST so it paints on top of the cover-flow (Slint has no per-item z;
    // paint order == declaration order). Kept OUTSIDE the FocusScope: it is mouse +
    // screen-reader oriented, and keyboard navigation stays owned by the carousel.
    // Clicking an item fires the existing rfd picker callback, then restores
    // keyboard focus to the carousel (preserving the old toolbar behavior).
    nav := NavBar {
        x: (parent.width - self.width) / 2;
        y: Theme.space-md;
        search-query <=> root.search-query;
        file-icon: @image-url("assets/file.svg");
        folder-icon: @image-url("assets/folder.svg");
        plus-icon: @image-url("assets/plus.svg");
        search-icon: @image-url("assets/search.svg");
        settings-icon: @image-url("assets/settings.svg");
        combined-add-picker: root.combined-add-picker;
        // §3.2-4: the Select ENTRY now lives IN the NavBar as a toggle capsule
        // (replacing the former entry pill in the slide-strip below).
        select-icon: @image-url("assets/filter.svg");
        // §10 Item D: the continue-reading capsule REUSES the ribbon's bookmark
        // glyph (same affordance, same asset) by user decision.
        bookmark-icon: @image-url("assets/bookmark.svg");
        selection-active: root.selection-mode;
        // Parity with the former pill's gate: `items` is the VISIBLE projection, so
        // under a no-results search the capsule faints exactly as the pill used to
        // hide — a Select affordance over an empty library / no-results panel is
        // noise. Deliberate divergence: we do NOT fold `!modal-open` in here. Like
        // the sibling add/settings capsules, the modal backdrop absorber already
        // blocks input; folding a modal flag in would flicker the capsule faint
        // under the scrim.
        select-enabled: root.items.length > 0;
        // Toggle the bulk-selection mode. The exit arm reproduces the Esc arm and
        // the toolbar's `exit` EXACTLY: clear the local flag, then fire
        // exit-selection() so Rust clears the selection set. The enter arm mirrors
        // the former pill — enter the mode ONLY; do NOT toggle the focused book
        // (that is the `x` key's job).
        toggle-selection => {
            if (root.selection-mode) {
                root.selection-mode = false;
                root.exit-selection();
            } else {
                root.selection-mode = true;
            }
        }
        // §2.6: recede the NavBar behind the foreground SelectionToolbar. Bound to
        // the SAME condition that slides the toolbar in (`selection-mode &&
        // !modal-open`), so the veil fades in the same beat as the bar transition.
        // The recede is purely a translucent veil (NO TouchArea) — the search
        // field and every nav capsule stay fully usable while receded
        // (selection-orthogonal). The veil's `animate background` (motion-fast)
        // matches the strip's `animate y`, so both land together.
        receded: root.selection-mode && !root.modal-open;
        search-changed(q) => { root.search-changed(q); }
        search-exit => { root.focus-self(); }
        add-books => { root.add-books(); root.focus-self(); }
        add-folder => { root.add-folder(); root.focus-self(); }
        settings => { root.settings(); }
        // Follow the `settings` forwarding style — NO root.focus-self(): the
        // bookmark-present path opens a book and navigates to the Viewer (carousel
        // focus is moot), and the no-bookmark path only pushes a status notice
        // while the carousel FocusScope keeps owning key input. A refocus here
        // would be a no-op at best and a focus-yank at worst.
        continue-reading => { root.continue-reading(); }
    }

    // ── Bulk-selection chrome (§2.6): a clipped slide-strip below the NavBar ───
    // Declared AFTER `nav := NavBar` (same paint-order / outside-FocusScope
    // rationale as the NavBar above): mouse + screen-reader oriented, drawn on
    // top of the cover-flow, and kept OUT of the keyboard focus chain so the
    // carousel FocusScope keeps owning key input.
    //
    // The strip now hosts ONLY the SelectionToolbar: it slides DOWN into view in
    // selection mode and UP out of view otherwise, inside this `clip: true` strip,
    // on `y` between 0 (visible) and -height (tucked up under the NavBar, clipped
    // away). The Select ENTRY no longer lives here — it is a toggle capsule INSIDE
    // the NavBar (§3.2-4). NO `opacity` is used anywhere (HiDPI child-blur gotcha,
    // docs/patterns.md — hard repo rule); the reveal is pure geometry plus the
    // NavBar's own recede veil.
    //
    // STRIP HEIGHT — fixed at `Theme.nav-pill-height` (the SelectionToolbar root's
    // own height). The FIXED height is deliberate: the strip reserves the same band
    // in both modes, so the cover-flow content below never jumps when the mode
    // flips, and the toolbar slides a FULL strip height to clear the clip edge
    // cleanly. Anchored just below the NavBar via `nav.y`/`nav.height`.
    //
    // INPUT GUARD (belt-and-braces): a slid-away bar is clipped out of view but its
    // TouchAreas could still hit-test if clipping leaks, so the slid-out toolbar is
    // also disabled. The SelectionToolbar takes an `active` flag ANDed into every
    // TouchArea/a11y action; that term matches the bar's own visible condition and
    // folds in `!modal-open` (mirroring the FocusScope's modal reject guard) so a
    // settings/guide/shortcuts modal suppresses the toolbar's pointer targets even
    // mid-slide.
    slide-strip := Rectangle {
        x: 0;
        y: nav.y + nav.height + Theme.nav-item-gap;
        width: 100%;
        height: Theme.nav-pill-height;
        clip: true;

        // Whether the toolbar is visible. `toolbar-shown` also drives the NavBar
        // recede binding above, so the recede and the slide animate in the same beat.
        property <bool> toolbar-shown: root.selection-mode && !root.modal-open;

        // SelectionToolbar — slides DOWN into view in selection mode and UP out of
        // view otherwise. `exit` reproduces the Esc arm EXACTLY: clear the local
        // mode flag and fire exit-selection().
        //
        // The toolbar is wrapped in a full-width CENTERING layout, not positioned
        // with an x formula: the toolbar's content-hug width only resolves when it
        // is a LAYOUT CHILD — absolutely positioned, it defaults to the PARENT's
        // width and the glass bar spanned the whole window (docs/patterns.md "An
        // element placed OUTSIDE a layout…"). Keeping that wrapper is what preserves
        // the measured-width centering through the slide. The wrapper itself slides
        // on `y`; `alignment: center` packs the toolbar at its preferred width.
        toolbar-wrap := HorizontalLayout {
            x: 0;
            width: 100%;
            height: Theme.nav-pill-height;
            // 0 = docked just below the NavBar; -height = tucked up under it
            // (clipped). Slides each time `toolbar-shown` flips.
            y: slide-strip.toolbar-shown ? 0 : -self.height;
            animate y { duration: Theme.motion-fast; }
            alignment: center;

            SelectionToolbar {
                count-text: root.selection-count-text;
                select-all-label: root.select-all-label;
                exit-a11y: Strings.selection-exit-a11y;
                narrow: root.narrow;
                // Delete (PR-5): pre-composed label + has-selection gate down, the
                // request-delete action up (Rust opens the ConfirmDialog).
                delete-label: root.delete-label;
                has-selection: root.has-selection;
                // Input/a11y guard: only the slid-in toolbar takes input.
                active: slide-strip.toolbar-shown;
                select-all => { root.select-all(); }
                request-delete => { root.request-delete(); }
                exit => { root.selection-mode = false; root.exit-selection(); }
            }
        }
    }
}
