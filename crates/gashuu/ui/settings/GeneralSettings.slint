// GeneralSettings — the "General" settings section as a standalone unit.
//
// Extracted verbatim from SettingsDialog.slint's inline General block (the
// language dropdown only). Renders its own eyebrow (suppressible via
// `show-title`). App-global, so the flat dialog gates it to the Library-default
// context; the component itself is context-neutral. Theme.* only.
import { Theme } from "../Theme.slint";
import { Strings } from "../Strings.slint";
import { SettingRow } from "../components/SettingRow.slint";
import { Dropdown } from "../components/Dropdown.slint";

export component GeneralSettings inherits VerticalLayout {
    // Index into the language dropdown model (En=0, Ja=1 — enum_adapters.rs
    // owns the authoritative ordering).
    in-out property <int> language-index;
    callback set-language(int);
    in property <bool> show-title: true;

    // Focus the first control (the language Dropdown) on open / drill-in.
    public function focus-first() {
        language-control.focus-control();
    }

    spacing: Theme.space-lg;
    if root.show-title : Text {
        text: Strings.settings-section-general;
        font-size: Theme.font-label;
        font-weight: Theme.weight-semibold;
        color: Theme.text-dim;
        horizontal-alignment: left;
    }
    SettingRow {
        label: Strings.settings-language-label;
        trailing: true;
        language-control := Dropdown {
            // Language names are deliberately NOT translated: a language switcher
            // always shows each option in its own tongue, so a user lost in the
            // wrong language can still find their own.
            model: ["English", "日本語"];
            current-index <=> root.language-index;
            a11y-label: Strings.settings-language-a11y;
            selected(i) => {
                root.set-language(i);
            }
        }
    }
}
