// Horizontal thumbnail strip below the page view; the cell matching `current-index`
// gets an accent border. TouchArea is non-focusable (won't steal focus from ViewerWindow).

import { Theme } from "Theme.slint";
import { ThumbnailCell } from "components/ThumbnailCell.slint";

export struct ThumbnailItem {
    image: image,
    // 0-based page index (matches the index used by ViewerState/ImageCache).
    page: int,
    // false while the thumbnail is still being decoded; shows a gray placeholder.
    loaded: bool,
    // true when decoding failed; shows a distinct red-tinted placeholder.
    // Only meaningful when loaded == false.
    failed: bool,
}

export component ThumbnailStrip inherits Rectangle {
    // ── In-properties ──────────────────────────────────────────────────────────
    in property <[ThumbnailItem]> thumbnails;
    // The page index that should receive the highlight border.
    in property <int> current-index;

    // ── Callbacks ──────────────────────────────────────────────────────────────
    // Fired with the 0-based page index when the user clicks a thumbnail cell.
    callback thumbnail-clicked(int);
    // Fired (pixel geometry, not indices) on scroll/resize so Rust decodes only
    // near-viewport pages. Args: first on-screen pixel, viewport width, per-cell stride.
    callback visible-range-changed(length /* first-px */, length /* viewport-w */, length /* cell-stride */);

    // ── Sizing constants ───────────────────────────────────────────────────────
    private property <length> cell-width: 110px;
    private property <length> cell-height: 130px;
    private property <length> cell-spacing: 6px;
    private property <length> image-area-height: 100px;

    // Resizing can widen the window; re-evaluate so newly-uncovered cells backfill.
    // (The initial bind does not fire `changed`; Rust requests a leading window at open.)
    changed width => {
        root.visible-range-changed(-fl.viewport-x, root.width, root.cell-width + root.cell-spacing);
    }

    // ── Colors ─────────────────────────────────────────────────────────────────
    // Strip background matches the viewer's black aesthetic.
    background: Theme.surface;

    // The strip height is set by the parent (ViewerWindow), which is the single
    // source of truth; cells fit within whatever height it provides.

    // ── Scrollable content ─────────────────────────────────────────────────────
    fl := Flickable {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        // Allow horizontal-only scrolling; viewport width is computed from
        // the number of cells so Slint knows the scrollable extent.
        viewport-width: (root.cell-width + root.cell-spacing) * root.thumbnails.length + root.cell-spacing;
        viewport-height: root.height;

        // Each scroll surfaces pixel geometry so Rust backfills newly-visible pages.
        // viewport-x is <= 0 as the user scrolls right, so the first pixel is -viewport-x.
        changed viewport-x => {
            root.visible-range-changed(-self.viewport-x, root.width, root.cell-width + root.cell-spacing);
        }

        HorizontalLayout {
            x: root.cell-spacing;
            y: 8px;
            spacing: root.cell-spacing;

            for item[idx] in root.thumbnails : Rectangle {
                width: root.cell-width;
                height: root.cell-height;

                // Thumbnail image area. ThumbnailCell owns the border, background, radius,
                // and all three image states; sized to the image area, label sits below.
                ThumbnailCell {
                    x: 0;
                    y: 0;
                    width: root.cell-width;
                    height: root.image-area-height;
                    source: item.image;
                    loaded: item.loaded;
                    failed: item.failed;
                    highlighted: item.page == root.current-index;
                    radius: Theme.radius-xs;
                }

                // ── Page number label ──────────────────────────────────────────
                // 1-based display (item.page is 0-based internally).
                Text {
                    x: 0;
                    y: root.image-area-height + 4px;
                    width: root.cell-width;
                    height: root.cell-height - root.image-area-height - 4px;
                    text: item.page + 1;
                    color: item.page == root.current-index ? Theme.accent : Theme.text-mid;
                    font-size: Theme.font-micro;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                // Click target. TouchArea is non-focusable in Slint and will not steal
                // keyboard focus from the FocusScope in ViewerWindow.
                TouchArea {
                    clicked => { root.thumbnail-clicked(item.page); }
                }
            }
        }
    }
}
