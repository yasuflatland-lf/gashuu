# ── FirstRunGuide ───────────────────────────────────────────────────────────

msgid "Welcome to gashuu"
msgstr "gashuu へようこそ"

msgid "A quick guide to get you started:"
msgstr "かんたんな使い方ガイド:"

msgid "Open: use the toolbar buttons — Open Folder… / Open Archive… (CBZ/ZIP/CBR/RAR)."
msgstr "開く: ツールバーの「フォルダーを開く…」「アーカイブを開く…」(CBZ/ZIP/CBR/RAR) ボタンを使います。"

msgid "Turn pages: Space = next, Backspace = previous. Arrow keys follow the reading direction."
msgstr "ページ送り: Space = 次へ、Backspace = 前へ。矢印キーは読む方向に従います。"

msgid "Modes: D = spread (single → double → auto), R = reading direction (LTR/RTL), C = cover layout."
msgstr "モード: D = ページ表示 (単ページ → 見開き → 自動)、R = 読む方向 (左から右 / 右から左)、C = 表紙レイアウト。"

msgid "Zoom & fit: + / - to zoom, 0 to reset, 1 for actual size, f to cycle fit mode. Wheel zooms at the cursor; drag to pan."
msgstr "ズームとフィット: + / - でズーム、0 でリセット、1 で原寸、f でフィット切替。ホイールはカーソル位置でズーム、ドラッグで移動します。"

msgid "Thumbnails: T toggles the thumbnail strip; click a thumbnail to jump to that page."
msgstr "サムネイル: T で一覧の表示を切替。サムネイルをクリックするとそのページへ移動します。"

msgid "Settings: open the Settings dialog from the toolbar to change these options anytime."
msgstr "設定: ツールバーから設定ダイアログを開くと、これらの設定をいつでも変更できます。"

msgid "Got it"
msgstr "わかりました"

